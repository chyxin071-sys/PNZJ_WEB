<view class="page-container">
  <scroll-view scroll-y class="form-scroll">
    <view class="form-group">
      <view class="label">客户姓名 <text class="required">*</text></view>    
      <input class="input-box" placeholder="输入客户姓名..." placeholder-class="ph" value="{{formData.name}}" bindinput="onInput" data-field="name" />
    </view>

    <view class="form-group">
      <view class="label">联系电话 <text class="required">*</text></view>    
      <input type="number" class="input-box" placeholder="输入11位手机号..." placeholder-class="ph" value="{{formData.phone}}" bindinput="onInput" data-field="phone" />
    </view>

    <view class="form-group">
      <view class="label">小区地址 <text class="required">*</text></view>    
      <input class="input-box" placeholder="如：恒大绿洲3栋101..." placeholder-class="ph" value="{{formData.address}}" bindinput="onInput" data-field="address" />
    </view>

    <view class="form-row-group">
      <view class="form-group half">
        <view class="label">房屋面积</view>
        <input type="number" class="input-box" placeholder="面积 (m²)" placeholder-class="ph" value="{{formData.area}}" bindinput="onInput" data-field="area" />
      </view>
      <view class="form-group half">
        <view class="label">需求类型</view>
        <picker bindchange="onPickerChange" data-field="requirementType" data-options="reqOptions" value="{{reqOptions.indexOf(formData.requirementType)}}" range="{{reqOptions}}">
          <view class="picker-box">
            <text>{{formData.requirementType}}</text>
            <view class="arrow-down"></view>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-row-group">
      <view class="form-group half">
        <view class="label">客户评级</view>
        <picker bindchange="onPickerChange" data-field="rating" data-options="ratingOptions" value="{{ratingOptions.indexOf(formData.rating)}}" range="{{ratingOptions}}">
          <view class="picker-box">
            <text>{{formData.rating}}级</text>
            <view class="arrow-down"></view>
          </view>
        </picker>
      </view>
      <view class="form-group half">
        <view class="label">当前状态</view>
        <picker bindchange="onPickerChange" data-field="status" data-options="statusOptions" value="{{statusOptions.indexOf(formData.status)}}" range="{{statusOptions}}">
          <view class="picker-box">
            <text>{{formData.status}}</text>
            <view class="arrow-down"></view>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-row-group">
      <view class="form-group half">
        <view class="label">装修预算</view>
        <picker bindchange="onPickerChange" data-field="budget" data-options="budgetOptions" value="{{budgetOptions.indexOf(formData.budget)}}" range="{{budgetOptions}}">
          <view class="picker-box">
            <text>{{formData.budget}}</text>
            <view class="arrow-down"></view>
          </view>
        </picker>
      </view>
      <view class="form-group half">
        <view class="label">客户来源</view>
        <picker bindchange="onPickerChange" data-field="source" data-options="sourceOptions" value="{{sourceOptions.indexOf(formData.source)}}" range="{{sourceOptions}}">
          <view class="picker-box">
            <text>{{formData.source}}</text>
            <view class="arrow-down"></view>
          </view>
        </picker>
      </view>
    </view>

    <view class="form-group" wx:if="{{formData.source === '其他'}}">
      <view class="label">其他来源</view>
      <input class="input-box" placeholder="请输入具体来源" placeholder-class="ph" value="{{customSource}}" bindinput="inputCustomSource" />
    </view>

    <view class="form-group">
      <view class="label">销售</view>
      <picker bindchange="onEmpChange" data-field="sales" data-list="salesList" data-index="salesIndex" value="{{salesIndex}}" range="{{salesList}}" range-key="name">
        <view class="picker-box">
          <text class="{{salesIndex === -1 ? 'ph' : ''}}">{{salesIndex !== -1 ? salesList[salesIndex].name : '请选择销售人员'}}</text>
          <view class="arrow-down"></view>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <view class="label">设计师</view>
      <picker bindchange="onEmpChange" data-field="designer" data-list="designerList" data-index="designerIndex" value="{{designerIndex}}" range="{{designerList}}" range-key="name">
        <view class="picker-box">
          <text class="{{designerIndex === -1 ? 'ph' : ''}}">{{designerIndex !== -1 ? designerList[designerIndex].name : '请选择设计师'}}</text>
          <view class="arrow-down"></view>
        </view>
      </picker>
    </view>

    <view class="form-group">
      <view class="label">项目经理</view>
      <picker bindchange="onEmpChange" data-field="manager" data-list="managerList" data-index="managerIndex" value="{{managerIndex}}" range="{{managerList}}" range-key="name">
        <view class="picker-box">
          <text class="{{managerIndex === -1 ? 'ph' : ''}}">{{managerIndex !== -1 ? managerList[managerIndex].name : '请选择项目经理'}}</text>
          <view class="arrow-down"></view>
        </view>
      </picker>
    </view>

    <view class="bottom-padding"></view>
  </scroll-view>

  <view class="bottom-bar">
    <view class="btn-cancel hover-scale" bindtap="goBack" wx:if="{{!isEdit}}">取消</view>
    <view class="btn-delete hover-scale" bindtap="deleteLead" wx:if="{{isEdit}}" style="flex: 1;">删除</view>
    <view class="btn-save hover-scale" bindtap="saveLead" style="flex: 2;">保存资料</view>
  </view>

  <!-- 签单确认弹窗 -->
  <view class="modal-mask" wx:if="{{showSignModal}}" bindtap="closeSignModal"></view>
  <view class="sign-modal" wx:if="{{showSignModal}}">
    <view class="sign-icon">🎉</view>
    <view class="sign-title">恭喜！确认签单？</view>
    <view class="sign-desc">为【{{formData.name}}】办理签单手续</view>
    
    <view class="form-group sign-date-picker">
      <text class="label">签单日期</text>
      <picker mode="date" value="{{signDate}}" bindchange="onSignDateChange">
        <view class="picker-view">
          <text>{{signDate}}</text>
          <view class="arrow-down"></view>
        </view>
      </picker>
    </view>

    <view class="sign-actions">
      <view class="btn-cancel hover-scale" bindtap="closeSignModal">再想想</view>
      <view class="btn-save hover-scale" bindtap="confirmSign" style="background: var(--amber-600); color: #fff;">确认签单</view>
    </view>
  </view>

  <!-- 签单成功喜报弹窗 (保守方案) -->
  <view class="modal-mask" wx:if="{{showSuccessModal}}"></view>
  <view class="success-modal" wx:if="{{showSuccessModal}}">
    <view class="success-header">
      <text class="success-badge">开单喜报</text>
    </view>
    <view class="success-body">
      <view class="success-title">品诺筑家 恭喜签约</view>
      <view class="success-desc">成功签约客户：<text class="highlight">{{formData.name}}</text></view>
    </view>
    <view class="btn-save hover-scale" bindtap="closeSuccessAndBack" style="margin-top: 60rpx; width: 80%; background: linear-gradient(135deg, var(--amber-600), var(--rose-600)); border-radius: 40rpx;">返回线索列表</view>
  </view>
</view>

