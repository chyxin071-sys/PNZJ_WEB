@import "../todoForm/index.wxss";

/* 签单弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
.sign-modal { position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 85%; background: #fff; border-radius: 32rpx; padding: 60rpx 40rpx; z-index: 1000; display: flex; flex-direction: column; align-items: center; text-align: center; }
.sign-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.sign-title { font-size: 40rpx; font-weight: bold; color: var(--amber-600); margin-bottom: 12rpx; }
.sign-desc { font-size: 28rpx; color: var(--primary-500); margin-bottom: 40rpx; }
.sign-date-picker { width: 100%; text-align: left; }
.sign-actions { display: flex; width: 100%; gap: 24rpx; margin-top: 40rpx; }

/* 签单成功喜报弹窗 (保守方案) */
.success-modal { position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 80%; background: #fff; border-radius: 32rpx; padding: 0 0 40rpx 0; z-index: 1000; overflow: hidden; display: flex; flex-direction: column; align-items: center; text-align: center; }
.success-header { width: 100%; background: linear-gradient(135deg, var(--amber-600), var(--rose-600)); padding: 40rpx 0; display: flex; justify-content: center; }
.success-badge { background: #fff; color: var(--rose-600); font-size: 36rpx; font-weight: bold; padding: 10rpx 32rpx; border-radius: 40rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); }
.success-body { padding: 40rpx 40rpx 0; width: 100%; box-sizing: border-box; }
.success-title { font-size: 40rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 20rpx; }
.success-desc { font-size: 30rpx; color: var(--primary-600); }
.success-desc .highlight { color: var(--rose-600); font-weight: bold; font-size: 34rpx; }

/* 多选弹窗 */
.multi-select-modal { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 32rpx 32rpx 0 0; z-index: 1000; padding-bottom: env(safe-area-inset-bottom); display: flex; flex-direction: column; max-height: 80vh; }
.ms-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 40rpx; border-bottom: 1rpx solid #f1f5f9; }
.ms-cancel { font-size: 30rpx; color: #94a3b8; padding: 10rpx; margin-left: -10rpx; }
.ms-title { font-size: 32rpx; font-weight: bold; color: #1e293b; }
.ms-confirm { font-size: 30rpx; font-weight: bold; color: var(--primary-600); padding: 10rpx; margin-right: -10rpx; }
.ms-list { flex: 1; padding: 0 40rpx; box-sizing: border-box; }
.ms-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 0; border-bottom: 1rpx solid #f8fafc; }
.ms-name { font-size: 30rpx; color: #334155; font-weight: 500; }
.checkbox { width: 40rpx; height: 40rpx; border-radius: 8rpx; border: 2rpx solid #cbd5e1; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.checkbox.checked { background: var(--primary-600); border-color: var(--primary-600); }
.checkmark { width: 12rpx; height: 20rpx; border: solid #fff; border-width: 0 4rpx 4rpx 0; transform: rotate(45deg); margin-top: -4rpx; }


