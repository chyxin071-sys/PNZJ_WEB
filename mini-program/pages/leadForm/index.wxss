@import "../todoForm/index.wxss";

/* 签单弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; }
.sign-modal { position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 85%; background: #fff; border-radius: 32rpx; padding: 60rpx 40rpx; z-index: 1000; display: flex; flex-direction: column; align-items: center; text-align: center; }
.sign-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.sign-title { font-size: 40rpx; font-weight: bold; color: #f59e0b; margin-bottom: 12rpx; }
.sign-desc { font-size: 28rpx; color: var(--primary-500); margin-bottom: 40rpx; }
.sign-date-picker { width: 100%; text-align: left; }
.sign-actions { display: flex; width: 100%; gap: 24rpx; margin-top: 40rpx; }

/* 签单成功喜报弹窗 (保守方案) */
.success-modal { position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 80%; background: #fff; border-radius: 32rpx; padding: 0 0 40rpx 0; z-index: 1000; overflow: hidden; display: flex; flex-direction: column; align-items: center; text-align: center; }
.success-header { width: 100%; background: linear-gradient(135deg, #f59e0b, #ef4444); padding: 40rpx 0; display: flex; justify-content: center; }
.success-badge { background: #fff; color: #ef4444; font-size: 36rpx; font-weight: bold; padding: 10rpx 32rpx; border-radius: 40rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1); }
.success-body { padding: 40rpx 40rpx 0; width: 100%; box-sizing: border-box; }
.success-title { font-size: 40rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 20rpx; }
.success-desc { font-size: 30rpx; color: var(--primary-600); }
.success-desc .highlight { color: #ef4444; font-weight: bold; font-size: 34rpx; }