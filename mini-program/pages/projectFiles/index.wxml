<wxs src="../../utils/format.wxs" module="format" />
<view class="container" style="padding-bottom: {{(activeTab === 'files' && isUploader) || (activeTab === 'materials' && materials.length > 0) ? 'calc(240rpx + env(safe-area-inset-bottom))' : 'env(safe-area-inset-bottom)'}};">
  <view class="header bg-white p-6 shadow-sm mb-4 border-b border-gray-100 flex items-center justify-between">
    <view>
      <view class="text-lg font-bold text-gray-900" style="display: flex; align-items: center;">
        <text>{{lead.name}}的项目资料</text>
        <canvas type="2d" id="materialShareCanvas" style="width: 500px; height: 400px; position: fixed; left: -9999px; top: -9999px;"></canvas>
      </view>
      <view class="text-sm text-gray-500 mt-1">{{lead.address}}</view>
    </view>
  </view>

  <!-- 顶部 Tab 切换 -->
  <view style="display: flex; background: #fff; border-bottom: 1rpx solid #f1f5f9; margin-bottom: 24rpx; padding: 0 40rpx;">
    <view bindtap="switchTab" data-tab="files" style="flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; font-weight: {{activeTab === 'files' ? 'bold' : 'normal'}}; color: {{activeTab === 'files' ? 'var(--primary-900)' : '#64748b'}}; border-bottom: 4rpx solid {{activeTab === 'files' ? 'var(--primary-900)' : 'transparent'}};">
      文件图纸
    </view>
    <view bindtap="switchTab" data-tab="materials" style="flex: 1; text-align: center; padding: 24rpx 0; font-size: 28rpx; font-weight: {{activeTab === 'materials' ? 'bold' : 'normal'}}; color: {{activeTab === 'materials' ? 'var(--primary-900)' : '#64748b'}}; border-bottom: 4rpx solid {{activeTab === 'materials' ? 'var(--primary-900)' : 'transparent'}};">
      主材清单
    </view>
  </view>

  <scroll-view scroll-y class="flex-1 w-full px-4 box-border">
    <!-- === 文件图纸 Tab === -->
    <block wx:if="{{activeTab === 'files'}}">
      <!-- 空状态 -->
      <view wx:if="{{groupedFiles.length === 0}}" class="flex flex-col items-center justify-center py-20">
        <view class="w-24 h-24 mb-4 bg-gray-100 rounded-full flex items-center justify-center">
          <text class="text-gray-400 text-3xl">📄</text>
        </view>
        <text class="text-gray-500 text-sm">暂无项目资料，请点击下方按钮上传</text>
      </view>

      <!-- 文件夹列表 -->
      <block wx:for="{{groupedFiles}}" wx:key="folderName" wx:for-item="group" wx:for-index="catIndex">
        <view style="margin-bottom: 40rpx;">
          <!-- 文件夹标题 -->
          <view bindtap="toggleFolder" data-index="{{catIndex}}" style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 12rpx 0;">
            <view style="display: flex; align-items: center; gap: 12rpx; flex: 1; min-width: 0;">
              <view style="width: 8rpx; height: 32rpx; background: var(--primary-600); border-radius: 4rpx; flex-shrink: 0;"></view>
              <view style="font-size: 32rpx; font-weight: bold; color: var(--primary-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{group.folderName}}</view>
              <view style="font-size: 24rpx; color: #94a3b8; margin-left: 8rpx; flex-shrink: 0;">{{group.items.length}} 项</view>
            </view>
            <view style="display: flex; align-items: center; gap: 24rpx; flex-shrink: 0; margin-left: 20rpx;">
              <view wx:if="{{isUploader && group.folderName !== '默认文件夹'}}" catchtap="openFolderOptions" data-foldername="{{group.folderName}}" style="padding: 4rpx 16rpx; display: flex; align-items: center; justify-content: center;">
                <view class="icon-edit-folder"></view>
              </view>
              <view style="color: #94a3b8; font-size: 24rpx; transition: transform 0.3s; transform: rotate({{group.isCollapsed ? '-90deg' : '0'}});">
                ▼
              </view>
            </view>
          </view>
          
          <view wx:if="{{!group.isCollapsed}}">
            <view wx:if="{{group.items.length === 0}}" style="padding: 24rpx; text-align: center; color: #94a3b8; font-size: 24rpx; background: #f8fafc; border-radius: 16rpx; border: 2rpx dashed #e2e8f0;">
              该文件夹为空
            </view>

            <!-- 文件列表 -->
              <view wx:for="{{group.items}}" wx:key="fileID" class="mb-4" style="border-radius: 32rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02); border: 2rpx solid #f3f4f6; background: #fff;">
                <scroll-view class="swipe-area" scroll-x enhanced="{{true}}" show-scrollbar="{{false}}" bounces="{{false}}" paging-enabled="{{false}}" fast-deceleration="{{true}}" style="width: 100%; white-space: nowrap; scroll-snap-type: x mandatory;">
                  <view class="swipe-view" style="display: inline-flex; flex-direction: row; min-width: 100%; align-items: stretch;">
                    <!-- 顶层可滑动内容区 -->
                <view class="bg-white p-4 flex justify-center items-center" style="width: calc(100vw - 2rem - 4rpx); scroll-snap-align: start; flex-shrink: 0; box-sizing: border-box; white-space: normal;" bindtap="previewFile" data-item="{{item}}" hover-class="bg-gray-50">
                  <!-- 文件图标/缩略图 -->
                  <view style="width: 80rpx; height: 80rpx; flex-shrink: 0; border-radius: 12rpx; overflow: hidden; background: #f8fafc; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e2e8f0; margin-right: 20rpx;">
                    <image wx:if="{{item.type === 'image' || format.getFileIconText(format.getFileExt(item.name)) === 'IMG'}}" src="{{format.formatImageUrl(item.fileID || item.url)}}" mode="aspectFill" style="width: 100%; height: 100%;"></image>
                    <view wx:else style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: {{format.getFileIconColor(format.getFileExt(item.name))}}20;">
                      <text style="font-size: 22rpx; font-weight: bold; color: {{format.getFileIconColor(format.getFileExt(item.name))}};">{{format.getFileIconText(format.getFileExt(item.name))}}</text>
                    </view>
                  </view>
                  <!-- 文件信息 -->
                  <view class="flex-1 overflow-hidden pl-2">
                    <view class="text-sm font-bold text-gray-900 mb-1 truncate flex items-center gap-2" style="white-space: normal; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
                      {{item.name}}
                      <text style="font-size: 20rpx; background: {{item.isVisible === false ? '#f1f5f9' : 'var(--emerald-50)'}}; color: {{item.isVisible === false ? '#64748b' : 'var(--emerald-600)'}}; padding: 2rpx 8rpx; border-radius: 8rpx; font-weight: normal; flex-shrink: 0;">{{item.isVisible === false ? '内部' : '公开'}}</text>
                    </view>
                    <view class="text-xs text-gray-500 flex items-center">
                      <text class="mr-2">{{item.sizeStr}}</text>
                      <text class="text-gray-300 mr-2">|</text>
                      <text class="mr-2">{{item.uploader || '未知'}}</text>
                      <text class="text-gray-300 mr-2">|</text>
                      <text>{{item.displayTime}}</text>
                    </view>
                  </view>
                </view>
                
                <!-- 右侧滑动操作按钮 -->
                <view wx:if="{{isUploader}}" style="display: flex; flex-shrink: 0; width: 300rpx; scroll-snap-align: end;">
                  <view catchtap="toggleVisibility" data-id="{{item.fileID}}" style="width: 100rpx; background: {{item.isVisible === false ? 'var(--emerald-600)' : '#94a3b8'}}; color: white; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; height: 100%;">
                    {{item.isVisible === false ? '公开' : '内部'}}
                  </view>
                  <view catchtap="openMoveFileModal" data-id="{{item.fileID}}" style="width: 100rpx; background: var(--amber-500); color: white; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; height: 100%;">
                    移动
                  </view>
                  <view catchtap="deleteFile" data-id="{{item.fileID}}" style="width: 100rpx; background: var(--rose-600); color: white; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; height: 100%;">
                    删除
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>
          </view>
        </view>
      </block>
    </block>

    <!-- === 主材清单 Tab === -->
    <block wx:if="{{activeTab === 'materials'}}">
      <view wx:if="{{materials.length === 0}}" class="flex flex-col items-center justify-center py-20">
        <view class="w-24 h-24 mb-4 bg-gray-100 rounded-full flex items-center justify-center">
          <text class="text-gray-400 text-3xl">📦</text>
        </view>
        <text class="text-gray-500 text-sm">暂无主材记录，请点击相应分类下的按钮添加</text>
      </view>

      <block wx:for="{{groupedMaterials}}" wx:key="category" wx:for-item="group" wx:for-index="catIndex">
        <view style="margin-bottom: 40rpx;">
          <!-- 分类标题 -->
          <view style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; padding: 12rpx 0;">
            <view style="display: flex; flex-direction: column; gap: 4rpx; flex: 1; min-width: 0;">
              <view style="display: flex; align-items: center; gap: 12rpx;">
                <view style="width: 8rpx; height: 32rpx; background: var(--primary-600); border-radius: 4rpx; flex-shrink: 0;"></view>
                <view style="font-size: 32rpx; font-weight: bold; color: var(--primary-900); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">{{group.category}}</view>
                <view style="font-size: 24rpx; color: #94a3b8; margin-left: 8rpx; flex-shrink: 0;">{{group.items.length}} 项</view>
              </view>
              <!-- 类别状态 -->
              <view wx:if="{{lead.materialCategoryStates[group.category]}}" style="font-size: 22rpx; color: {{lead.materialCategoryStates[group.category].status === '已确认' ? 'var(--emerald-600)' : 'var(--amber-600)'}}; margin-top: 4rpx; margin-left: 20rpx;">
                {{lead.materialCategoryStates[group.category].status === '已确认' ? '客户已确认 | ' + (lead.materialCategoryStates[group.category].confirmedAt || '') : '待确认 | 发送时间: ' + (lead.materialCategoryStates[group.category].sentAt || '')}}
              </view>
            </view>
            <!-- 添加按钮 -->
            <view wx:if="{{isUploader}}" bindtap="openAddMaterial" data-category="{{group.category}}" style="display: flex; align-items: center; gap: 4rpx; color: var(--primary-600); font-size: 28rpx; padding: 8rpx 16rpx; border: 1rpx dashed var(--primary-300); border-radius: 8rpx;" hover-class="bg-gray-100">
              <text style="font-size: 32rpx; line-height: 1;">+</text>
              <text>添加</text>
            </view>
          </view>

          <!-- 分类下的主材列表 -->
          <view wx:for="{{group.items}}" wx:key="id" class="mb-4" style="border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.02); border: 1rpx solid #e2e8f0; background: #fff;">
            <scroll-view scroll-x enhanced="{{true}}" show-scrollbar="{{false}}" bounces="{{false}}" paging-enabled="{{false}}" fast-deceleration="{{true}}" style="width: 100%; white-space: nowrap; scroll-snap-type: x mandatory;">
              <view class="swipe-view" style="display: inline-flex; flex-direction: row; min-width: 100%; align-items: stretch;">
                  <view style="width: calc(100vw - 2rem - 2rpx); scroll-snap-align: start; flex-shrink: 0; box-sizing: border-box; white-space: normal; padding: 24rpx;">
                  <!-- 标题行 -->
                  <view wx:if="{{item.displayTitle}}" style="font-size: 32rpx; font-weight: bold; color: #1e293b; margin-bottom: {{item.displayLine1 || item.displayLine2 || item.remark ? '12rpx' : '0'}};">{{item.displayTitle}}</view>

                  <!-- 第一行信息 -->
                  <view wx:if="{{item.displayLine1}}" style="font-size: 28rpx; color: #334155; margin-bottom: {{item.displayLine2 || item.remark ? '8rpx' : '0'}};">{{item.displayLine1}}</view>

                  <!-- 第二行信息 -->
                  <view wx:if="{{item.displayLine2}}" style="font-size: 24rpx; color: #64748b; margin-bottom: {{item.remark ? '8rpx' : '0'}};">{{item.displayLine2}}</view>

                  <!-- 备注 -->
                  <view wx:if="{{item.remark}}" style="font-size: 24rpx; color: #94a3b8; margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx dashed #f1f5f9;">
                    <text style="margin-right: 8rpx;">备注:</text><text>{{item.remark}}</text>
                  </view>

                  <!-- 图片区域 -->
                  <view style="margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx dashed #f1f5f9;">
                    <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;">
                      <text style="font-size: 24rpx; color: #64748b; font-weight: bold;">材料图片</text>
                      <view wx:if="{{isUploader}}" catchtap="toggleMaterialImageEdit" data-catindex="{{catIndex}}" data-index="{{index}}" style="font-size: 24rpx; color: {{item.isEditingImages ? 'var(--primary-600)' : '#94a3b8'}}; padding: 4rpx 16rpx; background: {{item.isEditingImages ? 'var(--primary-50)' : '#f8fafc'}}; border-radius: 24rpx;">
                        {{item.isEditingImages ? '确认' : '编辑'}}
                      </view>
                    </view>
                    <view style="display: flex; flex-wrap: wrap; gap: 16rpx;">
                      <block wx:for="{{item.images || []}}" wx:key="*this" wx:for-item="imgUrl" wx:for-index="imgIdx">
                        <view style="width: calc((100% - 48rpx) / 4); box-sizing: border-box; aspect-ratio: 1; position: relative; border-radius: 8rpx; overflow: hidden; border: 1rpx solid #e2e8f0;">
                          <image src="{{imgUrl}}" mode="aspectFill" catchtap="previewMaterialImage" data-urls="{{item.images}}" data-current="{{imgUrl}}" style="width: 100%; height: 100%;"></image>
                          <view wx:if="{{item.isEditingImages}}" catchtap="deleteMaterialImage" data-catindex="{{catIndex}}" data-index="{{index}}" data-imgindex="{{imgIdx}}" style="position: absolute; top: 0; right: 0; width: 40rpx; height: 40rpx; background: rgba(225, 29, 72, 0.9); border-bottom-left-radius: 8rpx; display: flex; align-items: center; justify-content: center;">
                            <text style="color: white; font-size: 24rpx; font-weight: bold; line-height: 1;">×</text>
                          </view>
                        </view>
                      </block>
                      <view wx:if="{{item.isEditingImages}}" catchtap="addMaterialImage" data-catindex="{{catIndex}}" data-index="{{index}}" style="width: calc((100% - 48rpx) / 4); box-sizing: border-box; aspect-ratio: 1; border-radius: 8rpx; border: 2rpx dashed #cbd5e1; display: flex; align-items: center; justify-content: center; background: #f8fafc;">
                        <text style="font-size: 48rpx; color: #94a3b8; font-weight: 300;">+</text>
                      </view>
                      <view wx:if="{{!item.isEditingImages && (!item.images || item.images.length === 0)}}" style="width: 100%; text-align: center; padding: 20rpx 0; color: #cbd5e1; font-size: 24rpx;">
                        暂无图片
                      </view>
                    </view>
                  </view>
                </view>

                <!-- 左滑操作按钮 -->
                <view wx:if="{{isUploader}}" style="display: flex; flex-shrink: 0; width: 200rpx; scroll-snap-align: end;">
                  <view catchtap="openEditMaterial" data-catindex="{{catIndex}}" data-index="{{index}}" style="width: 100rpx; background: var(--primary-600); color: white; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; height: 100%;">
                    编辑
                  </view>
                  <view catchtap="deleteMaterial" data-catindex="{{catIndex}}" data-index="{{index}}" style="width: 100rpx; background: var(--rose-600); color: white; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; height: 100%;">
                    删除
                  </view>
                </view>
              </view>
            </scroll-view>
          </view>

        </view>
      </block>
    </block>
  </scroll-view>

  <!-- 底部固定上传按钮 -->
  <view wx:if="{{activeTab === 'files' && isUploader}}" style="position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-top: 1rpx solid #f1f5f9; z-index: 100; display: flex; flex-direction: column; gap: 16rpx; box-sizing: border-box;">
    <view style="font-size: 22rpx; color: #94a3b8; text-align: center;">
      为确保上传稳定性，大文件建议分批上传
    </view>
    <view style="display: flex; gap: 24rpx; width: 100%;">
      <view bindtap="chooseAndUpload" style="flex: 1; background: var(--primary-900); color: #fff; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; box-shadow: 0 8rpx 24rpx rgba(74,64,58,0.2);" class="active:opacity-80 transition-opacity">
        上传资料
      </view>
    </view>
  </view>

  <!-- ====== 底部悬浮操作栏：仅当存在主材数据时显示发送确认按钮 ====== -->
  <view wx:if="{{activeTab === 'materials' && materials.length > 0}}" style="position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-top: 1rpx solid #f1f5f9; z-index: 100; box-sizing: border-box; display: flex; flex-direction: column; gap: 16rpx;">
    <view style="font-size: 24rpx; color: #64748b; text-align: center;">
      将主材清单发送给客户，以供客户确认
    </view>
    <view style="display: flex; gap: 24rpx; width: 100%;">
      <!-- 如果已建立工地，则可点击打开分享选择弹窗 -->
      <button wx:if="{{projectId}}" bindtap="openShareCategoryModal" style="flex: 1; background: var(--primary-900); color: #fff; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; box-shadow: 0 8rpx 24rpx rgba(74,64,58,0.2); margin: 0;" class="active:opacity-80 transition-opacity">
        发送给客户确认
      </button>
      <!-- 如果未建立工地，点击时提示错误 -->
      <button wx:else bindtap="handleNoProjectShare" style="flex: 1; background: var(--primary-900); color: #fff; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; box-shadow: 0 8rpx 24rpx rgba(74,64,58,0.2); margin: 0;" class="active:opacity-80 transition-opacity">
        发送给客户确认
      </button>
    </view>
  </view>

  <!-- 移动文件弹窗 -->
  <view wx:if="{{showMoveFileModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; display: flex; justify-content: center; align-items: center;">
    <view style="background: #fff; width: 85%; border-radius: 24rpx; overflow: hidden;">
      <view style="padding: 32rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
        <view style="font-size: 32rpx; font-weight: bold;">移动文件至</view>
        <view bindtap="closeMoveFileModal" style="font-size: 40rpx; color: #94a3b8; line-height: 1;">×</view>
      </view>
      <view style="padding: 32rpx; display: flex; flex-direction: column; gap: 24rpx;">
        <view>
          <view style="font-size: 24rpx; color: #64748b; margin-bottom: 8rpx;">选择目标文件夹</view>
          <picker mode="selector" range="{{folderOptions}}" range-key="" bindchange="onMoveFolderChange">
            <view style="background: #f8fafc; padding: 20rpx; border-radius: 8rpx; font-size: 28rpx; color: #334155; display: flex; justify-content: space-between;">
              <text>{{moveFolderIndex == folders.length ? '新建文件夹...' : folders[moveFolderIndex]}}</text>
              <text style="color: #94a3b8;">▼</text>
            </view>
          </picker>
        </view>
        <view wx:if="{{moveFolderIndex == folders.length}}">
          <view style="font-size: 24rpx; color: #64748b; margin-bottom: 8rpx;">新建文件夹名称 <text style="color: var(--rose-600);">*</text></view>
          <input placeholder="请输入文件夹名称" value="{{moveNewFolderName}}" bindinput="onMoveNewFolderInput" style="background: #f8fafc; padding: 0 20rpx; height: 80rpx; line-height: 80rpx; border-radius: 8rpx; font-size: 28rpx; width: 100%; box-sizing: border-box;" />
        </view>
      </view>
      <view style="display: flex; border-top: 1rpx solid #f1f5f9;">
        <view bindtap="closeMoveFileModal" style="flex: 1; padding: 30rpx 0; text-align: center; font-size: 30rpx; color: #64748b;">取消</view>
        <view bindtap="confirmMoveFile" style="flex: 1; padding: 30rpx 0; text-align: center; font-size: 30rpx; font-weight: bold; color: #fff; background: var(--primary-900);">确定移动</view>
      </view>
    </view>
  </view>

  <!-- 重命名文件夹弹窗 -->
  <view wx:if="{{showRenameFolderModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 999; display: flex; justify-content: center; align-items: center;">
    <view style="background: #fff; width: 85%; border-radius: 24rpx; overflow: hidden;">
      <view style="padding: 32rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
        <view style="font-size: 32rpx; font-weight: bold;">重命名文件夹</view>
        <view bindtap="closeRenameFolderModal" style="font-size: 40rpx; color: #94a3b8; line-height: 1;">×</view>
      </view>
      <view style="padding: 32rpx; display: flex; flex-direction: column; gap: 24rpx;">
        <view>
          <view style="font-size: 24rpx; color: #64748b; margin-bottom: 8rpx;">原文件夹名称</view>
          <view style="background: #f1f5f9; padding: 0 20rpx; height: 80rpx; line-height: 80rpx; border-radius: 8rpx; font-size: 28rpx; color: #94a3b8; width: 100%; box-sizing: border-box;">{{oldFolderName}}</view>
        </view>
        <view>
          <view style="font-size: 24rpx; color: #64748b; margin-bottom: 8rpx;">新文件夹名称 <text style="color: var(--rose-600);">*</text></view>
          <input placeholder="请输入新文件夹名称" value="{{renameFolderNameInput}}" bindinput="onRenameFolderInput" style="background: #f8fafc; padding: 0 20rpx; height: 80rpx; line-height: 80rpx; border-radius: 8rpx; font-size: 28rpx; width: 100%; box-sizing: border-box;" />
        </view>
      </view>
      <view style="display: flex; border-top: 1rpx solid #f1f5f9;">
        <view bindtap="closeRenameFolderModal" style="flex: 1; padding: 30rpx 0; text-align: center; font-size: 30rpx; color: #64748b;">取消</view>
        <view bindtap="confirmRenameFolder" style="flex: 1; padding: 30rpx 0; text-align: center; font-size: 30rpx; font-weight: bold; color: #fff; background: var(--primary-900);">确定修改</view>
      </view>
    </view>
  </view>

