@import "../index/index.wxss";

/* ===== 顶部用户 Banner ===== */
.user-banner {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  padding: 32rpx 32rpx 28rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.user-banner:active {
  background: #f8fafc;
}

.banner-avatar-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}

.banner-avatar-img {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
}

.banner-avatar-text {
  font-size: 36rpx;
  font-weight: bold;
}

.avatar-bg-admin   { background: #faf5ff; color: #7e22ce; }
.avatar-bg-sales   { background: #eff6ff; color: #1d4ed8; }
.avatar-bg-designer { background: var(--emerald-50); color: var(--emerald-600); }
.avatar-bg-manager { background: #fffbeb; color: var(--amber-600); }
.avatar-bg-finance { background: #fff1f2; color: #be123c; }
.avatar-bg-default { background: #f1f5f9; color: #64748b; }

.banner-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.banner-greeting {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-900);
}

.banner-sub {
  font-size: 24rpx;
  color: var(--primary-400);
}

.banner-arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 3rpx solid #cbd5e1;
  border-right: 3rpx solid #cbd5e1;
  transform: rotate(45deg);
  flex-shrink: 0;
}

/* ===== Tab 切换栏 ===== */
.tab-bar {
  display: flex;
  background: #fff;
  border-bottom: 1rpx solid #f1f5f9;
  padding: 0 16rpx;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: var(--primary-400);
  position: relative;
}

.tab-active {
  color: var(--primary-900);
  font-weight: bold;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  width: 60%;
  height: 4rpx;
  background: var(--primary-900);
  border-radius: 4rpx;
}

.tab-badge {
  background: #ef4444;
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
  line-height: 1;
}

/* ===== 消息列表 ===== */
.list-container {
  flex: 1;
  padding: 24rpx 32rpx;
  width: 100%;
  box-sizing: border-box;
}

.swipe-wrap {
  width: 100%;
  margin-bottom: 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.swipe-area {
  width: 100%;
  overflow: hidden;
  border-radius: 24rpx;
}

.swipe-view {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  min-width: 100%;
  align-items: stretch;
}

/* 消息卡片（复用 todo-card 基础样式） */
.todo-card {
  margin-bottom: 0 !important;
}

.unread-card {
  border-left: 6rpx solid #3b82f6 !important;
}

.read {
  opacity: 0.7;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.sender-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.avatar-circle {
  width: 64rpx;
  height: 64rpx;
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.avatar-circle-img {
  object-fit: cover;
  background: #f1f5f9;
}

.avatar-bg-system { background: #f1f5f9; color: #64748b; }

.sender-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.sender-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary-900);
}

.item-time {
  font-size: 22rpx;
  color: var(--primary-400);
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 8rpx;
  background: #3b82f6;
  flex-shrink: 0;
}

.icon-star-filled {
  color: var(--amber-600);
  font-size: 32rpx;
  flex-shrink: 0;
}

.card-body-msg {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.msg-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-900);
}

.msg-desc {
  font-size: 26rpx;
  color: var(--primary-500);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 滑动操作按钮 */
.swipe-actions {
  width: 280rpx;
  display: flex;
  flex-shrink: 0;
}

.action-btn {
  width: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.btn-star { background: var(--amber-500); }
.btn-delete {
  background: var(--rose-500);
  border-top-right-radius: 24rpx;
  border-bottom-right-radius: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
  color: var(--primary-400);
  font-size: 30rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #f1f5f9;
  border-radius: 80rpx;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-icon::after {
  content: "!";
  position: static;
  transform: none;
  font-size: 100rpx;
  font-weight: bold;
  color: #cbd5e1;
  line-height: 1;
  background: transparent;
  width: auto;
  height: auto;
}
