<view class="page-container">
  <!-- 顶部导航栏 (Tabs + 个人中心入口) -->
  <view class="top-bar">
    <view class="tabs">
      <view class="tab {{activeTab === 'unread' ? 'active' : ''}}" bindtap="switchTab" data-tab="unread">未读消息</view>
      <view class="tab {{activeTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">全部消息</view>
      <view class="tab {{activeTab === 'starred' ? 'active' : ''}}" bindtap="switchTab" data-tab="starred">收藏</view>
    </view>
    <view class="profile-entry" bindtap="goToProfile">
      <view class="mini-avatar bg-{{userInfo.role || 'default'}}">
        <text>{{userInfo.name ? userInfo.name[0] : '用'}}</text>
      </view>
    </view>
  </view>

  <view class="list-container">
    <block wx:if="{{notifications.length > 0}}">
      <view class="swipe-wrap" wx:for="{{notifications}}" wx:key="_id" style="transform: translateZ(0);">
        <scroll-view class="swipe-area" scroll-x enhanced show-scrollbar="{{false}}" bounces="{{false}}" paging-enabled="{{false}}" fast-deceleration="{{true}}" style="width: 100%; white-space: nowrap; scroll-snap-type: x mandatory;">
          <view class="swipe-view" style="display: flex; flex-direction: row; min-width: 100%; align-items: stretch;">
            
            <!-- 表面内容卡片 (滚动对齐点) -->
            <view class="notification-item {{item.isRead ? 'read' : 'unread'}}" style="width: 100%; scroll-snap-align: start; flex-shrink: 0; white-space: normal; box-sizing: border-box;" bindtap="handleNotificationClick" data-item="{{item}}">
              <view class="item-icon">
                <view class="avatar-circle avatar-bg-{{item.senderRole || 'default'}}" wx:if="{{item.senderName && item.senderName !== '系统'}}">{{item.senderName[0]}}</view>
                <view class="avatar-circle avatar-bg-system" wx:elif="{{item.senderName === '系统' || !item.senderName}}">系</view>
                <view class="icon-circle {{item.type}}" wx:else></view>
              </view>
              <view class="item-content">
                <view class="item-header">
                  <view class="item-title-wrap">
                    <text class="item-title">{{item.title}}</text>
                    <text wx:if="{{item.isStarred}}" class="icon-star-filled">★</text>
                  </view>
                  <text class="item-time">{{item.createTimeStr}}</text>
                </view>
                <view class="item-desc">{{item.content}}</view>
              </view>
            </view>
            
            <!-- 右侧滑动按钮区域 (滚动对齐点) -->
            <view class="swipe-actions" style="width: 280rpx; display: flex; flex-shrink: 0; scroll-snap-align: end; background: transparent;">
              <view class="action-btn btn-star" catchtap="toggleStar" data-id="{{item._id}}" data-index="{{index}}">{{item.isStarred ? '取消收藏' : '收藏'}}</view>
              <view class="action-btn btn-delete" catchtap="deleteNotification" data-id="{{item._id}}" data-index="{{index}}">删除</view>
            </view>
            
          </view>
        </scroll-view>
      </view>
    </block>
    
    <view class="empty-state" wx:else>
      <view class="empty-icon"></view>
      <text>暂无{{activeTab === 'unread' ? '未读' : (activeTab === 'starred' ? '收藏' : '')}}通知消息</text>
    </view>
    
    <view class="pb-tabbar"></view>
  </view>
</view>
