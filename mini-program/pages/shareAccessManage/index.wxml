<!--pages/shareAccessManage/index.wxml-->
<view style="min-height: 100vh; background: #f8fafc; padding: 32rpx;">

  <view wx:if="{{loading}}" style="padding: 100rpx 0; text-align: center;">
    <text style="font-size: 28rpx; color: #94a3b8;">加载中...</text>
  </view>

  <block wx:else>
    <!-- 工地标题 -->
    <view style="background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);">
      <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; margin-bottom: 8rpx;">{{project.address || '工地进度'}}</view>
      <view style="font-size: 26rpx; color: #64748b;">分享查看申请管理</view>
    </view>

    <!-- 申请列表 -->
    <view wx:if="{{requests.length === 0}}" style="text-align: center; padding: 100rpx 0;">
      <view style="font-size: 60rpx; margin-bottom: 20rpx;">📋</view>
      <view style="font-size: 28rpx; color: #94a3b8;">暂无查看申请</view>
    </view>

    <view wx:for="{{requests}}" wx:key="_id" style="background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);">
      <view style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx;">
        <view>
          <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; margin-bottom: 8rpx;">{{item.name}}</view>
          <view style="font-size: 26rpx; color: #64748b;">关系：{{item.relation}}</view>
          <view wx:if="{{item.phone}}" style="font-size: 26rpx; color: #64748b; margin-top: 4rpx;">电话：{{item.phone}}</view>
        </view>
        <view>
          <view wx:if="{{item.status === 'pending'}}" style="font-size: 22rpx; color: var(--amber-600); background: var(--amber-50); padding: 6rpx 20rpx; border-radius: 20rpx; font-weight: bold;">待审核</view>
          <view wx:elif="{{item.status === 'approved'}}" style="font-size: 22rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 6rpx 20rpx; border-radius: 20rpx; font-weight: bold;">{{item.autoApproved ? '自动通过' : '已通过'}}</view>
          <view wx:elif="{{item.status === 'rejected'}}" style="font-size: 22rpx; color: var(--rose-600); background: var(--rose-50); padding: 6rpx 20rpx; border-radius: 20rpx; font-weight: bold;">已拒绝</view>
        </view>
      </view>
      <view style="font-size: 24rpx; color: #94a3b8; margin-bottom: 24rpx;">申请时间：{{item.displayTime}}</view>

      <!-- 待审核时显示操作按钮 -->
      <view wx:if="{{item.status === 'pending'}}" style="display: flex; gap: 20rpx;">
        <button bindtap="approve" data-id="{{item._id}}" data-name="{{item.name}}" style="flex: 1; background: var(--emerald-600); color: #fff; font-size: 28rpx; font-weight: bold; border-radius: 12rpx; padding: 20rpx 0; margin: 0; border: none;">
          通过
        </button>
        <button bindtap="reject" data-id="{{item._id}}" data-name="{{item.name}}" style="flex: 1; background: #f1f5f9; color: #64748b; font-size: 28rpx; font-weight: bold; border-radius: 12rpx; padding: 20rpx 0; margin: 0; border: none;">
          拒绝
        </button>
      </view>
    </view>
  </block>
</view>
