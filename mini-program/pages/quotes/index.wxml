<view class="page-container">
  <!-- 顶部标题与新建按钮 -->
  <view class="page-header">
    <view class="header-titles">
      <text class="page-title">报价管理</text>
      <text class="page-subtitle">支持引用材料库或灵活手写</text>
    </view>
    <view class="btn-create-icon hover-scale" bindtap="createQuote">
      <text class="plus-icon">+</text>
      新建
    </view>
  </view>

  <!-- 搜索与状态切换 -->
  <view class="search-filter-section">
    <scroll-view class="status-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="status-tabs">
        <view class="status-tab {{activeStatus === '全部' ? 'active' : ''}}" bindtap="switchStatus" data-status="全部">全部</view>
        <view class="status-tab {{activeStatus === '初步' ? 'active' : ''}}" bindtap="switchStatus" data-status="初步">初步</view>
        <view class="status-tab {{activeStatus === '待确认' ? 'active' : ''}}" bindtap="switchStatus" data-status="待确认">待确认</view>
        <view class="status-tab {{activeStatus === '已确认' ? 'active' : ''}}" bindtap="switchStatus" data-status="已确认">已确认</view>
        <view class="status-tab {{activeStatus === '已作废' ? 'active' : ''}}" bindtap="switchStatus" data-status="已作废">已作废</view>
      </view>
    </scroll-view>
    <view class="search-box">
      <view class="icon-search"></view>
      <input type="text" placeholder="搜索客户 / 手机号..." value="{{searchQuery}}" bindinput="onSearch" class="search-input"/>
    </view>
  </view>

  <!-- 报价列表 -->
  <scroll-view scroll-y class="list-container">
    <block wx:if="{{filteredQuotes.length > 0}}">
      <view class="quote-card" wx:for="{{filteredQuotes}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="card-header">
          <view class="customer-info">
            <customer-info 
              name="{{item.customer}}" 
              phone="{{item.phone}}" 
              customerNo="{{item.customerNo || item.leadId}}" 
            />
          </view>
          <view class="status-badge status-{{item.status === '初步' ? 'draft' : item.status === '待确认' ? 'wait' : item.status === '已确认' ? 'done' : 'cancel'}}">
            {{item.status || '初步'}}
          </view>
        </view>
        
        <view class="card-body">
          <view class="info-row" style="display: flex; justify-content: space-between;">
            <view style="display: flex; align-items: center; max-width: 65%;">
              <text class="info-icon">🏠</text>
              <text class="info-text truncate">{{item.address || '暂无地址'}}</text>
            </view>
            <view style="font-size: 22rpx; color: var(--rose-600); background: var(--rose-50); padding: 4rpx 16rpx; border-radius: 8rpx; font-weight: bold;">
              V{{item.version || 1}} 版
            </view>
          </view>
          <view class="info-row" style="display: flex; justify-content: space-between;">
            <view style="display: flex; align-items: center;">
              <text class="info-icon">👤</text>
              <text class="info-text">最后修改：{{item.modifier || item.sales || '未知'}}</text>
            </view>
            <view style="font-size: 22rpx; color: #94a3b8;">
              {{item._updatedAtFormatted || '最近'}}
            </view>
          </view>
        </view>

        <view class="card-footer">
          <view class="price-box">
            <text class="price-label">总价</text>
            <text class="price-val text-gray">¥{{item.total || 0}}</text>
          </view>
          <view class="price-box">
            <text class="price-label">最终成交价</text>
            <text class="price-val text-primary font-bold">¥{{item.final || 0}}</text>
          </view>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon-box">📄</view>
      <text class="empty-text">暂无相关报价单</text>
    </view>
  </scroll-view>

  <!-- 新建报价单：选择客户弹窗 -->
  <view class="modal-mask" wx:if="{{showCreateModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 40rpx;">
    <view class="modal-content" style="background: #fff; width: 100%; height: 70vh; border-radius: 24rpx; display: flex; flex-direction: column; overflow: hidden; position: relative;">
      
      <view style="padding: 30rpx 40rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
        <view style="font-size: 32rpx; font-weight: bold; color: #1e293b;">选择客户</view>
        <view bindtap="closeCreateModal" style="font-size: 40rpx; color: #94a3b8; padding: 10rpx;">×</view>
      </view>
      
      <view style="padding: 20rpx 40rpx;">
        <input placeholder="搜索客户姓名或手机号..." value="{{searchLeadQuery}}" bindinput="onLeadSearch" style="width: 100%; height: 72rpx; background: #f8fafc; border-radius: 36rpx; padding: 0 30rpx; font-size: 28rpx; box-sizing: border-box;" />
      </view>

      <scroll-view scroll-y style="flex: 1; padding: 0 40rpx;">
        <block wx:if="{{leadsList.length > 0}}">
          <view wx:for="{{leadsList}}" wx:key="_id" bindtap="selectLead" data-id="{{item._id}}" style="padding: 30rpx 0; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
            <view>
              <view style="margin-bottom: 12rpx;">
                <customer-info 
                  name="{{item.name}}" 
                  phone="{{item.phone}}" 
                  customerNo="{{item.customerNo || item._id}}" 
                />
              </view>
              <view style="font-size: 24rpx; color: #64748b;">{{item.address || '无地址'}}</view>
            </view>
            <view style="font-size: 24rpx; color: #fff; background: var(--emerald-600); padding: 8rpx 20rpx; border-radius: 30rpx;">选择</view>
          </view>
        </block>
        <view wx:else style="padding: 100rpx 0; text-align: center; color: #94a3b8; font-size: 28rpx;">
          没有找到匹配的客户线索
        </view>
      </scroll-view>
    </view>
  </view>
</view>
