<view class="page-container">

  <!-- 头部 -->
  <view class="header-section">
    <view class="header-left">
      <view class="title">组织架构</view>
      <view class="subtitle">{{isAdmin ? '管理员工账号与权限' : '查看公司成员与联系方式'}}</view>
    </view>
    <view class="btn-add hover-scale" bindtap="showAddModal" wx:if="{{isAdmin}}">
      <text>+</text> 添加
    </view>
  </view>

  <!-- 管理员视图：搜索+筛选+完整列表 -->
  <block wx:if="{{isAdmin}}">
    <view class="filter-section">
      <view class="tabs">
        <view
          class="tab {{activeTab === item.key ? 'active' : ''}}"
          wx:for="{{tabs}}"
          wx:key="key"
          bindtap="switchTab"
          data-tab="{{item.key}}"
        >
          {{item.name}}
        </view>
      </view>
      <view class="search-wrap">
        <icon type="search" size="16" color="#b5a49a" />
        <input placeholder="搜索员工姓名/账号/手机号..." placeholder-class="ph" bindinput="onSearch" />
      </view>
    </view>

    <scroll-view scroll-y class="list-scroll">
      <view class="employee-card hover-scale" wx:for="{{filteredEmployees}}" wx:key="_id" bindtap="showActionSheet" data-employee="{{item}}">
        <view class="card-left">
          <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" class="avatar avatar-img" mode="aspectFill" />
          <view wx:else class="avatar {{item.role}}">{{item.name[0]}}</view>
          <view class="info">
            <view class="name-row" style="display: flex; align-items: center; gap: 12rpx; flex-wrap: wrap;">
              <text class="name" style="font-size: 32rpx; font-weight: bold; color: var(--primary-900);">{{item.name}}</text>
              <text class="tag-me" wx:if="{{item._id === currentUserId}}" style="font-size: 20rpx; background: var(--amber-50); color: var(--amber-600); padding: 4rpx 10rpx; border-radius: 6rpx; font-weight: bold; height: 36rpx; line-height: 28rpx; box-sizing: border-box; display: inline-flex; align-items: center;">我</text>
              <view class="role-badge role-{{item.role}}" style="padding: 0 12rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: bold; height: 36rpx; display: inline-flex; align-items: center; box-sizing: border-box;">
                {{item.role === 'admin' ? '管理员' : item.role === 'designer' ? '设计师' : item.role === 'sales' ? '销售' : item.role === 'manager' ? '项目经理' : item.role === 'finance' ? '财务' : '员工'}}
              </view>
              <view class="status-badge {{item.status === 'active' ? 'active' : 'inactive'}}" style="padding: 0 12rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: bold; height: 36rpx; display: inline-flex; align-items: center; box-sizing: border-box;">
                {{item.status === 'active' ? '在职' : '离职'}}
              </view>
              <view wx:if="{{item.joinDays}}" style="display: inline-flex; align-items: center; justify-content: center; height: 36rpx; padding: 0 12rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: bold; color: var(--rose-600); background: var(--rose-50); border: 1rpx solid #ffe4e6; white-space: nowrap; box-sizing: border-box;">第 {{item.joinDays}} 天</view>
            </view>
            <view class="meta-row" style="display: flex; align-items: center; flex-wrap: wrap; margin-top: 8rpx;">
              <text class="meta-item">{{item.phone}}</text>
              <text class="divider">|</text>
              <text class="meta-item">入职: {{item.joinDate}}</text>
            </view>
          </view>
        </view>
        <view class="card-right">
          <view class="icon-more"></view>
        </view>
      </view>
      <view class="empty-state" wx:if="{{filteredEmployees.length === 0}}">
        <text>暂无相关人员</text>
      </view>
      <view class="bottom-padding"></view>
    </scroll-view>
  </block>

  <!-- 非管理员视图：部门分组卡片 -->
  <block wx:else>
    <scroll-view scroll-y class="list-scroll">
      <view wx:for="{{deptGroups}}" wx:key="label" class="dept-group">
        <view class="dept-header">
          <text class="dept-label">{{item.label}}</text>
          <text class="dept-count">{{item.members.length}} 人</text>
        </view>
        <view class="dept-members">
          <view class="member-card" wx:for="{{item.members}}" wx:for-item="emp" wx:key="_id">
            <image wx:if="{{emp.avatarUrl}}" src="{{emp.avatarUrl}}" class="member-avatar member-avatar-img" mode="aspectFill" />
            <view wx:else class="member-avatar avatar-{{emp.role}}">{{emp.name[0]}}</view>
            <view class="member-info">
              <view class="member-name-row">
                <text class="member-name">{{emp.name}}</text>
                <text class="tag-me" wx:if="{{emp.isMe}}">我</text>
              </view>
              <view style="display: flex; gap: 16rpx; align-items: center;">
                <text class="member-phone">{{emp.phone || '暂无电话'}}</text>
                <text wx:if="{{emp.joinDays}}" style="font-size: 22rpx; color: var(--rose-600); background: var(--rose-50); padding: 2rpx 12rpx; border-radius: 8rpx; border: 1rpx solid #ffe4e6;">入职 {{emp.joinDays}} 天</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="empty-state" wx:if="{{deptGroups.length === 0}}">
        <text>暂无成员信息</text>
      </view>
      <view class="bottom-padding"></view>
    </scroll-view>
  </block>

  <!-- 员工编辑弹窗 (仅管理员) -->
  <view class="modal-mask" wx:if="{{showModal}}" bindtap="closeModal"></view>
  <view class="modal-content" wx:if="{{showModal}}">
    <view class="modal-header">
      <text>{{modalType === 'add' ? '添加员工' : '编辑员工'}}</text>
      <view class="btn-close" bindtap="closeModal">取消</view>
    </view>
    <scroll-view scroll-y class="modal-scroll">
      <view class="modal-body">
        <view class="form-group">
          <text class="label">姓名</text>
          <input class="input" placeholder="请输入姓名" value="{{formData.name}}" bindinput="onInput" data-field="name" />
        </view>
        <view class="form-group">
          <text class="label">手机号</text>
          <input class="input" type="number" placeholder="请输入11位手机号" value="{{formData.phone}}" bindinput="onInput" data-field="phone" />
        </view>
        <view class="form-group">
          <text class="label">登录账号</text>
          <input class="input" type="text" placeholder="请输入字母账号 (手机号或账号均可登录)" value="{{formData.account}}" bindinput="onInput" data-field="account" />
        </view>
        <view class="form-group">
          <text class="label">身份</text>
          <picker bindchange="onRoleChange" value="{{roleIndex}}" range="{{roleOptions}}" range-key="name">
            <view class="picker-view">
              <text>{{roleOptions[roleIndex].name || '请选择身份'}}</text>
              <view class="arrow-down"></view>
            </view>
          </picker>
        </view>
        <view class="form-group">
          <text class="label">入职时间</text>
          <picker mode="date" value="{{formData.joinDate}}" bindchange="onJoinDateChange">
            <view class="picker-view">
              <text>{{formData.joinDate || '请选择入职时间'}}</text>
              <view class="arrow-down"></view>
            </view>
          </picker>
        </view>
        <view style="font-size: 24rpx; color: var(--rose-600); margin-bottom: 30rpx; text-align: center;">注：新员工默认登录密码为 888888</view>
        <view class="btn-save hover-scale" bindtap="saveEmployee">保 存</view>
      </view>
    </scroll-view>
  </view>
</view>