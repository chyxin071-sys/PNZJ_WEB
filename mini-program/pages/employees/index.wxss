page { background: #f5f4f2; }
.page-container { display: flex; flex-direction: column; height: 100vh; }

/* 头部 */
.header-section { padding: 40rpx 40rpx 20rpx; display: flex; justify-content: space-between; align-items: flex-end; flex-shrink: 0; }
.title { font-size: 44rpx; font-weight: 800; color: var(--primary-900); }
.subtitle { font-size: 26rpx; color: var(--primary-600); margin-top: 8rpx; }

.btn-add { background: var(--primary-900); color: #fff; padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 500; display: flex; align-items: center; gap: 8rpx; }

/* 筛选与搜索 */
.filter-section { padding: 0 40rpx 32rpx; flex-shrink: 0; display: flex; flex-direction: column; gap: 24rpx; }
.tabs { display: flex; gap: 16rpx; overflow-x: auto; white-space: nowrap; }
.tab { padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: 500; color: var(--primary-600); background: #fff; border: 1rpx solid transparent; transition: all 0.2s; }
.tab.active { background: var(--primary-900); color: #fff; box-shadow: 0 4rpx 12rpx rgba(74, 64, 58, 0.2); }

.search-wrap { background: #fff; border-radius: 20rpx; display: flex; align-items: center; padding: 0 24rpx; height: 80rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); flex: 1; }
.search-wrap icon { margin-right: 16rpx; }
.search-wrap input { flex: 1; font-size: 28rpx; color: var(--primary-900); }
.ph { color: var(--primary-400); }

/* 列表区 */
.list-scroll { flex: 1; overflow-y: hidden; }
.employee-card { margin: 0 40rpx 24rpx; background: #fff; border-radius: 24rpx; padding: 32rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: 0 4rpx 16rpx rgba(74, 64, 58, 0.04); }

.card-left { display: flex; align-items: center; gap: 24rpx; flex: 1; }
.avatar { width: 88rpx; height: 88rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; font-weight: bold; flex-shrink: 0; }
/* 头像颜色映射 */
.avatar.admin { background: #faf5ff; color: #7e22ce; border: 2rpx solid #f3e8ff; }
.avatar.sales { background: #eff6ff; color: #1d4ed8; border: 2rpx solid #dbeafe; }
.avatar.designer { background: #ecfdf5; color: #047857; border: 2rpx solid #d1fae5; }
.avatar.manager { background: #fffbeb; color: #b45309; border: 2rpx solid #fef3c7; }

.info { flex: 1; display: flex; flex-direction: column; gap: 12rpx; }
.name-row { display: flex; align-items: center; gap: 16rpx; }
.name { font-size: 32rpx; font-weight: bold; color: var(--primary-900); }

.role-badge { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: bold; }
.role-admin { background: #faf5ff; color: #7e22ce; }
.role-sales { background: #eff6ff; color: #1d4ed8; }
.role-designer { background: #ecfdf5; color: #047857; }
.role-manager { background: #fffbeb; color: #b45309; }

.status-badge { padding: 4rpx 12rpx; border-radius: 8rpx; font-size: 20rpx; font-weight: bold; border: 1rpx solid transparent; }
.status-badge.active { background: #ecfdf5; color: #059669; border-color: #a7f3d0; }
.status-badge.inactive { background: #f1f5f9; color: #64748b; border-color: #cbd5e1; }

.meta-row { display: flex; align-items: center; font-size: 24rpx; color: var(--primary-600); font-family: monospace; }
.divider { margin: 0 12rpx; color: var(--primary-200); }

.empty-state { padding: 80rpx 0; text-align: center; color: var(--primary-400); font-size: 28rpx; }
.bottom-padding { height: 60rpx; }

/* 交互反馈 */
.hover-scale { transition: transform 0.1s ease; }
.hover-scale:active { transform: scale(0.98); }