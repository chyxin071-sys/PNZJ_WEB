<view class="page-container">
  
  <!-- 头部用户信息卡片 -->
  <view class="profile-header">
    <view class="user-card">
      <view class="avatar-wrap avatar-bg-{{userInfo.role || 'default'}}">
        <text class="avatar-text">{{userInfo.name ? userInfo.name[0] : '用'}}</text>
      </view>
      <view class="user-info">
        <view class="name-row">
          <view class="name">{{userInfo.name || '未登录'}}</view>
          <view class="icon-edit" bindtap="openEditName"></view>
        </view>
        <view class="role-badge">{{userInfo.role === 'admin' ? '管理员' : userInfo.role === 'designer' ? '设计师' : userInfo.role === 'sales' ? '销售' : userInfo.role === 'manager' ? '项目经理' : userInfo.role === 'finance' ? '财务' : '员工'}}</view>
      </view>
    </view>
  </view>

  <!-- 修改姓名弹窗 -->
  <view class="modal-mask" wx:if="{{showEditModal}}" bindtap="closeEditName"></view>
  <view class="modal-content" wx:if="{{showEditModal}}">
    <view class="modal-header">
      <text>修改姓名</text>
      <view class="btn-close" bindtap="closeEditName">取消</view>
    </view>
    <view class="modal-body">
      <view class="input-wrap">
        <input class="input" placeholder="请输入新姓名" value="{{editName}}" bindinput="onNameInput" />
      </view>
      <view class="btn-save hover-scale" bindtap="saveName">保 存</view>
    </view>
  </view>

  <!-- 修改密码弹窗 -->
  <view class="modal-mask" wx:if="{{showPasswordModal}}" bindtap="closePasswordModal"></view>
  <view class="modal-content" wx:if="{{showPasswordModal}}">
    <view class="modal-header">
      <text>修改密码</text>
      <view class="btn-close" bindtap="closePasswordModal">取消</view>
    </view>
    <view class="modal-body">
      <view class="input-wrap" style="margin-bottom: 24rpx; position: relative;">
        <input class="input" type="{{showOldPwd ? 'text' : 'password'}}" placeholder="请输入原密码" value="{{oldPassword}}" bindinput="onPasswordInput" data-field="oldPassword" style="padding-right: 60rpx;" />
        <view class="icon-eye {{showOldPwd ? 'open' : 'closed'}}" bindtap="togglePwdVisibility" data-field="showOldPwd"></view>
      </view>
      <view class="input-wrap" style="margin-bottom: 24rpx; position: relative;">
        <input class="input" type="{{showNewPwd ? 'text' : 'password'}}" placeholder="请输入新密码" value="{{newPassword}}" bindinput="onPasswordInput" data-field="newPassword" style="padding-right: 60rpx;" />
        <view class="icon-eye {{showNewPwd ? 'open' : 'closed'}}" bindtap="togglePwdVisibility" data-field="showNewPwd"></view>
      </view>
      <view class="btn-save hover-scale" bindtap="savePassword" style="margin-top: 10rpx;">确认修改</view>
    </view>
  </view>

  <!-- 数据概览模块 -->
  <view class="stats-section">
    <view class="stat-item">
      <view class="stat-val">{{myTodosCount || 0}}</view>
      <view class="stat-label">我的待办</view>
    </view>
    <view class="stat-item">
      <view class="stat-val">{{myLeadsCount || 0}}</view>
      <view class="stat-label">跟进客户</view>
    </view>
    <view class="stat-item">
      <view class="stat-val">{{myProjectsCount || 0}}</view>
      <view class="stat-label">负责工地</view>
    </view>
  </view>

  <!-- 功能菜单列表 -->
  <view class="menu-list">
    <view class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="icon-menu icon-phone"></view>
        <text>手机号</text>
      </view>
      <view class="menu-right">
        <text class="menu-val">{{userInfo.phone || '未绑定'}}</text>
      </view>
    </view>
    
    <view class="menu-item" hover-class="menu-hover">
      <view class="menu-left">
        <view class="icon-menu icon-account"></view>
        <text>登录账号</text>
      </view>
      <view class="menu-right">
        <text class="menu-val">{{userInfo.account || '未设置'}}</text>
      </view>
    </view>

    <view class="menu-item" hover-class="menu-hover" bindtap="openEditPassword">
      <view class="menu-left">
        <view class="icon-menu icon-lock"></view>
        <text>修改密码</text>
      </view>
      <view class="menu-right">
        <view class="arrow-right"></view>
      </view>
    </view>

    <view class="menu-item" hover-class="menu-hover" bindtap="goToMaterials" wx:if="{{userInfo.role === 'admin'}}">
      <view class="menu-left">
        <view class="icon-menu icon-material"></view>
        <text>材料大厅管理</text>
      </view>
      <view class="menu-right">
        <view class="arrow-right"></view>
      </view>
    </view>

    <view class="menu-item" hover-class="menu-hover" bindtap="goToTeam">
      <view class="menu-left">
        <view class="icon-menu icon-team"></view>
        <text>组织架构</text>
      </view>
      <view class="menu-right">
        <view class="arrow-right"></view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-btn hover-scale" bindtap="handleLogout">
    <text>退出登录</text>
  </view>

  <!-- 底部品牌信息 -->
  <view class="brand-info">
    <view class="brand-name">品诺筑家</view>
    <view class="brand-slogan">品诺有心，筑家有道。</view>
  </view>
</view>