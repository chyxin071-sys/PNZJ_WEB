.page-container {
  background: #faf9f8;
  min-height: 100vh;
  padding-bottom: 60rpx;
}

/* 头部卡片 */
.profile-header {
  background: #fff;
  padding: 40rpx 40rpx 80rpx;
  border-bottom-left-radius: 40rpx;
  border-bottom-right-radius: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(74, 64, 58, 0.02);
}
.user-card {
  display: flex;
  align-items: center;
  gap: 32rpx;
}
.avatar-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  border: 6rpx solid #f1f5f9;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}
.avatar-text {
  font-size: 56rpx;
  font-weight: 800;
}
.avatar-bg-admin { background: #faf5ff; color: #7e22ce; border-color: #f3e8ff; }
.avatar-bg-sales { background: #eff6ff; color: #1d4ed8; border-color: #dbeafe; }
.avatar-bg-designer { background: var(--emerald-50); color: var(--emerald-600); border-color: var(--emerald-100); }
.avatar-bg-manager { background: #fffbeb; color: var(--amber-600); border-color: var(--amber-50); }
.avatar-bg-default { background: #f8fafc; color: #64748b; border-color: #e2e8f0; }
.user-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.name-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.name {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--primary-900);
  letter-spacing: 2rpx;
}
.icon-edit {
  width: 36rpx;
  height: 36rpx;
  background: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="%2394a3b8" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>')
    no-repeat center/contain;
}
.role-badge {
  display: inline-flex;
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
  background: var(--primary-50);
  color: var(--primary-600);
  border: 1rpx solid #e2e8f0;
  max-width: fit-content;
}

/* 修改姓名弹窗 */
.modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 100; }
.modal-content { position: fixed; left: 0; right: 0; bottom: 0; background: #fff; border-radius: 40rpx 40rpx 0 0; z-index: 101; padding-bottom: env(safe-area-inset-bottom); display: flex; flex-direction: column; }
.modal-header { display: flex; justify-content: space-between; align-items: center; padding: 40rpx; font-size: 34rpx; font-weight: bold; border-bottom: 1rpx solid #f1f5f9; }
.btn-close {
  font-size: 28rpx;
  color: #94a3b8;
  font-weight: normal;
}
.modal-body {
  padding: 40rpx;
}
.input-wrap {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  border: 2rpx solid #e2e8f0;
  margin-bottom: 32rpx;
}
.input {
  font-size: 30rpx;
  color: var(--primary-900);
}
.btn-save {
  background: var(--primary-900);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 48rpx;
}

/* 数据概览 */
.stats-section {
  background: #fff;
  margin: -40rpx 40rpx 40rpx;
  padding: 32rpx 0;
  border-radius: 24rpx;
  display: flex;
  justify-content: space-around;
  box-shadow: 0 10rpx 30rpx rgba(74, 64, 58, 0.04);
  position: relative;
  z-index: 10;
  border: 2rpx solid #f8fafc;
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-val {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-900);
}
.stat-label {
  font-size: 26rpx;
  color: var(--primary-600);
}

/* 菜单列表 */
.menu-list {
  background: #fff;
  margin: 0 40rpx 40rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
}
.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f1f5f9;
  background: #fff;
  transition: background 0.2s;
}
.menu-item:last-child {
  border-bottom: none;
}
.menu-hover {
  background: #f8fafc;
}
.menu-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  font-size: 30rpx;
  color: var(--primary-900);
  font-weight: 500;
}
.menu-right {
  display: flex;
  align-items: center;
}
.menu-val {
  font-size: 28rpx;
  color: var(--primary-400);
}
.arrow-right {
  width: 14rpx;
  height: 14rpx;
  border-top: 4rpx solid #cbd5e1;
  border-right: 4rpx solid #cbd5e1;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* 图标样式 */
.icon-menu {
  width: 40rpx;
  height: 40rpx;
  border-radius: 8rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}
.icon-account {
  background: #f3e8ff;
}
.icon-account::before {
  content: "";
  width: 14rpx;
  height: 20rpx;
  border: 4rpx solid #9333ea;
  border-radius: 4rpx;
}
.icon-phone::before {
  content: "";
  width: 14rpx;
  height: 22rpx;
  border: 4rpx solid #3b82f6;
  border-radius: 4rpx;
}
.icon-quote {
  background: #fff7ed;
}
.icon-quote::before {
  content: "";
  width: 16rpx;
  height: 20rpx;
  border: 4rpx solid #f97316;
  border-radius: 4rpx;
}
.icon-material {
  background: var(--emerald-50);
}
.icon-material::before {
  content: "";
  width: 16rpx;
  height: 16rpx;
  border: 4rpx solid var(--emerald-600);
  transform: rotate(45deg);
}

.icon-lock {
  background: var(--amber-50);
}
.icon-lock::before {
  content: "";
  width: 14rpx;
  height: 10rpx;
  border: 4rpx solid var(--amber-600);
  border-radius: 4rpx;
  position: relative;
  margin-top: 6rpx;
}
.icon-lock::after {
  content: "";
  position: absolute;
  top: 8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border: 4rpx solid var(--amber-600);
  border-bottom: none;
  border-radius: 6rpx 6rpx 0 0;
}

.icon-team {
  background: var(--rose-50);
}
.icon-team::before {
  content: "";
  width: 12rpx;
  height: 12rpx;
  border: 4rpx solid var(--rose-600);
  border-radius: 50%;
  box-shadow:
    -10rpx 10rpx 0 var(--rose-600),
    10rpx 10rpx 0 var(--rose-600);
  margin-bottom: 8rpx;
}

.icon-bell {
  background: var(--rose-50);
}
.icon-bell::before {
  content: "";
  width: 14rpx;
  height: 16rpx;
  border: 4rpx solid var(--rose-600);
  border-radius: 8rpx 8rpx 0 0;
  border-bottom: none;
}
.icon-bell::after {
  content: "";
  position: absolute;
  bottom: 8rpx;
  width: 22rpx;
  height: 4rpx;
  background: var(--rose-600);
  border-radius: 4rpx;
}
.badge-dot {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  width: 16rpx;
  height: 16rpx;
  background: var(--rose-600);
  border-radius: 50%;
  border: 2rpx solid #fff;
}

/* 退出登�?*/
.logout-btn {
  background: #fff;
  margin: 0 40rpx;
  padding: 32rpx;
  border-radius: 24rpx;
  text-align: center;
  color: #1e293b; /* 修改为深灰色/黑色 */
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.02);
  transition: transform 0.2s;
}
.hover-scale:active {
  transform: scale(0.96);
}

/* 品牌信息 */
.brand-info {
  margin-top: 60rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}
.brand-name {
  font-size: 32rpx;
  font-weight: 800;
  color: #d6d3d1;
  letter-spacing: 2rpx;
}
.brand-slogan {
  font-size: 24rpx;
  color: #cbd5e1;
  letter-spacing: 4rpx;
}

