<view class="page-container">
  <!-- 顶部标题与新建按钮 -->
  <view class="page-header" wx:if="{{!selectMode}}">
    <view class="header-titles">
      <text class="page-title">材料库</text>
      <text class="page-subtitle">公司标准化物料与套餐库</text>
    </view>
    <view class="btn-create-icon hover-scale" bindtap="createMaterial" style="display: flex; align-items: center; justify-content: center; gap: 4rpx;">
      <text class="plus-icon">+</text>
      新建
    </view>
  </view>

  <!-- 搜索与分类切换 -->
  <view class="search-filter-section">
    <scroll-view class="status-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="status-tabs">
        <view class="status-tab {{activeCategory === '全部' ? 'active' : ''}}" bindtap="switchCategory" data-category="全部">全部</view>
        <view class="status-tab {{activeCategory === '主材' ? 'active' : ''}}" bindtap="switchCategory" data-category="主材">主材</view>
        <view class="status-tab {{activeCategory === '辅材' ? 'active' : ''}}" bindtap="switchCategory" data-category="辅材">辅材</view>
        <view class="status-tab {{activeCategory === '软装' ? 'active' : ''}}" bindtap="switchCategory" data-category="软装">软装</view>
        <view class="status-tab {{activeCategory === '家电' ? 'active' : ''}}" bindtap="switchCategory" data-category="家电">家电</view>
        <view class="status-tab {{activeCategory === '人工' ? 'active' : ''}}" bindtap="switchCategory" data-category="人工">人工</view>
        <view class="status-tab {{activeCategory === '定制' ? 'active' : ''}}" bindtap="switchCategory" data-category="定制">定制</view>
        <view class="status-tab {{activeCategory === '套餐' ? 'active' : ''}}" bindtap="switchCategory" data-category="套餐">套餐</view>
      </view>
    </scroll-view>
    <view class="search-box">
      <view class="icon-search"></view>
      <input type="text" placeholder="搜索名称 / 品牌 / 型号..." value="{{searchQuery}}" bindinput="onSearch" class="search-input"/>
    </view>
  </view>

  <!-- 材料列表 -->
  <scroll-view scroll-y class="list-container" style="{{selectMode ? 'padding-bottom: 180rpx;' : ''}}">
    <block wx:if="{{filteredMaterials.length > 0}}">
      <view class="material-card" wx:for="{{filteredMaterials}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
        <view class="card-header">
          <view class="material-info">
            <view class="material-title-box">
              <text class="material-name">{{item.name}}</text>
              <text class="category-badge">{{item.category || '未分类'}}</text>
            </view>
            <text class="material-brand">品牌: {{item.brand || '暂无'}} | 型号: {{item.sku || '暂无'}}</text>
          </view>
          <view class="status-badge {{item.status === 'active' ? 'status-active' : 'status-inactive'}}">
            {{item.status === 'active' ? '已上架' : '已下架'}}
          </view>
        </view>
        
        <view class="card-body">
          <view class="info-row">
            <text class="info-icon">📦</text>
            <text class="info-text">当前库存：<text class="font-mono font-bold {{item.stock < 20 ? 'text-danger' : 'text-primary-900'}}">{{item.stock || 0}}</text> {{item.unit}}</text>
          </view>
        </view>

        <view class="card-footer" style="display: flex; justify-content: space-between; align-items: center;">
          <view class="price-box">
            <text class="price-label">标准单价</text>
            <text class="price-val text-primary font-bold">¥{{item.price || 0}} <text style="font-size:24rpx;color:#94a3b8;">/ {{item.unit}}</text></text>
          </view>
          <view wx:if="{{selectMode}}" class="action-box">
            <view class="btn-add-cart {{item.added ? 'added' : ''}}" catchtap="toggleItem" data-id="{{item._id}}" style="padding: 8rpx 24rpx; border-radius: 8rpx; font-size: 24rpx; font-weight: bold; transition: all 0.2s; {{item.added ? 'background: #f1f5f9; color: #94a3b8; border: 1rpx solid #e2e8f0;' : 'background: #4a403a; color: #fff; border: 1rpx solid #4a403a;'}}">
              {{item.added ? '已添加' : '添加'}}
            </view>
          </view>
        </view>
      </view>
    </block>
    <view class="empty-state" wx:else>
      <view class="empty-icon-box">📦</view>
      <text class="empty-text">暂无相关材料数据</text>
    </view>
  </scroll-view>

  <!-- 底部购物车栏 (仅在选择模式下显示) -->
  <view wx:if="{{selectMode}}" class="cart-bar" style="position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-top: 1rpx solid #e2e8f0; padding: 20rpx 30rpx; display: flex; justify-content: space-between; align-items: center; z-index: 100; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05); padding-bottom: calc(20rpx + env(safe-area-inset-bottom));">
    <view class="cart-info" style="display: flex; flex-direction: column;">
      <text style="font-size: 24rpx; color: #64748b; margin-bottom: 4rpx;">已选: <text style="color: #ef4444; font-weight: bold;">{{quote.items.length || 0}}</text> 项材料</text>
      <text style="font-size: 32rpx; font-weight: bold; color: #1e293b;">预估总额: <text style="color: #ef4444;">¥{{quote.total || 0}}</text></text>
    </view>
    <view class="btn-done" bindtap="goBack" style="background: #4a403a; color: #fff; padding: 16rpx 40rpx; border-radius: 40rpx; font-size: 28rpx; font-weight: bold; box-shadow: 0 4rpx 12rpx rgba(74, 64, 58, 0.2);">
      返回编辑
    </view>
  </view>
</view>