
<view class="page-container {{mode === 'view' ? 'view-mode' : ''}}">
  <scroll-view scroll-y class="form-scroll">
    <!-- 标题 -->
    <view class="form-group">
      <view class="label">任务标题 <text class="required" wx:if="{{mode !== 'view'}}">*</text></view>
      <input class="input-box" placeholder="输入待办任务标题..." placeholder-class="ph" value="{{formData.title}}" bindinput="onInput" data-field="title" disabled="{{mode === 'view'}}" />
    </view>

    <!-- 优先级 -->
    <view class="form-group">
      <view class="label">优先级 <text class="required" wx:if="{{mode !== 'view'}}">*</text></view>
      <view class="priority-selector {{mode === 'view' ? 'disabled' : ''}}">
        <view class="p-btn {{formData.priority === 'low' ? 'p-active-low' : ''}}" bindtap="{{mode === 'view' ? '' : 'setPriority'}}" data-value="low">
          <view class="p-dot bg-emerald-500"></view>普通
        </view>
        <view class="p-btn {{formData.priority === 'medium' ? 'p-active-medium' : ''}}" bindtap="{{mode === 'view' ? '' : 'setPriority'}}" data-value="medium">
          <view class="p-dot bg-amber-500"></view>重要
        </view>
        <view class="p-btn {{formData.priority === 'high' ? 'p-active-high' : ''}}" bindtap="{{mode === 'view' ? '' : 'setPriority'}}" data-value="high">
          <view class="p-dot bg-rose-500"></view>紧急
        </view>
      </view>
    </view>

    <!-- 关联类型与对象 -->
    <view class="form-row-group">
      <view class="form-group half">
        <view class="label">关联类型</view>
        <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{typeOptions}}" disabled="{{mode === 'view'}}">
          <view class="picker-box">
            <text class="{{!formData.relatedType ? 'ph' : ''}}">{{typeOptions[typeIndex] || '请选择'}}</text>
            <view class="arrow-down" wx:if="{{mode !== 'view'}}"></view>
          </view>
        </picker>
      </view>

      <view class="form-group half" wx:if="{{formData.relatedType !== 'none'}}">
        <view class="label" style="display:flex; justify-content:space-between; align-items:center;">
          <text>关联{{formData.relatedType === 'lead' ? '客户' : '工地'}}</text>
        </view>
        <picker bindchange="onRelatedChange" value="{{relatedIndex}}" range="{{relatedOptions}}" range-key="name" disabled="{{mode === 'view'}}">
          <view class="picker-box" style="{{mode === 'view' && formData.relatedId ? 'background: #f5f0eb; border: 1rpx solid #d4c4b8; border-radius: 8rpx; display: flex; justify-content: space-between; align-items: center; padding: 16rpx 24rpx;' : ''}}" bindtap="{{mode === 'view' && formData.relatedId ? 'goToRelated' : ''}}">
            <text class="{{!formData.relatedId ? 'ph' : ''}}" style="{{mode === 'view' && formData.relatedId ? 'color: var(--primary-700); font-weight: bold;' : ''}}">{{relatedIndex !== -1 ? relatedOptions[relatedIndex].name : (formData._displayRelatedName || '请选择')}}</text>
            <view class="arrow-down" wx:if="{{mode !== 'view'}}"></view>
          </view>
        </picker>
      </view>
    </view>

    <!-- 截止日期 -->
    <view class="form-group">
      <view class="label">截止日期 <text class="required" wx:if="{{mode !== 'view'}}">*</text></view>
      <picker mode="date" value="{{formData.dueDate}}" bindchange="onDateChange" disabled="{{mode === 'view'}}">
        <view class="picker-box">
          <text class="{{!formData.dueDate ? 'ph' : ''}}">{{formData.dueDate || '选择截止日期'}}</text>
          <view class="icon-calendar" wx:if="{{mode !== 'view'}}"></view>
        </view>
      </picker>
    </view>

    <!-- 执行人 (多选) -->
    <view class="form-group">
      <view class="label">指派给谁 (执行人可多选) <text class="required" wx:if="{{mode !== 'view'}}">*</text></view>
      <view class="multi-select-box" bindtap="{{mode === 'view' ? '' : 'showAssigneeModal'}}">
        <text class="{{selectedEmployeeNames ? '' : 'ph'}}">{{selectedEmployeeNames || '请选择执行人'}}</text>
        <view class="arrow-down" wx:if="{{mode !== 'view'}}"></view>
      </view>
    </view>

    <!-- 详细描述 -->
    <view class="form-group" wx:if="{{mode !== 'view' || (mode === 'view' && formData.description)}}">
      <view class="label" style="{{mode === 'view' && !formData.description ? 'color: #94a3b8; font-weight: normal;' : ''}}">详细描述</view>
      <textarea class="textarea-box" placeholder="添加更详细的任务描述（选填）..." placeholder-class="ph" value="{{formData.description}}" bindinput="onInput" data-field="description" auto-height maxlength="500" disabled="{{mode === 'view'}}"></textarea>
    </view>

    <!-- 创建日期 (仅查看模式) -->
    <view class="form-group" wx:if="{{mode === 'view' && formData.createdAt}}">
      <view class="label">创建日期</view>
      <view class="view-text">
        <text>{{formData.createdAt}}</text>
      </view>
    </view>
    
    <view class="bottom-padding"></view>
  </scroll-view>

  <!-- 底部固定按钮区 -->
  <view class="bottom-bar" wx:if="{{mode === 'view' && (isAdmin || isRelated)}}">
    <view class="btn-delete hover-scale" bindtap="deleteTodo">删除</view>
    <view class="btn-save hover-scale" bindtap="enterEditMode">编辑</view>
  </view>
  <view class="bottom-bar" wx:elif="{{mode !== 'view'}}">
    <view class="btn-cancel hover-scale" bindtap="{{mode === 'edit' ? 'cancelEdit' : 'goBack'}}">取消</view>
    <view class="btn-save hover-scale" bindtap="saveTodo">保存</view>
  </view>

  <!-- 执行人多选弹窗 -->
  <view class="modal-mask" wx:if="{{showAssigneeModal}}" bindtap="hideAssigneeModal"></view>
  <view class="modal-content" wx:if="{{showAssigneeModal}}">
    <view class="modal-header">
      <text>选择执行人</text>
      <view class="btn-close" bindtap="hideAssigneeModal">完成</view>
    </view>
    <scroll-view scroll-y class="modal-list">
      <view class="employee-item" wx:for="{{employees}}" wx:key="id" bindtap="toggleAssignee" data-id="{{item.id}}">
        <view class="checkbox {{item.selected ? 'checked' : ''}}">
          <view wx:if="{{item.selected}}" class="checkmark"></view>
        </view>
        <text class="emp-name">{{item.displayName}}</text>
      </view>
    </scroll-view>
  </view>
</view>
