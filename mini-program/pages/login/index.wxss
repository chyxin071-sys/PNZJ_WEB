page {
  background-color: #ffffff;
  height: 100%;
}

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  height: 100vh;
  padding: 80rpx 40rpx 60rpx;
  box-sizing: border-box;
}

/* Header Section */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 100rpx;
}

.logo-placeholder {
  width: 160rpx;
  height: 160rpx;
  background: linear-gradient(135deg, #6b5c54 0%, #4a403a 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 80rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 30rpx rgba(74, 64, 58, 0.2);
  margin-bottom: 40rpx;
}

.brand-name {
  font-size: 48rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
}

.slogan {
  font-size: 28rpx;
  color: #999999;
  letter-spacing: 4rpx;
}

/* Main Section */
.main {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: -100rpx;
}

.btn-login-wechat {
  width: 100% !important;
  height: 100rpx;
  background-color: #07c160;
  color: #ffffff;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(7, 193, 96, 0.3);
  margin-bottom: 30rpx;
}

.btn-hover {
  background-color: #06ad56;
  transform: scale(0.98);
}

.wechat-icon {
  width: 44rpx;
  height: 44rpx;
  /* background-image removed for safe testing */
  background-color: transparent;
  margin-right: 16rpx;
}

.login-tip {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 60rpx;
}

.mock-login {
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  color: #4a403a;
  background-color: #f5f4f2;
  border-radius: 40rpx;
  border: 1px solid #e0dcd9;
  transition: all 0.2s;
}

.mock-hover {
  background-color: #e0dcd9;
}

/* Footer Section */
.footer {
  width: 100%;
  text-align: center;
}

.agreement {
  font-size: 22rpx;
  color: #999999;
  line-height: 1.5;
}

.link {
  color: #4a403a;
  font-weight: 500;
}