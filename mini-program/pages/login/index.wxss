page {
  background-color: #ffffff;
  height: 100%;
}

.login-container { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100vh; background: #faf9f8; padding: 0 60rpx; box-sizing: border-box; }

.brand { display: flex; flex-direction: column; align-items: center; margin-bottom: 100rpx; }
.logo-wrap { width: 180rpx; height: 180rpx; background: transparent; display: flex; align-items: center; justify-content: center; margin-bottom: 32rpx; overflow: hidden; border-radius: 40rpx; }
.logo-img { width: 100%; height: 100%; }
.logo-fallback { width: 100%; height: 100%; background: var(--primary-900); color: #fff; font-size: 80rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; }

.title { font-size: 48rpx; font-weight: 800; color: var(--primary-900); margin-bottom: 16rpx; letter-spacing: 4rpx; }
.slogan { font-size: 28rpx; color: var(--primary-400); letter-spacing: 2rpx; }

.form { width: 100%; display: flex; flex-direction: column; gap: 32rpx; }
.input-wrap { display: flex; align-items: center; background: #fff; height: 100rpx; border-radius: 24rpx; padding: 0 32rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.02); border: 2rpx solid transparent; transition: all 0.2s; }
.input-wrap:focus-within { border-color: var(--primary-900); }

.icon-user { width: 32rpx; height: 32rpx; border: 4rpx solid var(--primary-400); border-radius: 50%; position: relative; margin-right: 20rpx; flex-shrink: 0; }
.icon-user::after { content: ''; position: absolute; bottom: -16rpx; left: -8rpx; width: 40rpx; height: 16rpx; border: 4rpx solid var(--primary-400); border-bottom: none; border-radius: 20rpx 20rpx 0 0; }

.icon-lock { width: 28rpx; height: 24rpx; border: 4rpx solid var(--primary-400); border-radius: 4rpx; position: relative; margin-right: 20rpx; margin-top: 10rpx; flex-shrink: 0; }
.icon-lock::before { content: ''; position: absolute; top: -14rpx; left: 4rpx; width: 12rpx; height: 12rpx; border: 4rpx solid var(--primary-400); border-bottom: none; border-radius: 8rpx 8rpx 0 0; }

.input { flex: 1; height: 100%; font-size: 30rpx; color: var(--primary-900); }
.ph { color: #cbd5e1; }

.btn-login { width: 100%; height: 100rpx; background: var(--primary-900); color: #fff; border-radius: 50rpx; display: flex; align-items: center; justify-content: center; font-size: 34rpx; font-weight: bold; margin-top: 40rpx; box-shadow: 0 10rpx 24rpx rgba(74, 64, 58, 0.2); transition: all 0.2s; letter-spacing: 8rpx; text-indent: 8rpx; }
.hover-scale:active { transform: scale(0.96); }

.bottom-tips { position: absolute; bottom: 60rpx; font-size: 24rpx; color: var(--primary-400); }