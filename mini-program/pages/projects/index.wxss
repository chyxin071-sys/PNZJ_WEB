@import "../index/index.wxss";

/* 工地页专有样式补�?*/
.bg-blue-50 { background: #eff6ff; }
.bg-emerald-50 { background: var(--emerald-50); }
.bg-orange-50 { background: #fff7ed; }

/* 全部工地：房屋结�?*/
.icon-home { width: 22rpx; height: 10rpx; border-left: 3rpx solid #3b82f6; border-right: 3rpx solid #3b82f6; position: relative; margin-top: 14rpx; box-sizing: border-box; }
.icon-home::before { content: ''; position: absolute; top: -12rpx; left: 1rpx; width: 14rpx; height: 14rpx; border-top: 3rpx solid #3b82f6; border-right: 3rpx solid #3b82f6; transform: rotate(-45deg); border-radius: 2rpx; box-sizing: border-box; }
.icon-home::after { content: ''; position: absolute; top: -3rpx; left: -6rpx; right: -6rpx; height: 3rpx; background: #3b82f6; border-radius: 2rpx; }

/* 施工中：锤子 */
.icon-hammer { width: 12rpx; height: 20rpx; border: 3rpx solid #f97316; border-radius: 3rpx; position: relative; transform: rotate(45deg); margin-left: -4rpx; margin-top: 6rpx; box-sizing: border-box; }
.icon-hammer::before { content: ''; position: absolute; top: -6rpx; left: -8rpx; width: 22rpx; height: 10rpx; background: #f97316; border-radius: 4rpx; box-sizing: border-box; }

/* 列表�?*/
.list-container { flex: 1; padding: 20rpx 32rpx; width: 100%; box-sizing: border-box; }
.title { font-size: 32rpx; font-weight: bold; color: var(--primary-900); display: -webkit-box; -webkit-box-orient: vertical; -webkit-line-clamp: 2; overflow: hidden; }

.status-badge { padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 24rpx; font-weight: 500; white-space: nowrap; }
.status-active { background: #fff7ed; color: #ea580c; }
.status-done { background: var(--emerald-50); color: var(--emerald-600); }
.status-stop { background: var(--rose-50); color: var(--rose-600); }

.card-body { padding-left: 0; margin-bottom: 24rpx; }
.info-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.customer-name { font-size: 30rpx; color: var(--primary-600); font-weight: 500; }

.rating-badge { padding: 2rpx 12rpx; border-radius: 6rpx; font-size: 22rpx; font-weight: bold; color: #fff; }
.rating-A { background: var(--rose-600); }
.rating-B { background: var(--amber-600); }
.rating-C { background: #3b82f6; }
.rating-D { background: #94a3b8; }

/* 新版工地卡片样式 */
.project-card { background: #fff; border-radius: 24rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); border: 1rpx solid rgba(0,0,0,0.02); transition: all 0.2s; }
.project-card:active { transform: scale(0.98); background: #f8fafc; border-color: var(--primary-100); }

.card-header-new { border-bottom: 2rpx dashed #f1f5f9; padding-bottom: 24rpx; margin-bottom: 24rpx; }
.header-main { display: flex; align-items: center; gap: 24rpx; margin-bottom: 20rpx; }
.avatar-circle { width: 80rpx; height: 80rpx; border-radius: 40rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; flex-shrink: 0; }
.bg-primary { background: var(--primary-900); color: #fff; }
.bg-red { background: var(--rose-100); color: var(--rose-600); }
.text-red { color: var(--rose-600); }
.header-text { flex: 1; }
.customer-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 6rpx; }
.customer-name { font-size: 32rpx; font-weight: bold; color: var(--primary-900); }
.address-text { font-size: 24rpx; color: var(--primary-500); flex: 1; text-align: right; }
.manager-text { font-size: 24rpx; color: var(--primary-500); }

.header-meta { display: flex; align-items: center; gap: 32rpx; }
.meta-item { display: flex; flex-direction: column; gap: 4rpx; }
.meta-label { font-size: 22rpx; color: var(--primary-400); }
.meta-val { font-size: 26rpx; font-weight: bold; color: var(--primary-900); }

.health-badge { padding: 4rpx 16rpx; border-radius: 12rpx; font-size: 24rpx; font-weight: bold; margin-top: 10rpx; border: 2rpx solid transparent; }
.badge-green { background: var(--emerald-50); color: var(--emerald-600); border-color: var(--emerald-100); }
.badge-yellow { background: #fffbeb; color: var(--amber-600); border-color: var(--amber-100); }
.badge-red { background: var(--rose-50); color: var(--rose-600); border-color: var(--rose-100); }

/* 8节点进度�?*/
.card-body-new { margin-bottom: 32rpx; }
.node-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 24rpx; }
.node-title { font-size: 28rpx; font-weight: bold; color: var(--primary-900); }
.node-count { font-size: 24rpx; color: var(--primary-500); font-family: monospace; }

.node-progress-wrap { position: relative; padding: 0 20rpx; height: 60rpx; }
.node-line-bg { position: absolute; top: 18rpx; left: 20rpx; right: 20rpx; height: 6rpx; background: #f1f5f9; border-radius: 6rpx; }
.node-line-active { position: absolute; top: 18rpx; left: 20rpx; height: 6rpx; background: var(--primary-900); border-radius: 6rpx; transition: width 0.5s ease; }
.node-dots { position: absolute; top: 0; left: 20rpx; right: 20rpx; display: flex; justify-content: space-between; align-items: flex-start; }
.node-dot-wrap { display: flex; flex-direction: column; align-items: center; gap: 12rpx; width: 40rpx; }
.node-dot { width: 16rpx; height: 16rpx; border-radius: 8rpx; background: #cbd5e1; border: 4rpx solid #f8fafc; z-index: 2; transition: all 0.3s; margin-top: 9rpx; }
.node-dot.completed { background: var(--primary-900); border-color: var(--primary-900); }
.node-dot.current { background: var(--amber-600); border-color: var(--amber-50); width: 24rpx; height: 24rpx; border-radius: 12rpx; margin-top: 5rpx; }
.node-name { font-size: 20rpx; color: var(--primary-400); white-space: nowrap; transform: scale(0.9); }
.node-name.current-text { color: var(--primary-900); font-weight: bold; transform: scale(1); }

/* 底部按钮 */
.card-footer-new { display: flex; justify-content: space-between; align-items: center; margin-top: 24rpx; }
.footer-btns { display: flex; gap: 16rpx; }
.btn-outline { padding: 10rpx 24rpx; border: 2rpx solid #e2e8f0; border-radius: 12rpx; font-size: 24rpx; color: var(--primary-600); font-weight: 500; background: #f8fafc; }
.btn-primary-small { padding: 12rpx 32rpx; background: var(--primary-50); color: var(--primary-900); border-radius: 12rpx; font-size: 26rpx; font-weight: bold; }

/* 模态框通用 (与待办样式完全一致) */
.modal-mask { position: fixed; top: -100rpx; left: 0; right: 0; bottom: -200rpx; background: rgba(0,0,0,0.5); z-index: 999; }
.modal-content { position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 90%; height: 65vh; background: #fff; border-radius: 24rpx; z-index: 1000; overflow: hidden; display: flex; flex-direction: column; }
.modal-header { padding: 32rpx 40rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; font-size: 32rpx; font-weight: bold; color: var(--primary-900); flex-shrink: 0; position: relative; }
.modal-header text { width: 100%; text-align: left; }
.btn-close { font-size: 28rpx; color: #94a3b8; font-weight: normal; padding: 10rpx; margin: -10rpx; position: absolute; right: 40rpx; top: 50%; transform: translateY(-50%); z-index: 10; }
.modal-scroll { flex: 1; height: 100%; }
.modal-body { padding: 40rpx; padding-bottom: 120rpx; }
.modal-list { flex: 1; padding: 40rpx; box-sizing: border-box; }

.filter-section { margin-bottom: 48rpx; }
.filter-title { font-size: 28rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 24rpx; }
.filter-tags { display: flex; flex-wrap: wrap; gap: 20rpx; }
.filter-tag { padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 26rpx; background: #f8fafc; color: var(--primary-600); border: 2rpx solid transparent; transition: all 0.2s; }
.filter-tag.active { background: #4a403a; color: #fff; border-color: #4a403a; font-weight: normal; }

/* 日期范围 */
.date-range { display: flex; align-items: center; gap: 20rpx; }
.date-picker-item { flex: 1; height: 80rpx; background: #f8fafc; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: var(--primary-400); border: 2rpx solid transparent; width: 100%; box-sizing: border-box; }
.date-picker-item.active { background: #4a403a; color: #fff; border-color: #4a403a; }
.date-range-sep { font-size: 26rpx; color: var(--primary-400); flex-shrink: 0; padding: 0 10rpx; }

/* Filter Section Groups */
.dept-title { font-size: 26rpx; color: var(--primary-900); margin: 24rpx 0 12rpx; font-weight: bold; padding: 16rpx 24rpx; background: #f8fafc; border-radius: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.dept-employees { padding: 0 12rpx; }
.arrow { width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; }
.arrow.down { border-top: 10rpx solid #94a3b8; border-bottom: none; }
.arrow.up { border-bottom: 10rpx solid #94a3b8; border-top: none; }


/* 开工时间日期选择�?*/
.date-range-picker { display: flex; align-items: center; gap: 20rpx; margin-top: 10rpx; }
.date-box { padding: 12rpx 32rpx; background: #f8fafc; border: 2rpx solid #e2e8f0; border-radius: 40rpx; font-size: 28rpx; color: var(--primary-400); text-align: center; min-width: 180rpx; transition: all 0.2s; }
.date-box.active { background: var(--primary-50); border-color: var(--primary-900); color: var(--primary-900); font-weight: 500; }
.date-separator { font-size: 28rpx; color: var(--primary-400); font-weight: bold; }

.actions { display: flex; align-items: center; gap: 16rpx; }
.btn-add { background: var(--primary-900); color: #fff; padding: 12rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; font-weight: 500; display: flex; align-items: center; gap: 6rpx; }
.date-filter-box { display: flex; align-items: center; gap: 8rpx; padding: 10rpx 24rpx; background: #f8fafc; border-radius: 40rpx; border: 1rpx solid transparent; font-size: 24rpx; color: var(--primary-600); font-weight: 500; }
.date-filter-box .arrow-down { width: 0; height: 0; border-left: 8rpx solid transparent; border-right: 8rpx solid transparent; border-top: 8rpx solid var(--primary-400); margin-top: 4rpx; }

/* 筛选与搜索 */
.search-bar { display: flex; gap: 16rpx; align-items: center; }
.search-input-wrap { background: #fff; border-radius: 40rpx; display: flex; align-items: center; padding: 0 24rpx; height: 80rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); flex: 1; }
.search-input-wrap icon { margin-right: 16rpx; }
.search-input-wrap input { flex: 1; font-size: 28rpx; color: var(--primary-900); }

/* 高级筛选按钮已经复�?app.wxss 中的 btn-filter */

/* 高级筛选弹�?(从底部滑出风�? */
.filter-modal { position: fixed; bottom: -100%; left: 0; width: 100%; background: #fff; z-index: 1000; display: flex; flex-direction: column; transition: bottom 0.3s ease; border-top-left-radius: 40rpx; border-top-right-radius: 40rpx; box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1); }
.filter-modal.show { bottom: 0; }
.filter-header { padding: 40rpx 40rpx 32rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; }
.filter-header .title { font-size: 36rpx; font-weight: bold; color: var(--primary-900); }
.filter-body { flex: 1; padding: 40rpx; }
.filter-group { margin-bottom: 48rpx; }
.group-title { font-size: 28rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 24rpx; }
.tags-wrap { display: flex; flex-wrap: wrap; gap: 20rpx; }
.tag { padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 26rpx; background: #f8fafc; color: var(--primary-600); border: 2rpx solid transparent; transition: all 0.2s; }
.tag.active { background: var(--rose-50); color: var(--rose-600); border-color: var(--rose-500); }

.date-range { display: flex; align-items: center; justify-content: center; gap: 20rpx; }
.date-picker-item { flex: 1; height: 80rpx; background: #f8fafc; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 26rpx; color: var(--primary-400); border: 2rpx solid transparent; width: 100%; box-sizing: border-box; }
.date-picker-item.active { background: #fffbeb; color: var(--primary-900); border-color: var(--amber-100); font-weight: bold; }
.date-range-sep { font-size: 26rpx; color: var(--primary-400); flex-shrink: 0; padding: 0 10rpx; }

.filter-footer { padding: 32rpx 40rpx; padding-bottom: calc(32rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #f1f5f9; display: flex; gap: 24rpx; }
.btn-reset { flex: 1; height: 88rpx; border-radius: 44rpx; background: #f8fafc; color: var(--primary-600); font-size: 32rpx; font-weight: bold; display: flex; align-items: center; justify-content: center; }
.btn-confirm { flex: 2; height: 88rpx; border-radius: 44rpx; background: var(--primary-900); color: #fff; font-size: 32rpx; font-weight: bold; display: flex; align-items: center; justify-content: center; }

/* 交互反馈 */
.hover-scale { transition: transform 0.1s ease; }
.hover-scale:active { transform: scale(0.96); }

/* 模态框通用已在 app.wxss 中定义 */
.center-modal-content { position: fixed; top: 50%; left: 50%; bottom: auto; transform: translate(-50%, -50%); width: 85%; background: #fff; border-radius: 24rpx; z-index: 1000; overflow: hidden; display: flex; flex-direction: column; max-height: 80vh; }
.modal-header { padding: 32rpx 40rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; font-size: 32rpx; font-weight: bold; color: var(--primary-900); }
.btn-close { font-size: 28rpx; color: #94a3b8; font-weight: normal; }
.modal-body { padding: 40rpx; padding-bottom: 80rpx; }
.form-group { margin-bottom: 32rpx; }
.label { display: block; font-size: 28rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 16rpx; }
.input, .picker-view { background: #f8fafc; border-radius: 16rpx; padding: 0 24rpx; height: 88rpx; border: 2rpx solid #e2e8f0; font-size: 30rpx; color: var(--primary-900); display: flex; align-items: center; justify-content: space-between; }
.arrow-down { width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-top: 10rpx solid #94a3b8; }

/* 多选弹窗 */
.multi-select-modal { position: fixed; bottom: 0; left: 0; right: 0; background: #fff; border-radius: 32rpx 32rpx 0 0; z-index: 1000; padding-bottom: env(safe-area-inset-bottom); display: flex; flex-direction: column; max-height: 80vh; }
.ms-header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 40rpx; border-bottom: 1rpx solid #f1f5f9; }
.ms-cancel { font-size: 30rpx; color: #94a3b8; padding: 10rpx; margin-left: -10rpx; }
.ms-title { font-size: 32rpx; font-weight: bold; color: #1e293b; }
.ms-confirm { font-size: 30rpx; font-weight: bold; color: var(--primary-600); padding: 10rpx; margin-right: -10rpx; }
.ms-list { flex: 1; padding: 0 40rpx; box-sizing: border-box; }
.ms-item { display: flex; justify-content: space-between; align-items: center; padding: 32rpx 0; border-bottom: 1rpx solid #f8fafc; }
.ms-name { font-size: 30rpx; color: #334155; font-weight: 500; }
.checkbox { width: 40rpx; height: 40rpx; border-radius: 8rpx; border: 2rpx solid #cbd5e1; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
.checkbox.checked { background: var(--primary-600); border-color: var(--primary-600); }
.checkmark { width: 12rpx; height: 20rpx; border: solid #fff; border-width: 0 4rpx 4rpx 0; transform: rotate(45deg); margin-top: -4rpx; }
.btn-save { background: var(--primary-900); color: #fff; text-align: center; padding: 24rpx 0; border-radius: 16rpx; font-size: 32rpx; font-weight: bold; margin-top: 48rpx; }


