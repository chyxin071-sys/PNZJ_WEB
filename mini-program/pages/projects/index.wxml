<view class="page-container">

  <!-- 顶部数据看板 -->
  <view class="dashboard">
    <view class="dashboard-header">
      <text class="dashboard-title">工地管理</text>
      <view class="actions">
        <picker mode="selector" range="{{timeFilterOptions}}" value="{{timeFilterIndex}}" bindchange="onTimeFilterChange">
          <view class="date-filter-box">
            <text>{{timeFilterLabel}}</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="dashboard-cards">
      <!-- 全部卡片 -->
      <view class="stat-card {{activeTab === '全部' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="全部">
        <view class="icon-box bg-blue-50">
          <view class="icon-home"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">全部工地</text>
          <text class="stat-num">{{totalCount}}</text>
        </view>
      </view>
      <!-- 施工中卡片 -->
      <view class="stat-card {{activeTab === '施工中' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="施工中">
        <view class="icon-box bg-orange-50">
          <view class="icon-hammer"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">施工中</text>
          <text class="stat-num">{{activeCount}}</text>
        </view>
      </view>
      <!-- 已竣工卡片 -->
      <view class="stat-card {{activeTab === '已竣工' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="已竣工">
        <view class="icon-box bg-emerald-50">
          <view class="icon-check"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">已竣工</text>
          <text class="stat-num">{{completedCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作栏 (搜索+新建) -->
  <view class="action-bar">
    <view class="search-wrap">
      <icon type="search" size="16" color="#b5a49a" />
      <input placeholder="搜索小区/客户/项目经理..." placeholder-class="ph" bindinput="onSearch" />
    </view>
    <!-- 高级筛选器 (三横线图标) -->
    <view class="btn-filter hover-scale" bindtap="openAdvancedFilter">
      <view class="icon-filter">
        <view class="line-mid"></view>
      </view>
      <view class="filter-badge" wx:if="{{selectedEmployeeIds.length > 0 || selectedStatuses.length > 0 || filterStartDateStart || filterStartDateEnd}}"></view>
    </view>
    <view class="btn-create-small" hover-class="btn-create-hover" bindtap="createProject" wx:if="{{canCreate}}">
      <view class="plus-icon"></view>
      <text>新建</text>
    </view>
  </view>

  <!-- 工地列表区 -->
  <scroll-view scroll-y class="list-container">
    <view class="project-card" wx:for="{{projects}}" wx:key="_id" bindtap="goToDetail" data-id="{{item._id}}">
      
      <!-- 头部信息区 -->
      <view class="card-header-new">
        <view class="header-main" style="display: flex; justify-content: space-between; align-items: flex-start;">
          <view class="header-text" style="flex: 1;">
            <view class="customer-row" style="margin-bottom: 12rpx;">
              <text class="address-text" style="font-size: 34rpx; font-weight: bold; color: #1a1a1a;">{{item.address || '未知小区'}}</text>
            </view>
            <view class="info-row" style="margin-bottom: 8rpx; display: flex; align-items: center;">
              <text style="font-size: 28rpx; font-weight: 500; color: #333; margin-right: 16rpx;">{{item.customer}} <text style="font-size:24rpx; color:#666; font-weight:normal;">{{item.customerNo || item.leadId}}</text></text>
              <text style="font-size: 26rpx; color: #666;">{{item.phone || '暂无电话'}}</text>
            </view>
            <view class="manager-text" style="font-size: 24rpx; color: #888; margin-top: 8rpx;">
              项目经理: {{item.manager || '未分配'}} | 销售: {{item.sales || '未分配'}} | 设计: {{item.designer || '未分配'}}
            </view>
          </view>
          <view class="health-badge {{item.health === '严重延期' ? 'badge-red' : (item.health === '预警' ? 'badge-yellow' : 'badge-green')}}" style="flex-shrink: 0; font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 8rpx; margin-left: 20rpx;">
            {{item.health}}
          </view>
        </view>
        
        <view class="header-meta" style="margin-top: 24rpx; display: flex; justify-content: space-between; padding-top: 20rpx; border-top: 1rpx dashed #eee;">
          <view class="meta-item" style="display: flex; flex-direction: column; align-items: flex-start;">
            <text class="meta-label" style="font-size: 22rpx; color: #999; margin-bottom: 8rpx;">开工时间</text>
            <text class="meta-val" style="font-size: 26rpx; color: #333; font-weight: 500;">{{item.startDate || '-'}}</text>
          </view>
          <view class="meta-item" style="display: flex; flex-direction: column; align-items: flex-start;">
            <text class="meta-label" style="font-size: 22rpx; color: #999; margin-bottom: 8rpx;">预计完工</text>
            <text class="meta-val" style="font-size: 26rpx; color: #333; font-weight: 500;">{{item.expectedEndDate || '-'}}</text>
          </view>
          <view class="meta-item" style="display: flex; flex-direction: column; align-items: flex-start;">
            <text class="meta-label" style="font-size: 22rpx; color: #999; margin-bottom: 8rpx;">已耗时</text>
            <text class="meta-val" style="font-size: 26rpx; color: #333; font-weight: 500;">{{item.daysElapsed}}天</text>
          </view>
        </view>
      </view>

      <!-- 8节点进度条区 -->
      <view class="card-body-new">
        <view class="node-header">
          <text class="node-title">当前阶段: {{item.nodeName}}</text>
          <text class="node-count">{{item.currentNode}} / 8</text>
        </view>
        
        <view class="node-progress-wrap">
          <view class="node-line-bg"></view>
          <view class="node-line-active" style="width: calc((100% - 40rpx) * {{(item.currentNode - 1) / 7}});"></view>
          
          <view class="node-dots">
            <view class="node-dot-wrap" wx:for="{{item.nodesList}}" wx:for-item="node" wx:for-index="idx" wx:key="*this">
              <view class="node-dot {{idx + 1 < item.currentNode ? 'completed' : (idx + 1 === item.currentNode ? 'current' : 'pending')}}"></view>
              <text class="node-name {{idx + 1 === item.currentNode ? 'current-text' : ''}}">{{node}}</text>
            </view>
          </view>
        </view>
      </view>

      <!-- 底部操作区：合同、报价、详情 -->
      <view class="card-footer-new" style="justify-content: flex-end;">
        <view class="btn-primary-small" catchtap="goToDetail">
          <text>查看详情</text>
        </view>
      </view>

    </view>
    
    <view class="empty-state" wx:if="{{projects.length === 0}}">
      <view class="empty-icon"></view>
      <text>暂无相关工地</text>
    </view>
    
    <view class="bottom-padding"></view>
  </scroll-view>

  <!-- 高级筛选弹窗 (修改为团队待办样式的居中弹窗) -->
  <view class="modal-mask" wx:if="{{showFilterModal}}" bindtap="closeFilterModal"></view>
  <view class="modal-content" wx:if="{{showFilterModal}}">
    <view class="modal-header">
      <text>工地高级筛选</text>
      <view class="btn-close" bindtap="applyFilter">确定</view>
    </view>
    <scroll-view scroll-y class="modal-list" style="height: 60vh;">
      <view class="filter-section">
        <view class="filter-title">状态</view>
        <view class="filter-tags">
          <view class="filter-tag {{item.selected ? 'active' : ''}}" wx:for="{{filterStatuses}}" wx:key="name" bindtap="toggleStatus" data-name="{{item.name}}">{{item.name}}</view>
        </view>
      </view>

      <view class="filter-section">
        <view class="filter-title">开工时间</view>
        <view class="date-range">
          <picker mode="date" value="{{filterStartDateStart}}" bindchange="onStartDateStartChange" style="flex: 1;">
            <view class="date-picker-item {{filterStartDateStart ? 'active' : ''}}" style="width: 100%;">
              {{filterStartDateStart || '开始日期'}}
            </view>
          </picker>
          <view class="date-range-sep">至</view>
          <picker mode="date" value="{{filterStartDateEnd}}" bindchange="onStartDateEndChange" style="flex: 1;">
            <view class="date-picker-item {{filterStartDateEnd ? 'active' : ''}}" style="width: 100%;">
              {{filterStartDateEnd || '结束日期'}}
            </view>
          </picker>
        </view>
      </view>

      <view class="filter-section">
        <view class="filter-title">负责人员</view>
        <block wx:for="{{groupedEmployees}}" wx:key="dept">
          <view class="dept-title">{{item.dept}}</view>
          <view class="employee-item" wx:for="{{item.employees}}" wx:for-item="emp" wx:key="id" bindtap="toggleEmployee" data-id="{{emp.id}}">
            <view class="checkbox {{emp.selected ? 'checked' : ''}}">
              <view wx:if="{{emp.selected}}" class="checkmark"></view>
            </view>
            <text class="emp-name">{{emp.name}}</text>
          </view>
        </block>
      </view>
    </scroll-view>
  </view>

  <!-- 新建工地弹窗 -->
  <view class="modal-mask" wx:if="{{showAddModal}}" bindtap="closeAddModal"></view>
  <view class="modal-content" wx:if="{{showAddModal}}">
    <view class="modal-header">
      <text>新建工地</text>
      <view class="btn-close" bindtap="closeAddModal">取消</view>
    </view>
    <scroll-view scroll-y style="max-height: 65vh;">
      <view class="modal-body">
        <view class="form-group">
          <text class="label">客户姓名 <text style="color:red">*</text></text>
          <input class="input" placeholder="请输入姓名" value="{{newProject.customer}}" bindinput="onNewProjectInput" data-field="customer" />
        </view>
        <view class="form-group">
          <text class="label">手机号 <text style="color:red">*</text></text>
          <input class="input" type="number" placeholder="请输入手机号" value="{{newProject.phone}}" bindinput="onNewProjectInput" data-field="phone" />
        </view>
        <view class="form-group">
          <text class="label">所在小区 (工地地址) <text style="color:red">*</text></text>
          <input class="input" placeholder="如：保利香槟国际2-1-201" value="{{newProject.address}}" bindinput="onNewProjectInput" data-field="address" />
        </view>
        <view class="form-group">
          <text class="label">计划开工时间 <text style="color:red">*</text></text>
          <picker mode="date" value="{{newProject.startDate}}" bindchange="onNewProjectDateChange">
            <view class="picker-view">
              <text>{{newProject.startDate || '请选择日期'}}</text>
              <view class="arrow-down"></view>
            </view>
          </picker>
        </view>
        <view class="btn-save hover-scale" bindtap="saveNewProject">保 存</view>
      </view>
    </scroll-view>
  </view>

</view>