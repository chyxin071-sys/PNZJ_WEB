<view class="page-container">

  <!-- 顶部数据看板 -->
  <view class="dashboard">
    <view class="dashboard-header">
      <text class="dashboard-title">工地管理</text>
      <view class="actions">
        <picker mode="selector" range="{{timeFilterOptions}}" value="{{timeFilterIndex}}" bindchange="onTimeFilterChange">
          <view class="date-filter-box">
            <text>{{timeFilterLabel}}</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="dashboard-cards">
      <!-- 全部卡片 -->
      <view class="stat-card {{activeTab === '全部' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="全部">
        <view class="icon-box bg-blue-50">
          <view class="icon-home"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">全部工地</text>
          <text class="stat-num">{{totalCount}}</text>
        </view>
      </view>
      <!-- 施工中卡片 -->
      <view class="stat-card {{activeTab === '施工中' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="施工中">
        <view class="icon-box bg-orange-50">
          <view class="icon-hammer"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">施工中</text>
          <text class="stat-num">{{activeCount}}</text>
        </view>
      </view>
      <!-- 已竣工卡片 -->
      <view class="stat-card {{activeTab === '已竣工' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="已竣工">
        <view class="icon-box bg-emerald-50">
          <view class="icon-check"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">已竣工</text>
          <text class="stat-num">{{completedCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作栏 (搜索+新建) -->
  <view class="action-bar">
    <view class="search-wrap">
      <icon type="search" size="16" color="#b5a49a" />
      <input placeholder="搜索小区/客户/项目经理..." placeholder-class="ph" bindinput="onSearch" />
    </view>
    <!-- 高级筛选器 (三横线图标) -->
    <view class="btn-filter hover-scale" bindtap="openAdvancedFilter">
      <view class="icon-filter">
        <view class="line-mid"></view>
      </view>
      <view class="filter-badge" wx:if="{{selectedEmployeeIds.length > 0 || selectedStatuses.length > 0 || filterStartDateStart || filterStartDateEnd}}"></view>
    </view>
    <view class="btn-create-small" hover-class="btn-create-hover" bindtap="createProject" wx:if="{{canCreate}}">
      <view class="plus-icon"></view>
      <text>新建</text>
    </view>
  </view>

  <!-- 工地列表区 -->
  <view class="list-container" style="overflow: hidden; padding: 0 24rpx;">
    <view class="swipe-container" wx:for="{{projects}}" wx:key="_id" style="margin-bottom: 24rpx; border-radius: 24rpx; overflow: hidden; transform: translateZ(0);">
      <scroll-view class="swipe-area" scroll-x enhanced show-scrollbar="{{false}}" bounces="{{true}}" paging-enabled="{{true}}" fast-deceleration="{{true}}" style="width: 100%; white-space: nowrap; scroll-snap-type: x mandatory;">
        <view class="swipe-view" style="display: inline-flex; min-width: 100%;">
          
          <!-- 表面内容卡片 (滚动对齐点) -->
          <view class="project-card" style="width: calc(100vw - 48rpx); scroll-snap-align: start; flex-shrink: 0; white-space: normal; margin-bottom: 0; border-radius: 24rpx; box-sizing: border-box;" bindtap="goToDetail" data-id="{{item._id}}">
            <!-- 头部信息区 -->
            <view class="card-header-new">
        <view class="header-main" style="display: flex; justify-content: space-between; align-items: flex-start;">
          <view class="header-text" style="flex: 1; text-align: left;">
            <view class="customer-row" style="margin-bottom: 12rpx; text-align: left;">
              <text class="address-text" style="font-size: 34rpx; font-weight: bold; color: #1a1a1a; display: block; width: 100%; text-align: left;">{{item.address || '未知小区'}}</text>
            </view>
            <view class="info-row" style="margin-bottom: 8rpx; display: flex; align-items: center; justify-content: flex-start;">
              <customer-info 
                name="{{item.customer}}" 
                phone="{{item.phone}}" 
                customerNo="{{item.customerNo || item.leadId}}" 
              />
            </view>
            <view class="manager-text" style="font-size: 24rpx; color: #888; margin-top: 8rpx;">
              项目经理: {{item.manager || '未分配'}} | 销售: {{item.sales || '未分配'}} | 设计: {{item.designer || '未分配'}}
            </view>
          </view>
          <view class="health-badge {{item.health === '严重延期' ? 'badge-red' : (item.health === '预警' ? 'badge-yellow' : 'badge-green')}}" style="flex-shrink: 0; font-size: 24rpx; padding: 4rpx 16rpx; border-radius: 8rpx; margin-left: 20rpx;">
            {{item.health}}
          </view>
        </view>
        
        <view class="header-meta" style="margin-top: 24rpx; display: flex; justify-content: space-between; padding-top: 20rpx; border-top: 1rpx dashed #eee;">
          <view class="meta-item" style="display: flex; flex-direction: column; align-items: flex-start;">
            <text class="meta-label" style="font-size: 22rpx; color: #999; margin-bottom: 8rpx;">开工时间</text>
            <text class="meta-val" style="font-size: 26rpx; color: #333; font-weight: 500;">{{item.startDate || '-'}}</text>
          </view>
          <view class="meta-item" style="display: flex; flex-direction: column; align-items: flex-start;">
            <text class="meta-label" style="font-size: 22rpx; color: #999; margin-bottom: 8rpx;">预计完工</text>
            <text class="meta-val" style="font-size: 26rpx; color: #333; font-weight: 500;">{{item.expectedEndDate || '-'}}</text>
          </view>
          <view class="meta-item" style="display: flex; flex-direction: column; align-items: flex-start;">
            <text class="meta-label" style="font-size: 22rpx; color: #999; margin-bottom: 8rpx;">已耗时</text>
            <text class="meta-val" style="font-size: 26rpx; color: #333; font-weight: 500;">{{item.daysElapsed}}天</text>
          </view>
        </view>
      </view>

      <!-- 8节点进度条区 -->
      <view class="card-body-new">
        <view class="node-header">
          <text class="node-title">当前阶段: {{item.nodeName}}</text>
          <text class="node-count">{{item.currentNode}} / 8</text>
        </view>
        
        <view class="node-progress-wrap">
          <view class="node-line-bg"></view>
          <view class="node-line-active" style="width: calc((100% - 40rpx) * {{(item.currentNode - 1) / 7}}); background: var(--emerald-600);"></view>
          
          <view class="node-dots">
            <view class="node-dot-wrap" wx:for="{{item.nodesList}}" wx:for-item="node" wx:for-index="idx" wx:key="*this">
              <view class="node-dot {{idx + 1 < item.currentNode ? 'completed' : (idx + 1 === item.currentNode ? 'current' : 'pending')}}" style="{{idx + 1 < item.currentNode ? 'background: var(--emerald-600);' : ''}}"></view>
              <text class="node-name {{idx + 1 === item.currentNode ? 'current-text' : ''}}">{{node}}</text>
            </view>
          </view>
        </view>
      </view>

          </view>
          
          <!-- 右侧滑动按钮区域 (滚动对齐点) -->
          <view class="swipe-actions" wx:if="{{isAdmin || item.manager === currentUserName}}" style="width: 160rpx; display: flex; flex-shrink: 0; scroll-snap-align: end; background: transparent; padding-left: 20rpx;">
            <view class="swipe-btn delete" catchtap="deleteProject" data-id="{{item._id}}" style="width: 140rpx; background: var(--rose-500); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold; border-radius: 24rpx; box-shadow: 0 4rpx 12rpx rgba(244, 63, 94, 0.2);">删除</view>
          </view>
          
        </view>
      </scroll-view>
    </view>
    
    <view class="empty-state" wx:if="{{projects.length === 0}}">
      <view class="empty-icon"></view>
      <text>暂无相关工地</text>
    </view>
    
    <view class="pb-tabbar"></view>
  </view>

  <!-- 高级筛选弹窗 -->
  <block wx:if="{{showFilterModal}}">
    <view class="modal-mask" bindtap="closeFilterModal"></view>
    <view class="modal-content">
        <view class="modal-header">
          <text>工地高级筛选</text>
          <view class="btn-close" bindtap="applyFilter">确定</view>
        </view>
        <scroll-view scroll-y class="modal-list" style="height: 60vh;">
      <view class="filter-section">
        <view class="filter-title">范围</view>
        <view class="filter-tags">
          <view class="filter-tag {{filterScope === '与我相关' ? 'active' : ''}}" bindtap="switchScope" data-scope="与我相关">与我相关</view>
          <view class="filter-tag {{filterScope === '全部工地' ? 'active' : ''}}" bindtap="switchScope" data-scope="全部工地">全部工地</view>
        </view>
      </view>

      <view class="filter-section">
        <view class="filter-title">状态</view>
        <view class="filter-tags">
          <view class="filter-tag {{item.selected ? 'active' : ''}}" wx:for="{{filterStatuses}}" wx:key="name" bindtap="toggleStatus" data-name="{{item.name}}">{{item.name}}</view>
        </view>
      </view>

      <view class="filter-section">
        <view class="filter-title">开工时间</view>
        <view class="date-range">
          <picker mode="date" value="{{filterStartDateStart}}" bindchange="onStartDateStartChange" style="flex: 1;">
            <view class="date-picker-item {{filterStartDateStart ? 'active' : ''}}" style="width: 100%;">
              {{filterStartDateStart || '开始日期'}}
            </view>
          </picker>
          <view class="date-range-sep">至</view>
          <picker mode="date" value="{{filterStartDateEnd}}" bindchange="onStartDateEndChange" style="flex: 1;">
            <view class="date-picker-item {{filterStartDateEnd ? 'active' : ''}}" style="width: 100%;">
              {{filterStartDateEnd || '结束日期'}}
            </view>
          </picker>
        </view>
      </view>

      <view class="filter-section">
        <view class="filter-title">负责人员</view>
        <block wx:for="{{groupedEmployees}}" wx:key="dept">
          <view class="dept-title" bindtap="toggleDept" data-dept="{{item.dept}}">
            <text>{{item.dept}}</text>
            <view class="arrow {{item.expanded ? 'up' : 'down'}}"></view>
          </view>
          <view class="dept-employees" wx:if="{{item.expanded}}">
            <view class="employee-item" wx:for="{{item.employees}}" wx:for-item="emp" wx:key="id" bindtap="toggleEmployee" data-id="{{emp.id}}">
              <view class="checkbox {{emp.selected ? 'checked' : ''}}">
                <view wx:if="{{emp.selected}}" class="checkmark"></view>
              </view>
              <text class="emp-name">{{emp.name}}</text>
            </view>
          </view>
        </block>
      </view>
      </scroll-view>
    </view>
  </block>

  <!-- 添加工地弹窗 -->
  <block wx:if="{{showAddModal}}">
    <view class="modal-mask" bindtap="closeAddModal"></view>
    <view class="modal-content">
        <view class="modal-header">
          <text>新建工地</text>
          <view class="btn-close" bindtap="closeAddModal">取消</view>
        </view>
        <scroll-view scroll-y style="max-height: 65vh;">
        <view class="modal-body">
          <view class="form-group">
            <text class="label">关联客户 (仅已签单客户) <text style="color:red">*</text></text>
            <picker bindchange="onLeadChange" range="{{leads}}" range-key="pickerLabel" value="{{leadIndex}}">
              <view class="picker-view" style="height: 88rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between;">
                <text style="{{leadIndex === -1 ? 'color: #94a3b8;' : ''}}">{{leadIndex === -1 ? '请选择关联客户' : leads[leadIndex].name}}</text>
                <view class="arrow-down" style="width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-top: 10rpx solid #94a3b8;"></view>
              </view>
            </picker>
          </view>

          <!-- 客户详细信息只读展示 -->
          <block wx:if="{{leadIndex !== -1}}">
            <view class="info-box" style="background: #f1f5f9; border-radius: 16rpx; padding: 24rpx; margin-top: -16rpx; margin-bottom: 32rpx;">
              <view class="info-row" style="display: flex; justify-content: space-between; margin-bottom: 12rpx; font-size: 26rpx;">
                <text class="info-label" style="color: var(--primary-500);">客户地址</text>
                <text class="info-val" style="color: var(--primary-900); font-weight: 500;">{{leads[leadIndex].address || '未填写'}}</text>
              </view>
              <view class="info-row" style="display: flex; justify-content: space-between; margin-bottom: 12rpx; font-size: 26rpx;">
                <text class="info-label" style="color: var(--primary-500);">签单时间</text>
                <text class="info-val" style="color: var(--primary-900); font-weight: 500;">{{leads[leadIndex].signDate || '未知'}}</text>
              </view>
              <view class="info-row" style="display: flex; justify-content: space-between; margin-bottom: 12rpx; font-size: 26rpx;">
                <text class="info-label" style="color: var(--primary-500);">归属销售</text>
                <text class="info-val" style="color: var(--primary-900); font-weight: 500;">{{leads[leadIndex].sales || '未分配'}}</text>
              </view>
              <view class="info-row" style="display: flex; justify-content: space-between; margin-bottom: 0; font-size: 26rpx;">
                <text class="info-label" style="color: var(--primary-500);">归属设计</text>
                <text class="info-val" style="color: var(--primary-900); font-weight: 500;">{{leads[leadIndex].designer || '未分配'}}</text>
              </view>
            </view>
          </block>

          <view class="form-group">
            <text class="label">项目经理 <text style="color:red">*</text></text>
            <view class="picker-view" bindtap="openMultiSelect" data-field="manager" style="height: 88rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between;">
              <text class="{{!newProject.manager ? 'text-placeholder' : ''}}">{{newProject.manager || '请选择项目经理 (可多选)'}}</text>
              <view class="arrow-down" style="width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-top: 10rpx solid #94a3b8;"></view>
            </view>
          </view>
          
          <view class="form-group">
            <text class="label">计划开工日期 <text style="color:red">*</text></text>
            <picker mode="date" value="{{newProject.startDate}}" bindchange="onStartDateChange">
              <view class="picker-view" style="height: 88rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between;">
                <text style="{{!newProject.startDate ? 'color: #94a3b8;' : ''}}">{{newProject.startDate || '请选择计划开工日期'}}</text>
                <view class="arrow-down" style="width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-top: 10rpx solid #94a3b8;"></view>
              </view>
            </picker>
          </view>

          <view class="form-group">
            <text class="label">排期模板</text>
            <view class="picker-view" style="height: 88rpx; border: 2rpx solid #e2e8f0; border-radius: 16rpx; padding: 0 24rpx; display: flex; align-items: center; justify-content: space-between; background: #f8fafc;">
              <text style="color: #64748b;">默认标准排期模板 (T+N)</text>
              <view style="color: #cbd5e1; font-size: 24rpx;">只读</view>
            </view>
          </view>
          
          <view class="btn-save hover-scale" bindtap="saveProject">保 存</view>
        </view>
        <view style="height: 48rpx;"></view>
      </scroll-view>
    </view>
  </block>

  <!-- 多选弹窗 -->
  <view class="modal-mask" wx:if="{{showMultiSelect}}" bindtap="closeMultiSelect"></view>
  <view class="multi-select-modal" wx:if="{{showMultiSelect}}">
    <view class="ms-header">
      <view class="ms-cancel" bindtap="closeMultiSelect">取消</view>
      <view class="ms-title">选择项目经理 (可多选)</view>
      <view class="ms-confirm" bindtap="confirmMultiSelect">确定</view>
    </view>
    <scroll-view scroll-y class="ms-list">
      <view class="ms-item" wx:for="{{currentMultiList}}" wx:key="name" bindtap="toggleMultiSelect" data-index="{{index}}">
        <view class="ms-name">{{item.name}}</view>
        <view class="checkbox {{item.checked ? 'checked' : ''}}">
          <view wx:if="{{item.checked}}" class="checkmark"></view>
        </view>
      </view>
    </scroll-view>
  </view>

</view>