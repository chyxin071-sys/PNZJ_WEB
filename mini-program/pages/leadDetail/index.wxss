@import "../leads/index.wxss";

.page-container { height: 100vh; display: flex; flex-direction: column; background: #faf9f8; overflow: hidden; }

/* 顶部卡片 */
.top-card { background: #fff; padding: 40rpx; margin: 24rpx; border-radius: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); }
.name { font-size: 36rpx; font-weight: bold; color: var(--primary-900); }
.address { font-size: 28rpx; color: var(--primary-600); }
.btn-edit-icon { padding: 8rpx 28rpx; background: #f1f5f9; color: var(--primary-600); border-radius: 30rpx; font-size: 26rpx; font-weight: bold; border: 1rpx solid #e2e8f0; }

/* 快捷操作�?(Web卡片风格) */
.action-cards { display: flex; gap: 20rpx; margin-top: 32rpx; border-top: 1rpx solid #f1f5f9; padding-top: 32rpx; }
.action-cards.one-card { flex-direction: column; }
.action-cards.two-cards { flex-direction: row; }

.action-card { flex: 1; border-radius: 16rpx; padding: 24rpx 20rpx; display: flex; align-items: center; justify-content: space-between; border: 2rpx solid transparent; font-size: 28rpx; font-weight: bold; transition: all 0.2s; }
.action-cards.two-cards .action-card { flex-direction: column; align-items: flex-start; gap: 16rpx; padding: 20rpx; }
.action-cards.two-cards .ac-left { gap: 12rpx; }
.action-cards.two-cards .icon-arrow-right, .action-cards.two-cards .icon-arrow-right-green { align-self: flex-end; }

.ac-left { display: flex; align-items: center; gap: 16rpx; }

/* 报价单卡�?*/
.quote-card { background: #fff; color: #1e293b; border-color: #e2e8f0; }
.icon-doc { width: 32rpx; height: 36rpx; border: 4rpx solid #334155; border-radius: 6rpx; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6rpx; }
.icon-doc::before { content: ''; width: 16rpx; height: 4rpx; background: #334155; border-radius: 2rpx; }
.icon-doc::after { content: ''; width: 12rpx; height: 4rpx; background: #334155; border-radius: 2rpx; margin-right: 4rpx; }

.icon-arrow-right { width: 16rpx; height: 16rpx; border-top: 4rpx solid #334155; border-right: 4rpx solid #334155; transform: rotate(45deg); margin-right: 4rpx; }

/* 工地大屏卡片 (改为黑白样式与报价单一�? */
.project-card { background: #fff; color: #1e293b; border-color: #e2e8f0; }
.icon-folder { width: 36rpx; height: 28rpx; border: 4rpx solid #334155; border-radius: 6rpx; position: relative; }
.icon-folder::before { content: ''; position: absolute; top: -8rpx; left: -4rpx; width: 16rpx; height: 8rpx; border: 4rpx solid #334155; border-bottom: none; border-radius: 6rpx 6rpx 0 0; }

.icon-arrow-right-green { width: 16rpx; height: 16rpx; border-top: 4rpx solid #334155; border-right: 4rpx solid #334155; transform: rotate(45deg); margin-right: 4rpx; }

/* 选项�?*/
.tabs { display: flex; background: #fff; border-bottom: 1rpx solid #f1f5f9; }
.tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: var(--primary-600); font-weight: 500; position: relative; }
.tab.active { color: var(--primary-900); font-weight: bold; }
.tab.active::after { content: ''; position: absolute; bottom: 0; left: 50%; transform: translateX(-50%); width: 40rpx; height: 6rpx; background: var(--primary-900); border-radius: 4rpx; }

.tab-content { flex: 1; background: #faf9f8; overflow-y: auto; }
.info-section { background: #fff; margin: 24rpx; padding: 32rpx; border-radius: 24rpx; }
.section-title { font-size: 32rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 24rpx; padding-left: 16rpx; border-left: 8rpx solid var(--primary-600); }

.info-list { display: flex; flex-direction: column; gap: 24rpx; }
.info-item { display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx dashed #f1f5f9; padding-bottom: 16rpx; }
.info-label { font-size: 28rpx; color: var(--primary-400); }
.info-value { font-size: 28rpx; color: var(--primary-900); font-weight: 500; }

.follow-section { background: #fff; margin: 24rpx; padding: 32rpx; border-radius: 24rpx; position: relative; }
.follow-item { position: relative; padding-left: 40rpx; margin-bottom: 40rpx; }
.timeline-dot { position: absolute; left: 0; top: 12rpx; width: 16rpx; height: 16rpx; background: var(--primary-600); border-radius: 50%; border: 4rpx solid #eaddd7; }
.follow-item::before { content: ''; position: absolute; left: 10rpx; top: 40rpx; bottom: -40rpx; width: 4rpx; background: #f1f5f9; }
.follow-item:last-child::before { display: none; }

.follow-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx; }
.follow-time { font-size: 24rpx; color: var(--primary-400); font-weight: bold; }
.follow-actions { display: flex; gap: 24rpx; }
.btn-text { font-size: 24rpx; font-weight: bold; }
.btn-text.edit { color: var(--primary-600); }
.btn-text.delete { color: var(--rose-600); }
.follow-content { font-size: 28rpx; color: var(--primary-900); line-height: 1.6; margin-bottom: 16rpx; }
.follow-user { font-size: 24rpx; color: var(--primary-400); }

.bottom-padding { height: calc(160rpx + env(safe-area-inset-bottom)); }

/* 底部按钮 */
.bottom-action-bar { position: fixed; bottom: 0; left: 0; right: 0; padding: 24rpx 40rpx; padding-bottom: calc(24rpx + env(safe-area-inset-bottom)); background: rgba(255,255,255,0.95); backdrop-filter: blur(10px); border-top: 1rpx solid #f1f5f9; z-index: 100; display: flex; gap: 24rpx; box-sizing: border-box; }
.btn-primary { flex: 2; background: var(--primary-900); color: #fff; height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; box-shadow: 0 8rpx 24rpx rgba(74,64,58,0.2); }
.btn-danger { flex: 1; background: var(--rose-50); color: var(--rose-600); height: 88rpx; border-radius: 44rpx; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: bold; border: 2rpx solid var(--rose-100); }
