<wxs module="util">
var getStatusClass = function(status) {
  if (status === '沟通中') return 'status-blue';
  if (status === '已量房') return 'status-indigo';
  if (status === '已交定金') return 'status-pink';
  if (status === '方案阶段') return 'status-purple';
  if (status === '已签单') return 'status-emerald';
  if (status === '已流失') return 'status-zinc';
  return 'status-default';
}
module.exports = { getStatusClass: getStatusClass };
</wxs>
<wxs module="ganttUtil">
  module.exports = {
    getDelayDays: function(actualEndDate, expectedEndDate) {
      if (!actualEndDate || !expectedEndDate) return 0;
      var actual = getDate(actualEndDate.replace(getRegExp('-', 'g'), '/')).getTime();
      var expected = getDate(expectedEndDate.replace(getRegExp('-', 'g'), '/')).getTime();
      if (actual <= expected) return 0;
      return Math.floor((actual - expected) / (1000 * 60 * 60 * 24));
    },
    getOverdueDays: function(expectedEndDate) {
      if (!expectedEndDate) return 0;
      var today = getDate();
      today.setHours(0,0,0,0);
      var expected = getDate(expectedEndDate.replace(getRegExp('-', 'g'), '/'));
      expected.setHours(0,0,0,0);
      var diff = today.getTime() - expected.getTime();
      if (diff <= 0) return 0;
      return Math.floor(diff / (1000 * 60 * 60 * 24));
    },
    getActualDays: function(actualStartDate, actualEndDate) {
      if (!actualStartDate || !actualEndDate) return 0;
      var start = getDate(actualStartDate.replace(getRegExp('-', 'g'), '/')).getTime();
      var end = getDate(actualEndDate.replace(getRegExp('-', 'g'), '/')).getTime();
      return Math.max(1, Math.floor((end - start) / (1000 * 60 * 60 * 24)) + 1);
    },
    formatDateRange: function(start, end) {
      if (!start || !end) return start + ' ~ ' + end;
      var startParts = start.split('-');
      var endParts = end.split('-');
      if (startParts.length !== 3 || endParts.length !== 3) return start + ' ~ ' + end;
      
      if (startParts[0] === endParts[0]) {
        return start + ' ~ ' + endParts[1] + '-' + endParts[2];
      }
      return start + ' ~ ' + end;
    }
  };
</wxs>
<view class="page-container" wx:if="{{lead}}">
  
  <!-- 顶部简要信息卡片 -->
  <view class="top-card">
    <view style="display: flex; justify-content: space-between; align-items: flex-start;">
      <!-- 左侧：姓名、编号、地址等 -->
      <view class="left-info" style="flex: 1; padding-right: 20rpx;">
        <view style="margin-bottom: 12rpx;">
          <customer-info 
            name="{{lead.name}}" 
            phone="{{lead.phone}}" 
            customerNo="{{lead.customerNo || lead._id}}" 
          />
        </view>
        <view class="address" style="font-size: 26rpx; color: #475569; line-height: 1.4; margin-top: 12rpx;">{{lead.address || '暂无地址'}}</view>
      </view>

      <!-- 右侧：评级、状态 (竖排，可点击) -->
      <view class="right-badges" style="display: flex; flex-direction: column; gap: 16rpx; align-items: flex-end; flex-shrink: 0;">
        <block wx:if="{{isAdmin || isRelated}}">
          <picker bindchange="onRatingChange" range="{{['A', 'B', 'C', 'D']}}" value="{{ratingIndex}}">
            <view class="rating-badge rating-{{lead.rating}}" style="display: flex; align-items: center; justify-content: center; gap: 6rpx; padding: 6rpx 20rpx; border-radius: 8rpx; min-width: 160rpx; width: auto; white-space: nowrap; box-sizing: border-box;">
              <text>{{lead.rating}}级</text>
              <text style="font-size: 18rpx; opacity: 0.6; margin-top: 2rpx;">▼</text>
            </view>
          </picker>
          <picker bindchange="onStatusChange" range="{{['待跟进', '沟通中', '已量房', '方案阶段', '已交定金', '已签单', '已流失']}}" value="{{statusIndex}}">
            <view class="status-badge {{util.getStatusClass(lead.status)}}" style="display: flex; align-items: center; justify-content: center; gap: 6rpx; padding: 6rpx 20rpx; border-radius: 8rpx; min-width: 160rpx; width: auto; white-space: nowrap; box-sizing: border-box;">
              <text>{{lead.status}}</text>
              <text style="font-size: 18rpx; opacity: 0.6; margin-top: 2rpx;">▼</text>
            </view>
          </picker>
        </block>
        <block wx:else>
          <view bindtap="showNoPermissionToast">
            <view class="rating-badge rating-{{lead.rating}}" style="display: flex; align-items: center; justify-content: center; gap: 6rpx; padding: 6rpx 20rpx; border-radius: 8rpx; min-width: 160rpx; width: auto; white-space: nowrap; box-sizing: border-box;">
              <text>{{lead.rating}}级</text>
              <text style="font-size: 18rpx; opacity: 0.6; margin-top: 2rpx;">▼</text>
            </view>
          </view>
          <view bindtap="showNoPermissionToast">
            <view class="status-badge {{util.getStatusClass(lead.status)}}" style="display: flex; align-items: center; justify-content: center; gap: 6rpx; padding: 6rpx 20rpx; border-radius: 8rpx; min-width: 160rpx; width: auto; white-space: nowrap; box-sizing: border-box;">
              <text>{{lead.status}}</text>
              <text style="font-size: 18rpx; opacity: 0.6; margin-top: 2rpx;">▼</text>
            </view>
          </view>
        </block>
      </view>
    </view>
    
    <!-- 快捷操作区 (Web风格卡片) -->
    <view class="action-cards mt-4 {{hasProject ? 'three-cards' : 'two-cards'}}">
      <view class="action-card quote-card hover-scale" bindtap="goToQuote">     
        <view class="ac-left">
          <view class="icon-doc"></view>
          <text>{{quoteId ? '查看报价单' : '生成报价单'}}</text>
        </view>
      </view>

      <view class="action-card files-card hover-scale" bindtap="goToProjectFiles">
        <view class="ac-left">
          <view class="icon-folder"></view>
          <text>项目资料</text>
        </view>
      </view>

      <view class="action-card project-card hover-scale" wx:if="{{hasProject}}" bindtap="goToProject">
        <view class="ac-left">
          <view class="icon-hammer"></view>
          <text>工地管理</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 选项卡 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'info' ? 'active' : ''}}" bindtap="switchTab" data-tab="info">详情信息</view>
    <view class="tab {{activeTab === 'design' ? 'active' : ''}}" wx:if="{{isVisible}}" bindtap="switchTab" data-tab="design">设计进度</view>
    <view class="tab {{activeTab === 'follow' ? 'active' : ''}}" wx:if="{{isVisible}}" bindtap="switchTab" data-tab="follow">
      <view style="position: relative; display: inline-block;">
        跟进记录
        <view wx:if="{{hasUnreadFollowUp}}" class="badge-dot" style="top: 0rpx; right: -16rpx;"></view>
      </view>
    </view>
  </view>

  <view class="tab-content" style="padding-bottom: 120rpx;">
    
    <!-- 详情信息 Tab -->
    <view wx:if="{{activeTab === 'info'}}" class="info-section">
      <view class="section-title">客户资料</view>
      <view class="info-list">
        <view class="info-item">
          <text class="info-label">联系电话</text>
          <text class="info-value">{{lead.phone}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">小区地址</text>
          <text class="info-value">{{lead.address}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">需求类型</text>
          <text class="info-value">{{lead.requirementType || lead.requirement || '未填'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">房屋面积</text>
          <text class="info-value">{{lead.area ? lead.area + ' m²' : '未填'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">装修预算</text>
          <text class="info-value">{{lead.budget}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">客户来源</text>
          <text class="info-value">{{lead.source}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">销售</text>
          <text class="info-value">{{lead.sales || '未分配'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">设计师</text>
          <text class="info-value">{{lead.designer || '未分配'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">项目经理</text>
          <text class="info-value">{{lead.manager || '未分配'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">创建时间</text>
          <text class="info-value">{{lead.createdAt}}</text>
        </view>
        <view class="info-item" wx:if="{{lead.status === '已签单'}}">
          <text class="info-label">签单人</text>
          <text class="info-value" style="color: var(--rose-600); font-weight: 500;">{{lead.signer || '-'}}</text>
        </view>
        <view class="info-item" wx:if="{{lead.status === '已签单'}}">
          <text class="info-label">签单时间</text>
          <text class="info-value" style="color: var(--rose-600); font-weight: 500;">{{lead.signDate || '-'}}</text>
        </view>
      </view>
    </view>

    <!-- 设计进度 Tab -->
    <view wx:if="{{activeTab === 'design'}}" class="design-section">
      <view wx:if="{{!lead.designNodes || lead.designNodes.length === 0}}" class="empty-state" style="padding: 80rpx 0; text-align: center;">
        <view style="margin-bottom: 40rpx; color: #64748b; font-size: 26rpx;">暂未开启设计出图进度管理</view>
        <button wx:if="{{isDesigner || isAdmin}}" class="btn-outline-primary hover-scale" style="width: 70%; margin: 0 auto; height: 88rpx; line-height: 88rpx; display: flex; align-items: center; justify-content: center; border-radius: 44rpx; font-size: 32rpx; font-weight: bold; background: #faf8f5; color: var(--primary-900); border: 2rpx solid var(--primary-900); box-shadow: 0 4rpx 12rpx rgba(74,64,58,0.05);" bindtap="openStartDesignModal">开启设计工作流</button>
      </view>
      <view wx:else>
        <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx;">
          <view class="section-title" style="margin-bottom: 0;">出图进度</view>
        </view>
        <!-- 时间轴容器 -->
        <view style="position: relative; width: 100%; box-sizing: border-box;">
          <!-- 垂直线背景 -->
          <view style="position: absolute; left: 26rpx; top: 20rpx; bottom: 20rpx; width: 4rpx; background: #f1f5f9; border-radius: 2rpx; z-index: 0;"></view>
          
          <view class="design-node" wx:for="{{lead.designNodes}}" wx:key="name" style="position: relative; margin-bottom: 40rpx; z-index: 2; width: 100%; box-sizing: border-box; display: flex;">
            
            <!-- 左侧状态图标圈 -->
            <view style="width: 56rpx; flex-shrink: 0; display: flex; justify-content: center; margin-right: 24rpx; padding-top: 8rpx;">
              <view wx:if="{{item.status === 'completed'}}" style="width: 48rpx; height: 48rpx; background: var(--emerald-600); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1); box-sizing: content-box;">
                <text style="color: #fff; font-size: 24rpx; font-weight: bold;">✓</text>
              </view>
              <view wx:elif="{{item.status === 'current'}}" style="width: 48rpx; height: 48rpx; background: var(--amber-600); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid var(--amber-50); box-sizing: content-box;">
                <text style="color: #fff; font-size: 24rpx; font-weight: bold;">•</text>
              </view>
              <view wx:else style="width: 48rpx; height: 48rpx; background: #f1f5f9; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff; box-sizing: content-box;">
                <text style="color: #94a3b8; font-size: 22rpx; font-weight: bold; font-family: monospace;">{{index + 1}}</text>
              </view>
            </view>
            
            <!-- 内容卡片 -->
            <view style="flex: 1; background: {{item.status === 'completed' ? '#f8fafc' : '#fff'}}; border-radius: 16rpx; padding: 24rpx; border: {{item.status === 'current' ? '2rpx solid rgba(245,158,11,0.3)' : '2rpx solid #f1f5f9'}}; box-shadow: {{item.status === 'current' ? '0 8rpx 24rpx rgba(245,158,11,0.12)' : 'none'}}; box-sizing: border-box; display: block; min-width: 0;">
              <view class="node-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12rpx;">
              <view class="node-title" style="font-size: 28rpx; font-weight: bold; color: {{item.status === 'completed' ? '#334155' : '#64748b'}};">
                {{item.name}} 
              </view>
              <view style="display: flex; align-items: center; gap: 12rpx;">
                <!-- 延迟/按时标签 -->
                <block wx:if="{{item.status === 'completed'}}">
                  <view wx:if="{{item.actualEndDate <= item.endDate}}" style="font-size: 20rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">按时完成</view>
                  <view wx:else style="font-size: 20rpx; color: var(--rose-600); background: var(--rose-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">逾期 {{ganttUtil.getDelayDays(item.actualEndDate, item.endDate)}} 天</view>
                </block>
                <block wx:elif="{{item.status === 'current'}}">
                  <view wx:if="{{ganttUtil.getOverdueDays(item.endDate) > 0}}" style="font-size: 20rpx; color: var(--rose-600); background: var(--rose-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">逾期 {{ganttUtil.getOverdueDays(item.endDate)}} 天</view>
                  <view wx:else style="font-size: 20rpx; color: var(--amber-600); background: var(--amber-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold; border: 1rpx solid var(--amber-200);">进行中</view>
                </block>

                <button wx:if="{{item.status === 'current' && (isDesigner || isAdmin)}}" class="btn-complete" bindtap="completeDesignNode" data-index="{{index}}" style="margin: 0; background: #fff; color: var(--primary-900); font-size: 24rpx; padding: 0 24rpx; height: 50rpx; line-height: 46rpx; border-radius: 25rpx; border: 2rpx solid var(--primary-900); box-sizing: border-box; width: fit-content; min-width: 120rpx; flex-shrink: 0; transform: translateX(12rpx);">完成</button>
              </view>
            </view>
            <!-- 预计时间与实际时间显示 -->
            <view style="display: flex; flex-direction: column; gap: 8rpx; font-size: 22rpx; color: #94a3b8;">
              <view style="display: flex; align-items: center; justify-content: space-between;">
                <view style="display: flex; align-items: center;">
                  <view style="width: 70rpx;">计划：</view>
                  <view>{{ganttUtil.formatDateRange(item.startDate, item.endDate)}}</view>
                </view>
                <view style="padding: 2rpx 12rpx; background: #f1f5f9; border-radius: 8rpx; color: #64748b; font-size: 20rpx;">计划 {{item.duration}} 天</view>
              </view>
              <!-- 实际进度与延期原因 -->
              <view wx:if="{{item.status !== 'pending' && item.actualStartDate}}" style="display: flex; flex-direction: column; gap: 8rpx;">
                <view style="display: flex; align-items: center; justify-content: space-between;">
                  <view style="display: flex; align-items: center; color: #64748b;">
                    <view style="width: 70rpx;">实际：</view>
                    <view>{{ganttUtil.formatDateRange(item.actualStartDate, item.actualEndDate || '至今')}}</view>
                  </view>
                  <view wx:if="{{item.status === 'completed'}}" style="padding: 2rpx 12rpx; background: #f1f5f9; border-radius: 8rpx; color: #64748b; font-size: 20rpx;">用时 {{ganttUtil.getActualDays(item.actualStartDate, item.actualEndDate)}} 天</view>
                </view>
                <view wx:if="{{item.status === 'completed' && ganttUtil.getDelayDays(item.actualEndDate, item.endDate) > 0}}" style="margin-top: 12rpx;">
                  <block wx:if="{{item.delayReason}}">
                    <view bindtap="openFillDelayReason" data-index="{{index}}" style="font-size: 24rpx; color: var(--rose-600); line-height: 1.5; word-break: break-all; background: var(--rose-50); padding: 12rpx 16rpx; border-radius: 8rpx; border: 1rpx dashed var(--rose-200); position: relative;">
                      <text style="font-weight: bold;">逾期原因：</text>{{item.delayReason}}
                    </view>
                  </block>
                  <block wx:else>
                    <view style="font-size: 22rpx; color: var(--rose-600);">
                      * 此工序已逾期，请补充填写逾期原因
                      <text catchtap="openFillDelayReason" data-index="{{index}}" style="color: var(--primary-600); margin-left: 12rpx; text-decoration: underline; font-weight: bold;">去填写</text>
                    </view>
                  </block>
                </view>
              </view>
            </view>
          </view>
        </view>
        </view>
      </view>
    </view>

    <!-- 跟进记录 Tab -->
    <view wx:if="{{activeTab === 'follow'}}" class="follow-section">
      <view class="follow-item-wrapper" wx:for="{{followUps}}" wx:key="_id">
        <!-- 时间轴点与线 -->
        <view class="timeline-dot"></view>
        <view class="timeline-line" wx:if="{{index < followUps.length - 1}}"></view>
        
        <!-- 左滑组件 (使用 scroll-view + scroll-snap 实现QQ级完美回弹和高度自适应) -->
        <view class="swipe-container" style="width: calc(100vw - 152rpx); border-radius: 16rpx; overflow: hidden; transform: translateZ(0);">
          <scroll-view class="swipe-area" scroll-x enhanced show-scrollbar="{{false}}" bounces="{{true}}" paging-enabled="{{true}}" fast-deceleration="{{true}}" style="width: 100%; white-space: nowrap; scroll-snap-type: x mandatory;">
            <view class="swipe-view" style="display: inline-flex; min-width: 100%;">
              
              <!-- 表面内容卡片 (滚动对齐点) -->
              <view class="follow-item-card" style="width: calc(100vw - 152rpx); background: #fff; scroll-snap-align: start; flex-shrink: 0; white-space: normal;">
                <view class="follow-header">
                  <view class="follow-time">
                    {{item.displayTime || item.createdAt}}
                    <text wx:if="{{item.editedAt}}" style="margin-left: 12rpx; font-size: 20rpx; color: #94a3b8; background: #f1f5f9; padding: 2rpx 12rpx; border-radius: 8rpx;">已编辑</text>
                  </view>
                </view>
                <view class="follow-content">
                  <text wx:if="{{item.method && item.method !== '系统记录'}}" style="display: inline; font-size: 22rpx; color: var(--primary-900); background: var(--primary-50); padding: 4rpx 16rpx; border-radius: 12rpx; margin-right: 8rpx; font-weight: 500; vertical-align: middle;">{{item.method}}</text>{{item.content}}
                </view>
                <view class="follow-user">记录人: {{item.createdBy}}</view>
              </view>
              
              <view class="swipe-actions" style="width: 280rpx; display: flex; flex-shrink: 0; scroll-snap-align: end;" wx:if="{{isAdmin || item.createdBy === currentUserName}}">
                <view class="swipe-btn edit" catchtap="editFollowUp" data-id="{{item._id}}" style="background: var(--amber-500);">编辑</view>
                <view class="swipe-btn delete" catchtap="deleteFollowUp" data-id="{{item._id}}" style="background: var(--rose-500);">删除</view>
              </view>
              
            </view>
          </scroll-view>
        </view>
      </view>
      
      <view class="empty-state" wx:if="{{followUps.length === 0}}">
        <text>暂无跟进记录</text>
      </view>
    </view>

    <view class="bottom-padding"></view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-action-bar" style="display: flex; gap: 20rpx;" wx:if="{{isVisible}}">
    <view class="btn-primary hover-scale" bindtap="addFollowUp" wx:if="{{activeTab === 'follow'}}" style="flex: 1; text-align: center;">添加跟进</view>
    <view class="btn-primary hover-scale" bindtap="openEditDesignModal" wx:elif="{{activeTab === 'design' && (isDesigner || isAdmin) && lead.designNodes && lead.designNodes.length > 0}}" style="flex: 1; text-align: center;">编辑排期</view>
    <view class="btn-primary hover-scale" bindtap="goToEdit" wx:elif="{{activeTab === 'info' && (isAdmin || isRelated)}}" style="flex: 1; text-align: center;">编辑资料</view>
  </view>

  <!-- 恭喜签单弹窗 -->
  <block wx:if="{{showSignModal}}">
    <view class="modal-mask" style="position: fixed; top: -100rpx; left: 0; right: 0; bottom: -200rpx; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px); z-index: 9998; display: flex; align-items: center; justify-content: center; padding: 40rpx;">
        <view class="sign-modal-content" style="background: #fff; width: 85%; border-radius: 32rpx; padding: 60rpx 40rpx 50rpx; position: relative; box-sizing: border-box; text-align: center; box-shadow: 0 20rpx 40rpx rgba(0,0,0,0.1);">
        
          <!-- 庆祝图标与标题 -->
      <view style="width: 120rpx; height: 120rpx; background: var(--rose-50); border-radius: 60rpx; display: flex; align-items: center; justify-content: center; margin: 0 auto 36rpx; border: 4rpx solid #fff; box-shadow: 0 8rpx 16rpx rgba(153, 41, 51, 0.1);">
        <icon type="success_no_circle" size="40" color="#992933"/>
      </view>
      <view style="font-size: 40rpx; font-weight: bold; color: var(--rose-600); margin-bottom: 12rpx; letter-spacing: 2rpx;">品诺筑家恭喜开单</view>
      <view style="font-size: 26rpx; color: #64748b; margin-bottom: 50rpx;">【{{lead.name}}】项目已成功签单</view>
      
      <!-- 表单内容 -->
      <view style="text-align: left; margin-bottom: 30rpx;">
        <view style="font-size: 26rpx; color: #475569; margin-bottom: 16rpx; font-weight: 500;">签单时间</view>
        <view style="display: flex; gap: 20rpx;">
          <picker mode="date" value="{{signDay}}" bindchange="onSignDayChange" style="flex: 1;">
            <view style="width: 100%; height: 88rpx; line-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155;">
              {{signDay || '日期'}}
            </view>
          </picker>
          <picker mode="time" value="{{signTime}}" bindchange="onSignTimeChange" style="flex: 1;">
            <view style="width: 100%; height: 88rpx; line-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155;">
              {{signTime || '时间'}}
            </view>
          </picker>
        </view>
      </view>

      <view style="text-align: left; margin-bottom: 50rpx;">
        <view style="font-size: 26rpx; color: #475569; margin-bottom: 16rpx; font-weight: 500;">签单人</view>
        <picker bindchange="onSignerChange" value="{{signerIndex}}" range="{{signersList}}">
          <view style="width: 100%; height: 88rpx; min-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155; display: flex; align-items: center; justify-content: space-between;">
            <text>{{signer || '请选择签单人'}}</text>
            <text style="font-size: 20rpx; color: #94a3b8;">▼</text>
          </view>
        </picker>
      </view>
      
      <!-- 按钮 -->
      <view style="display: flex; gap: 24rpx;">
        <button bindtap="closeSignModal" style="flex: 1; font-size: 30rpx; background: #f1f5f9; color: #475569; border-radius: 16rpx; border: none; padding: 24rpx 0; margin: 0; font-weight: 500; line-height: 1;">取消</button>
        <button bindtap="confirmSign" style="flex: 1; font-size: 30rpx; background: var(--rose-600); color: #fff; border-radius: 16rpx; border: none; padding: 24rpx 0; margin: 0; font-weight: bold; line-height: 1; box-shadow: 0 8rpx 20rpx rgba(153, 41, 51, 0.25);">确认签单</button>
      </view>
    </view>
    </view>
  </block>

  <!-- 完成设计节点日期选择弹窗 -->
  <block wx:if="{{showDesignCompleteDateModal}}">
    <view class="modal-mask" bindtap="closeDesignCompleteDateModal" style="position: fixed; top: -100rpx; left: 0; right: 0; bottom: -200rpx; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center;"></view>
    <view class="modal-content" style="position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 85%; background: #fff; border-radius: 32rpx; z-index: 10000; display: flex; flex-direction: column; overflow: hidden; padding: 48rpx;">
      <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; text-align: center; color: #44403c;">确认完成时间</view>
      <view style="font-size: 24rpx; color: #78716c; text-align: center; margin-bottom: 32rpx;">{{lead.designNodes[designCompleteIdx].name}}</view>

      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 26rpx; color: #78716c; margin-bottom: 12rpx;">实际完成日期</view>
        <picker mode="date" value="{{designCompleteDate}}" bindchange="onDesignCompleteDateChange" style="width: 100%; display: block;">
          <view style="width: 100%; height: 88rpx; line-height: 88rpx; padding: 0 24rpx; background: #fafaf9; border-radius: 12rpx; border: 1rpx solid #e7e5e4; font-size: 28rpx; display: flex; justify-content: space-between; align-items: center; box-sizing: border-box; color: #44403c;">
            <text>{{designCompleteDate || '请选择日期'}}</text>
            <text style="color: #a8a29e; font-size: 22rpx;">▼</text>
          </view>
        </picker>
        <view style="font-size: 22rpx; color: #a8a29e; margin-top: 12rpx;">如果昨天或更早完成，可以选择实际完成日期</view>
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeDesignCompleteDateModal" style="flex: 1; font-size: 30rpx; background: #f5f5f4; color: #57534e; border-radius: 16rpx; border: none; padding: 20rpx 0; margin: 0; font-weight: 500; line-height: 1.5;">取消</button>
        <button bindtap="confirmDesignCompleteWithDate" style="flex: 1; font-size: 30rpx; background: var(--primary-900); color: #fff; border-radius: 16rpx; border: none; padding: 20rpx 0; margin: 0; font-weight: bold; line-height: 1.5;">确认完成</button>
      </view>
    </view>
  </block>



  <!-- 逾期完成设计节点弹窗 -->
  <view class="modal-mask" wx:if="{{showDesignCompleteModal}}" style="position: fixed; top: -100rpx; left: 0; right: 0; bottom: -200rpx; background: rgba(0,0,0,0.5); z-index: 9998; display: flex; align-items: center; justify-content: center;">
    <view style="background: #fff; width: 85%; border-radius: 24rpx; padding: 40rpx 32rpx; box-sizing: border-box; position: relative; display: block;">
      <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 8rpx; text-align: center; color: #44403c;">逾期原因</view>
      <view style="font-size: 24rpx; color: #78716c; text-align: center; margin-bottom: 32rpx;">{{lead.designNodes[designCompleteIdx].name}}</view>

      <view style="margin-bottom: 40rpx;">
        <textarea placeholder="请详细说明导致此工序逾期的原因..." bindinput="onDesignDelayReasonInput" value="{{designDelayReason}}" style="width: 100%; height: 150rpx; background: var(--rose-50); padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid var(--rose-200); color: var(--rose-900); display: block; margin: 0;"></textarea>
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeDesignCompleteModal" style="flex: 1; font-size: 30rpx; background: #f5f5f4; color: #57534e; border-radius: 16rpx; border: none; padding: 20rpx 0; margin: 0; font-weight: 500; line-height: 1.5;">稍后填写</button>
        <button bindtap="confirmDesignComplete" style="flex: 1; font-size: 30rpx; background: var(--primary-900); color: #fff; border-radius: 16rpx; border: none; padding: 20rpx 0; margin: 0; font-weight: bold; line-height: 1.5;">保存</button>
      </view>
    </view>
  </view>

  <!-- 开启设计工作流弹窗 -->
  <view class="modal-mask" wx:if="{{showStartDesignModal}}" style="position: fixed; top: -100rpx; left: 0; right: 0; bottom: -200rpx; background: rgba(0,0,0,0.5); z-index: 9998; display: flex; align-items: center; justify-content: center; padding: 40rpx;">
    <view class="modal-content" style="background: #fff; width: 85%; max-height: 80vh; border-radius: 24rpx; padding: 40rpx; box-sizing: border-box; display: flex; flex-direction: column;">
      <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; text-align: center; flex-shrink: 0;">开启设计工作流</view>
      
      <scroll-view scroll-y style="flex: 1; min-height: 0; margin-bottom: 30rpx;">
        <view style="margin-bottom: 30rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">选择设计启动日期</view>
          <picker mode="date" value="{{designStartDate}}" bindchange="onDesignStartDateChange" style="width: 100%; display: block;">
            <view style="width: 100%; padding: 24rpx; background: #f8fafc; border-radius: 12rpx; border: 1rpx solid #e2e8f0; font-size: 28rpx; display: flex; justify-content: space-between; box-sizing: border-box; margin: 0;">
              <text>{{designStartDate || '请选择日期'}}</text>
              <text style="color: #94a3b8; font-size: 22rpx;">▼</text>
            </view>
          </picker>
        </view>

        <view style="margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center;">
          <text style="font-size: 26rpx; color: #64748b;">自定义工序与周期</text>
        </view>
        
        <view class="edit-node-item" wx:for="{{editDesignNodes}}" wx:key="id" 
              style="display: flex; flex-direction: column; margin-bottom: 32rpx; align-items: stretch; gap: 0; width: 100%; box-sizing: border-box; margin-left: 0; margin-right: 0;">
          
          <!-- 第一行：名称 + 删除 -->
          <view style="position: relative; margin-bottom: 16rpx; width: 100%; display: block; box-sizing: border-box;">
            <input class="edit-node-input" value="{{item.name}}" data-index="{{index}}" bindinput="onEditNodeName" placeholder="节点名称" style="width: 100%; font-size: 30rpx; color: #44403c; font-weight: bold; background: #fff; border: 2rpx solid #e2e8f0; height: 72rpx; padding: 0 60rpx 0 24rpx; border-radius: 8rpx; box-sizing: border-box; margin: 0; display: block;" />
            <view bindtap="removeDesignNode" data-index="{{index}}" style="position: absolute; right: 0; top: 0; bottom: 0; width: 60rpx; display: flex; align-items: center; justify-content: center; color: #cbd5e1; font-size: 44rpx; z-index: 10;">×</view>
          </view>
          
          <!-- 第二行：开始时间 + 周期 -->
          <view style="display: flex; align-items: center; justify-content: space-between; width: 100%; box-sizing: border-box; margin: 0;">
            <picker mode="date" value="{{item.startDate}}" data-index="{{index}}" bindchange="onEditNodeStartDate" style="flex: 1; margin-right: 24rpx; display: block; overflow: hidden;">
              <view style="display: flex; align-items: center; font-size: 26rpx; color: #94a3b8;">
                <text style="margin-right: 16rpx;">开始</text>
                <view style="flex: 1; background: #fff; border: 2rpx solid #e2e8f0; border-radius: 8rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; color: #44403c; font-weight: bold;">
                  {{item.startDate || '请选择'}}
                </view>
              </view>
            </picker>
            
            <view style="display: flex; align-items: center; font-size: 26rpx; color: #94a3b8;">
              <view style="background: #fff; border: 2rpx solid #e2e8f0; border-radius: 8rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; width: 100rpx; margin-right: 12rpx;">
                <input class="edit-node-dur" type="number" value="{{item.duration}}" data-index="{{index}}" bindinput="onEditNodeDur" style="width: 100%; text-align: center; color: #44403c; font-weight: bold; height: 100%; min-height: 0;" />
              </view>
              <text>天</text>
            </view>
          </view>
        </view>
        <view bindtap="addDesignNode" style="text-align: center; padding: 20rpx; color: #94a3b8; font-size: 28rpx; font-weight: bold; background: #f8fafc; border-radius: 12rpx; border: 2rpx dashed #e2e8f0; margin-top: 20rpx;">+ 添加新节点</view>
      </scroll-view>

      <view style="display: flex; gap: 20rpx; flex-shrink: 0;">
        <button bindtap="closeStartDesignModal" style="flex: 1; background: #fff; border: 2rpx solid #e2e8f0; color: #64748b; font-size: 30rpx; border-radius: 44rpx; height: 88rpx; line-height: 84rpx; padding: 0; margin: 0;">取消</button>
        <button bindtap="confirmStartDesign" style="flex: 1; background: var(--primary-900); color: #fff; font-size: 30rpx; border-radius: 44rpx; height: 88rpx; line-height: 88rpx; padding: 0; margin: 0;">确认开启</button>
      </view>
    </view>
  </view>

  <!-- 编辑设计排期弹窗 -->
  <view class="modal-mask" wx:if="{{showEditDesignModal}}" style="position: fixed; top: -100rpx; left: 0; right: 0; bottom: -200rpx; background: rgba(0,0,0,0.5); z-index: 9998; display: flex; align-items: center; justify-content: center; padding: 40rpx;">
    <view class="modal-content" style="background: #fff; width: 85%; max-height: 80vh; border-radius: 24rpx; padding: 40rpx; box-sizing: border-box; display: flex; flex-direction: column;">
      <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; text-align: center; flex-shrink: 0;">编辑出图排期</view>
      <scroll-view scroll-y style="flex: 1; min-height: 0; margin-bottom: 30rpx;">
        <view class="edit-node-item" wx:for="{{editDesignNodes}}" wx:key="id" 
              style="display: flex; flex-direction: column; margin-bottom: 32rpx; align-items: stretch; gap: 0; width: 100%; box-sizing: border-box; margin-left: 0; margin-right: 0;">
          
          <!-- 第一行：名称 + 删除 -->
          <view style="position: relative; margin-bottom: 16rpx; width: 100%; display: block; box-sizing: border-box;">
            <input class="edit-node-input" value="{{item.name}}" data-index="{{index}}" bindinput="onEditNodeName" placeholder="节点名称" style="width: 100%; font-size: 30rpx; color: #44403c; font-weight: bold; background: #fff; border: 2rpx solid #e2e8f0; height: 72rpx; padding: 0 60rpx 0 24rpx; border-radius: 8rpx; box-sizing: border-box; margin: 0; display: block;" />
            <view bindtap="removeDesignNode" data-index="{{index}}" style="position: absolute; right: 0; top: 0; bottom: 0; width: 60rpx; display: flex; align-items: center; justify-content: center; color: #cbd5e1; font-size: 44rpx; z-index: 10;">×</view>
          </view>
          
          <!-- 第二行：开始时间 + 周期 -->
          <view style="display: flex; align-items: center; justify-content: space-between; width: 100%; box-sizing: border-box; margin: 0;">
            <picker mode="date" value="{{item.startDate}}" data-index="{{index}}" bindchange="onEditNodeStartDate" style="flex: 1; margin-right: 24rpx; display: block; overflow: hidden;">
              <view style="display: flex; align-items: center; font-size: 26rpx; color: #94a3b8;">
                <text style="margin-right: 16rpx;">开始</text>
                <view style="flex: 1; background: #fff; border: 2rpx solid #e2e8f0; border-radius: 8rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; color: #44403c; font-weight: bold;">
                  {{item.startDate || '请选择'}}
                </view>
              </view>
            </picker>
            
            <view style="display: flex; align-items: center; font-size: 26rpx; color: #94a3b8;">
              <view style="background: #fff; border: 2rpx solid #e2e8f0; border-radius: 8rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; width: 100rpx; margin-right: 12rpx;">
                <input class="edit-node-dur" type="number" value="{{item.duration}}" data-index="{{index}}" bindinput="onEditNodeDur" style="width: 100%; text-align: center; color: #44403c; font-weight: bold; height: 100%; min-height: 0;" />
              </view>
              <text>天</text>
            </view>
          </view>
        </view>
        <view bindtap="addDesignNode" style="text-align: center; padding: 20rpx; color: #94a3b8; font-size: 28rpx; font-weight: bold; background: #f8fafc; border-radius: 12rpx; border: 2rpx dashed #e2e8f0; margin-top: 20rpx;">+ 添加新节点</view>
      </scroll-view>
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeEditDesignModal" style="flex: 1; background: #fff; border: 2rpx solid #e2e8f0; color: #64748b; font-size: 30rpx; border-radius: 44rpx; height: 88rpx; line-height: 84rpx; padding: 0; margin: 0;">取消</button>
        <button bindtap="confirmEditDesign" style="flex: 1; background: var(--primary-900); color: #fff; font-size: 30rpx; border-radius: 44rpx; height: 88rpx; line-height: 88rpx; padding: 0; margin: 0;">保存重算</button>
      </view>
    </view>
  </view>

</view>