<view class="page-container" wx:if="{{lead}}">
  
  <!-- 顶部简要信息卡片 -->
  <view class="top-card">
    <view class="flex justify-between items-center" style="margin-bottom: 12rpx;">
      <view class="flex items-center gap-3">
        <text class="name">{{lead.name}} <text style="font-size:24rpx; color:#666; font-weight:normal; margin-left:8rpx;">{{lead.customerNo || lead._id}}</text></text>
      </view>
    </view>
    <view class="flex items-center gap-3" style="margin-bottom: 20rpx;">
      <view class="rating-badge rating-{{lead.rating}}">{{lead.rating}}级</view>
      <view class="status-badge {{lead.status === '已签单' ? 'status-signed' : 'status-default'}}">{{lead.status}}</view>
    </view>
    <view class="address mt-2">{{lead.address}}</view>
    
    <!-- 快捷操作区 (Web风格卡片) -->
    <view class="action-cards mt-4 {{lead.status === '已签单' ? 'two-cards' : 'one-card'}}">
      <view class="action-card quote-card hover-scale" bindtap="goToQuote">     
        <view class="ac-left">
          <view class="icon-doc"></view>
          <text>{{quoteId ? '查看报价单' : '生成报价单'}}</text>
        </view>
      </view>

      <view class="action-card project-card hover-scale" wx:if="{{lead.status === '已签单'}}" bindtap="goToProject">
        <view class="ac-left">
          <view class="icon-folder"></view>
          <text>工地管理</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 选项卡 -->
  <view class="tabs">
    <view class="tab {{activeTab === 'info' ? 'active' : ''}}" bindtap="switchTab" data-tab="info">详情信息</view>
    <view class="tab {{activeTab === 'follow' ? 'active' : ''}}" bindtap="switchTab" data-tab="follow">跟进记录</view>
  </view>

  <scroll-view scroll-y class="tab-content">
    
    <!-- 详情信息 Tab -->
    <view wx:if="{{activeTab === 'info'}}" class="info-section">
      <view class="section-title" style="display: flex; justify-content: space-between; align-items: center;">
        <text>客户资料</text>
        <view bindtap="goToEdit" style="font-size: 24rpx; color: #10b981; font-weight: normal; display: flex; align-items: center; gap: 4rpx;">
          <text>✎ 编辑资料</text>
        </view>
      </view>
      <view class="info-list">
        <view class="info-item">
          <text class="info-label">联系电话</text>
          <text class="info-value">{{lead.phone}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">小区地址</text>
          <text class="info-value">{{lead.address}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">需求类型</text>
          <text class="info-value">{{lead.requirementType || lead.requirement || '未填'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">房屋面积</text>
          <text class="info-value">{{lead.area ? lead.area + ' m²' : '未填'}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">装修预算</text>
          <text class="info-value">{{lead.budget}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">客户来源</text>
          <text class="info-value">{{lead.source}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">指派销售</text>
          <text class="info-value">{{lead.sales}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">指派设计师</text>
          <text class="info-value">{{lead.designer}}</text>
        </view>
      </view>
    </view>

    <!-- 跟进记录 Tab -->
    <view wx:if="{{activeTab === 'follow'}}" class="follow-section">
      <view class="follow-item" wx:for="{{followUps}}" wx:key="_id">
        <view class="timeline-dot"></view>
        <view class="follow-header">
          <view class="follow-time">{{item.displayTime || item.createdAt}}</view>
          <view class="follow-actions">
            <text class="btn-text edit" bindtap="editFollowUp" data-id="{{item._id}}">编辑</text>
            <text class="btn-text delete" bindtap="deleteFollowUp" data-id="{{item._id}}">删除</text>
          </view>
        </view>
        <view class="follow-content">{{item.content}}</view>
        <view class="follow-user">记录人: {{item.createdBy}}</view>
      </view>
      
      <view class="empty-state" wx:if="{{followUps.length === 0}}">
        <text>暂无跟进记录</text>
      </view>
    </view>

    <view class="bottom-padding"></view>
  </scroll-view>

  <view class="bottom-action-bar">
    <view class="btn-danger hover-scale" bindtap="deleteLead">删除线索</view>
    <view class="btn-primary hover-scale" bindtap="addFollowUp" wx:if="{{activeTab === 'follow'}}">添加跟进</view>
    <view class="btn-primary hover-scale" bindtap="goToEdit" wx:else>编辑资料</view>
  </view>
</view>