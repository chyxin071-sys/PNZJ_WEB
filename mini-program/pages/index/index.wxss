
.page-container { min-height: 100vh; display: flex; flex-direction: column; background: var(--primary-50); box-sizing: border-box; }

/* 顶部数据看板 */
.dashboard { background: #fff; padding: 40rpx 40rpx 20rpx; border-bottom-left-radius: 40rpx; border-bottom-right-radius: 40rpx; box-shadow: 0 10rpx 30rpx rgba(74, 64, 58, 0.04); z-index: 10; flex-shrink: 0; }
.dashboard-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx; }
.dashboard-title { font-size: 36rpx; font-weight: bold; color: var(--primary-900); }
.date-display { font-size: 26rpx; color: var(--primary-400); font-weight: 500; }

/* 时间筛选器等样�?*/
.title-wrap { display: flex; flex-direction: column; gap: 8rpx; }
.date-text { font-size: 24rpx; color: var(--primary-400); font-weight: normal; }

.actions { display: flex; align-items: center; gap: 16rpx; }
.btn-add { background: var(--primary-900); color: #fff; padding: 12rpx 24rpx; border-radius: 40rpx; font-size: 24rpx; font-weight: 500; display: flex; align-items: center; gap: 6rpx; }
.date-filter-box { display: flex; align-items: center; gap: 8rpx; padding: 10rpx 24rpx; background: #f8fafc; border-radius: 40rpx; border: 1rpx solid transparent; font-size: 24rpx; color: var(--primary-600); font-weight: 500; }
.date-filter-box .arrow-down { width: 0; height: 0; border-left: 8rpx solid transparent; border-right: 8rpx solid transparent; border-top: 8rpx solid var(--primary-400); margin-top: 4rpx; }


/* 新版 Web 风格数据卡片 */
.dashboard-cards { display: flex; gap: 16rpx; }
.stat-card { flex: 1; background: #fff; border: 2rpx solid #f1f5f9; border-radius: 20rpx; padding: 24rpx 20rpx; display: flex; align-items: center; gap: 16rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); transition: all 0.2s; }
.stat-card.active-card { border-color: var(--primary-400); box-shadow: 0 8rpx 24rpx rgba(74, 64, 58, 0.08); background: var(--primary-50); }

/* 卡片内图�?*/
.icon-box { width: 44rpx; height: 44rpx; border-radius: 10rpx; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.bg-orange-50 { background: #fffbeb; }
.bg-emerald-50 { background: var(--emerald-50); }

/* �?CSS 绘制的精致时钟图�?*/
.icon-clock { width: 18rpx; height: 18rpx; border: 3rpx solid var(--amber-600); border-radius: 50%; position: relative; }
.icon-clock::before { content: ''; position: absolute; top: 2rpx; left: 6rpx; width: 3rpx; height: 6rpx; background: var(--amber-600); border-radius: 2rpx; }
.icon-clock::after { content: ''; position: absolute; top: 6rpx; left: 6rpx; width: 6rpx; height: 3rpx; background: var(--amber-600); border-radius: 2rpx; }

/* �?CSS 绘制的精致大勾图�?*/
.icon-check { width: 8rpx; height: 14rpx; border: 3rpx solid var(--emerald-600); border-top: none; border-left: none; transform: rotate(45deg); margin-top: -2rpx; }

.stat-info { display: flex; flex-direction: column; justify-content: center; flex: 1; }
.stat-label { font-size: 24rpx; color: var(--primary-600); margin-bottom: 2rpx; white-space: nowrap; }
.stat-num { font-size: 40rpx; font-weight: 800; color: var(--primary-900); line-height: 1.1; }

/* 操作�?(搜索+新建) */
.action-bar { display: flex; gap: 20rpx; padding: 32rpx 32rpx 10rpx; flex-shrink: 0; align-items: center; }
.search-wrap { flex: 1; background: #fff; border-radius: 20rpx; display: flex; align-items: center; padding: 0 24rpx; height: 80rpx; box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02); border: 1rpx solid transparent; transition: border-color 0.2s; }
.search-wrap:focus-within { border-color: var(--primary-200); }
.search-wrap input { flex: 1; margin-left: 16rpx; font-size: 28rpx; color: var(--primary-900); }
.ph { color: var(--primary-400); }

/* 筛选按钮样式已移至全局 app.wxss */

.btn-create-small { background: var(--primary-900); color: #fff; border-radius: 20rpx; height: 80rpx; padding: 0 32rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold; box-shadow: 0 6rpx 16rpx rgba(74, 64, 58, 0.2); transition: all 0.15s; flex-shrink: 0; }
.btn-create-hover { background: #3d342f !important; transform: scale(0.96); opacity: 0.95; }
.plus-icon { position: relative; width: 20rpx; height: 20rpx; margin-right: 12rpx; }
.plus-icon::before, .plus-icon::after { content: ''; position: absolute; background: #fff; border-radius: 2rpx; }
.plus-icon::before { top: 8rpx; left: 0; width: 20rpx; height: 4rpx; }
.plus-icon::after { top: 0; left: 8rpx; width: 4rpx; height: 20rpx; }

/* 列表�?*/
.list-container { flex: 1; padding: 20rpx 32rpx; width: 100%; box-sizing: border-box; }

.icon-sort { width: 36rpx; height: 32rpx; display: flex; flex-direction: column; justify-content: space-between; align-items: center; }
.icon-sort::before { content: ''; width: 36rpx; height: 4rpx; background: var(--primary-900); border-radius: 2rpx; }
.icon-sort .line-mid { width: 36rpx; height: 4rpx; background: var(--primary-900); border-radius: 2rpx; }
.icon-sort::after { content: ''; width: 36rpx; height: 4rpx; background: var(--primary-900); border-radius: 2rpx; }

.group-title { padding: 30rpx 0 20rpx; font-size: 28rpx; font-weight: bold; color: var(--primary-600); display: flex; align-items: center; gap: 12rpx; }
.group-count { background: var(--primary-100); color: var(--primary-600); font-size: 22rpx; padding: 2rpx 12rpx; border-radius: 20rpx; }

/* 卡片 */
/* 修复被裁切问题：增加 box-sizing: border-box 并控�?width */
.todo-card { background: #fff; border-radius: 24rpx; padding: 36rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03); transition: opacity 0.3s; width: 100%; box-sizing: border-box; border: 1rpx solid rgba(0,0,0,0.02); }
.opacity-60 { opacity: 0.5; }

/* 头部与新 Checkbox */
.card-header { display: flex; align-items: flex-start; margin-bottom: 16rpx; gap: 20rpx; }
/* 方形带微圆角的复选框，更具现代感 */
.checkbox { width: 44rpx; height: 44rpx; border-radius: 12rpx; border: 3rpx solid #cbd5e1; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: all 0.2s; background: #f8fafc; margin-top: 4rpx; }
.checkbox.checked { background: var(--primary-900); border-color: var(--primary-900); }
/* �?CSS 绘制的优雅对�?*/
.checkmark { width: 12rpx; height: 22rpx; border: 4rpx solid #fff; border-top: none; border-left: none; transform: rotate(45deg); margin-top: -4rpx; }

.title-wrap { flex: 1; display: flex; flex-direction: column; }
.title { font-size: 30rpx; font-weight: bold; line-height: 1.4; color: var(--primary-900); word-break: break-all; }
.line-through { text-decoration: line-through; color: var(--primary-400); }

/* 标题下方：优先级与日期并排的圆角�?*/
.meta-tags-row { display: flex; align-items: center; gap: 16rpx; flex-wrap: wrap; margin-top: 12rpx; }
.priority-badge-high { background: var(--rose-50); color: var(--rose-600); border: 1rpx solid var(--rose-100); }
.priority-badge-medium { background: #fffbeb; color: var(--amber-600); border: 1rpx solid var(--amber-100); }
.priority-badge-low { background: var(--emerald-50); color: var(--emerald-600); border: 1rpx solid var(--emerald-100); }
.priority-dot { width: 10rpx; height: 10rpx; border-radius: 50%; margin-right: 10rpx; flex-shrink: 0; }
.priority-bg-high { background: var(--rose-600); }
.priority-bg-medium { background: var(--amber-600); }
.priority-bg-low { background: var(--emerald-600); }

/* 主体内容 */
.card-body { padding-left: 64rpx; margin-bottom: 24rpx; }

.desc { font-size: 26rpx; color: var(--primary-600); line-height: 1.6; display: block; margin-bottom: 20rpx; }

/* 附件小标�?*/
.attachments { display: flex; flex-wrap: wrap; gap: 16rpx; }
.att-pill { display: flex; align-items: center; background: #f1f5f9; padding: 8rpx 20rpx; border-radius: 12rpx; font-size: 24rpx; color: #475569; max-width: 100%; }
.icon-clip { width: 8rpx; height: 16rpx; border: 3rpx solid #94a3b8; border-top: none; border-radius: 0 0 6rpx 6rpx; margin-right: 12rpx; position: relative; }
.icon-clip::before { content: ''; position: absolute; top: -6rpx; left: 1rpx; width: 6rpx; height: 10rpx; border: 3rpx solid #94a3b8; border-bottom: none; border-radius: 4rpx 4rpx 0 0; }

/* 底部区域 (对齐 Web 细节) */
.card-footer { padding-left: 64rpx; border-top: 1rpx solid #f1f5f9; padding-top: 24rpx; display: flex; flex-direction: column; align-items: flex-start; gap: 16rpx; }

.meta-stack { width: 100%; }

.meta-badge { display: inline-flex; align-items: center; padding: 8rpx 20rpx; border-radius: 12rpx; font-size: 26rpx; font-weight: 500; max-width: 100%; }
.meta-related { background: #f5f5f5; color: #1f2937; }
/* 截止日期颜色 */
.meta-date { color: var(--primary-600); background: #f8fafc; border-color: #e2e8f0; }
.meta-date.date-today { color: var(--amber-600); background: #fffbeb; border-color: var(--amber-100); }
.meta-date.date-today .icon-calendar::before { background: var(--amber-600); box-shadow: 12rpx 0 0 var(--amber-600); }
.meta-date.date-today .icon-calendar::after { background: var(--amber-600); }
.meta-date.date-today .icon-calendar { border-color: var(--amber-600); }

.meta-date.date-future { color: var(--emerald-600); background: var(--emerald-50); border-color: var(--emerald-100); }
.meta-date.date-future .icon-calendar::before { background: var(--emerald-600); box-shadow: 12rpx 0 0 var(--emerald-600); }
.meta-date.date-future .icon-calendar::after { background: var(--emerald-600); }
.meta-date.date-future .icon-calendar { border-color: var(--emerald-600); }

.meta-date.date-overdue { color: var(--rose-600); background: var(--rose-50); border-color: var(--rose-100); }
.meta-date.date-overdue .icon-calendar::before { background: var(--rose-600); box-shadow: 12rpx 0 0 var(--rose-600); }
.meta-date.date-overdue .icon-calendar::after { background: var(--rose-600); }
.meta-date.date-overdue .icon-calendar { border-color: var(--rose-600); }

.meta-completed-date { background: #f8fafc; color: var(--primary-600); border-color: #e2e8f0; }

/* �?CSS 绘制靶心图标 (关联对象) */
.icon-target { width: 22rpx; height: 22rpx; border: 3rpx solid currentColor; border-radius: 50%; position: relative; margin-right: 10rpx; flex-shrink: 0; }
.icon-target::after { content: ''; position: absolute; width: 6rpx; height: 6rpx; background: currentColor; border-radius: 50%; top: 50%; left: 50%; transform: translate(-50%, -50%); }

/* �?CSS 绘制日历图标 (截止日期) */
.icon-calendar { width: 22rpx; height: 20rpx; border: 3rpx solid currentColor; border-radius: 4rpx; position: relative; margin-right: 10rpx; margin-top: 4rpx; flex-shrink: 0; }
.icon-calendar::before { content: ''; position: absolute; top: -6rpx; left: 4rpx; width: 4rpx; height: 6rpx; background: currentColor; border-radius: 2rpx; box-shadow: 10rpx 0 0 currentColor; }
.icon-calendar::after { content: ''; position: absolute; top: 4rpx; left: 0; right: 0; border-top: 3rpx solid currentColor; }

/* �?CSS 绘制完成图标 (已完成时�? */
.icon-check-circle { width: 22rpx; height: 22rpx; border: 3rpx solid currentColor; border-radius: 50%; position: relative; margin-right: 10rpx; flex-shrink: 0; }
.icon-check-circle::after { content: ''; position: absolute; top: 2rpx; left: 6rpx; width: 6rpx; height: 12rpx; border: 3rpx solid currentColor; border-top: none; border-left: none; transform: rotate(45deg); }

/* 执行人与派发人信�?*/
.meta-assignee { display: flex; align-items: center; font-size: 26rpx; color: #4b5563; padding-left: 8rpx; margin-top: 4rpx; }

/* �?CSS 绘制用户图标 (人员) */
.icon-user { width: 12rpx; height: 12rpx; border: 3rpx solid currentColor; border-radius: 50%; position: relative; margin-right: 16rpx; flex-shrink: 0; margin-bottom: 8rpx; }
.icon-user::after { content: ''; position: absolute; top: 14rpx; left: 50%; transform: translateX(-50%); width: 20rpx; height: 10rpx; border: 3rpx solid currentColor; border-bottom: none; border-radius: 10rpx 10rpx 0 0; }

.mt-3 { margin-top: 20rpx; }
.flex { display: flex; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }

/* 角色标签：去除了边框，背景更柔和，文字颜色更深，与优先级明显区分 */
.role-badge { padding: 6rpx 20rpx; border-radius: 10rpx; font-size: 22rpx; font-weight: bold; }
.role-sales { background: #e0f2fe; color: #1e40af; }
.role-designer { background: #fce7f3; color: #9d174d; }
.role-manager { background: var(--emerald-100); color: #065f46; }
.role-admin { background: #f3e8ff; color: #6b21a8; }
.role-undefined { background: #f3f4f6; color: #4b5563; }

/* 空状�?*/
.empty-state { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 160rpx 0; color: var(--primary-400); font-size: 28rpx; }
.empty-icon { width: 100rpx; height: 100rpx; background: #f1f5f9; border-radius: 30rpx; margin-bottom: 32rpx; position: relative; }
.empty-icon::after { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 40rpx; height: 6rpx; background: #cbd5e1; border-radius: 6rpx; }

/* 点击动效 */
.card-hover { transform: scale(0.98); opacity: 0.9; }
.hover-scale { transition: transform 0.15s cubic-bezier(0.4, 0, 0.2, 1); }
.hover-scale:active { transform: scale(0.95); }

.modal-content { position: fixed; top: 45%; left: 50%; transform: translate(-50%, -50%); width: 90%; height: 65vh; background: #fff; border-radius: 24rpx; z-index: 1000; overflow: hidden; display: flex; flex-direction: column; }
.modal-header { padding: 32rpx 40rpx; border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center; font-size: 32rpx; font-weight: bold; color: var(--primary-900); flex-shrink: 0; }
.btn-close { font-size: 28rpx; color: #94a3b8; font-weight: normal; padding: 10rpx; margin: -10rpx; }
.modal-scroll { flex: 1; height: 100%; }
.modal-body { padding: 40rpx; padding-bottom: 120rpx; }
.btn-save { background: var(--primary-900); color: #fff; text-align: center; padding: 24rpx 0; border-radius: 16rpx; font-size: 32rpx; font-weight: bold; margin-top: 20rpx; }
.form-group { margin-bottom: 32rpx; }
.label { display: block; font-size: 28rpx; font-weight: bold; color: var(--primary-900); margin-bottom: 16rpx; }
.input, .picker-view { background: #f8fafc; border-radius: 16rpx; padding: 0 24rpx; height: 88rpx; border: 2rpx solid #e2e8f0; font-size: 30rpx; color: var(--primary-900); display: flex; align-items: center; justify-content: space-between; width: 100%; box-sizing: border-box; }
.arrow-down { width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; border-top: 10rpx solid #94a3b8; }

/* 标签选择样式补充 (执行人、状态等) */
.tags-wrap { display: flex; flex-wrap: wrap; gap: 20rpx; }
.tag { padding: 12rpx 32rpx; border-radius: 40rpx; font-size: 26rpx; background: #f8fafc; color: var(--primary-600); border: 2rpx solid transparent; transition: all 0.2s; }
.tag.active { background: var(--rose-50); color: var(--rose-600); border-color: var(--rose-500); }

/* 模拟下拉多选面�?*/
.form-group { position: relative; }
.text-placeholder { color: #94a3b8; }
.text-primary { color: var(--primary-900); }
.dropdown-panel { position: absolute; bottom: 110rpx; top: auto; left: 0; right: 0; background: #fff; border-radius: 16rpx; box-shadow: 0 10rpx 40rpx rgba(0,0,0,0.15); border: 1rpx solid #e2e8f0; z-index: 100; overflow: hidden; }
.dropdown-dept-title { padding: 16rpx 32rpx; font-size: 26rpx; color: var(--primary-900); background: #f8fafc; font-weight: bold; display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f1f5f9; }
.dropdown-item { padding: 24rpx 32rpx; display: flex; justify-content: space-between; align-items: center; border-bottom: 1rpx solid #f1f5f9; font-size: 28rpx; color: var(--primary-900); }
.dropdown-item:active { background: #f8fafc; }
.dropdown-item:last-child { border-bottom: none; }
.dropdown-footer { padding: 24rpx; text-align: center; color: var(--primary-900); font-weight: bold; border-top: 1rpx solid #e2e8f0; background: #f8fafc; }
.dept-title { font-size: 26rpx; color: var(--primary-900); margin: 24rpx 0 12rpx; font-weight: bold; padding: 16rpx 24rpx; background: #f8fafc; border-radius: 12rpx; display: flex; justify-content: space-between; align-items: center; }
.dept-employees { padding: 0 12rpx; }
.arrow { width: 0; height: 0; border-left: 10rpx solid transparent; border-right: 10rpx solid transparent; }
.arrow.down { border-top: 10rpx solid #94a3b8; border-bottom: none; }
.arrow.up { border-bottom: 10rpx solid #94a3b8; border-top: none; }


