<view class="page-container">

  
  <!-- 顶部概览 -->
  <view class="dashboard">
    <view class="dashboard-header">
      <view class="title-wrap">
        <text class="dashboard-title">团队待办</text>
        <text class="date-text">{{today}}</text>
      </view>
      <view class="actions">
        <picker mode="selector" range="{{timeFilterOptions}}" value="{{timeFilterIndex}}" bindchange="onTimeFilterChange">
          <view class="date-filter-box">
            <text>{{timeFilterLabel}}</text>
          </view>
        </picker>
      </view>
    </view>
    <view class="dashboard-cards">
      <!-- 待处理卡片 -->
      <view class="stat-card {{activeTab === 'pending' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="pending">
        <view class="icon-box bg-orange-50">
          <view class="icon-clock"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">待处理</text>
          <text class="stat-num">{{pendingCount}}</text>
        </view>
      </view>
      <!-- 已完成卡片 -->
      <view class="stat-card {{activeTab === 'completed' ? 'active-card' : ''}}" bindtap="switchTab" data-tab="completed">
        <view class="icon-box bg-emerald-50">
          <view class="icon-check"></view>
        </view>
        <view class="stat-info">
          <text class="stat-label">已完成</text>
          <text class="stat-num">{{completedCount}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 新建按钮 & 搜索过滤 (固定在看板下方) -->
  <view class="action-bar">
    <view class="search-wrap">
      <icon type="search" size="16" color="#b5a49a" />
      <input placeholder="搜索待办..." placeholder-class="ph" bindinput="onSearch" />
    </view>
    <!-- 排序/分组图标 -->
    <view class="btn-filter hover-scale" bindtap="openGroupActionSheet" style="margin-right: -10rpx;">
      <view class="icon-sort">
        <view class="line-mid"></view>
      </view>
      <view class="filter-badge" wx:if="{{groupType !== 'none'}}"></view>
    </view>
    <!-- 人员高级筛选器 (三横线图标) -->
    <view class="btn-filter hover-scale" bindtap="openAdvancedFilter">
      <view class="icon-filter">
        <view class="line-mid"></view>
      </view>
      <view class="filter-badge" wx:if="{{selectedEmployeeIds.length > 0}}"></view>
    </view>
    <view class="btn-create-small" hover-class="btn-create-hover" bindtap="createTodo">
      <view class="plus-icon"></view>
      <text>新建</text>
    </view>
  </view>

  <!-- 待办列表区 -->
  <view class="list-container">
    <block wx:if="{{groupType === 'none'}}">
      <view class="todo-card {{item.status === 'completed' ? 'opacity-60' : ''}}" hover-class="card-hover" hover-stay-time="100" wx:for="{{todos}}" wx:key="_id" bindtap="onTodoTap" data-id="{{item._id}}">
        
        <!-- 头部：标题与打勾 -->
        <view class="card-header" style="align-items: flex-start;">
          <view class="checkbox {{item.status === 'completed' ? 'checked' : ''}}" catchtap="toggleTodo" data-id="{{item._id}}" style="margin-top: 6rpx;">
            <view wx:if="{{item.status === 'completed'}}" class="checkmark"></view>
          </view>
          <view class="title-wrap" style="flex: 1; min-width: 0;">
            <view style="display: flex; justify-content: space-between; align-items: flex-start;">
              <text class="title {{item.status === 'completed' ? 'line-through' : ''}}" style="flex: 1; padding-right: 16rpx;">{{item.title}}</text>
              <view class="meta-badge priority-badge-{{item.priority}}" style="margin-bottom: 0; flex-shrink: 0;">
                <view class="priority-dot priority-bg-{{item.priority}}"></view>  
                <text>{{item.priorityText}}</text>
              </view>
            </view>
            
            <!-- 标题下方：关联对象自适应宽度展示 -->
            <view class="meta-tags-row mt-1" wx:if="{{item.relatedTo && item.relatedTo.type !== 'none'}}" catchtap="goToRelated" data-type="{{item.relatedTo.type}}" data-id="{{item.relatedTo.id}}" style="margin-top: 12rpx;">
              <view class="meta-badge meta-related" style="margin-bottom: 0; padding: 6rpx 16rpx; background: #f8fafc; border: 1rpx solid #e2e8f0; border-radius: 12rpx; color: var(--primary-700); display: inline-flex; align-items: center; max-width: 100%; width: fit-content; box-sizing: border-box;">
                <view class="icon-target" style="margin-bottom: 0; width: 18rpx; height: 18rpx; border-width: 2rpx; margin-right: 8rpx; flex-shrink: 0;"></view>
                <text style="font-size: 24rpx; font-weight: normal; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{item.relatedTo.type === 'project' ? '工地' : '客户'}}: {{item.relatedTo.name}}</text>
              </view>
            </view>
          </view>
        </view>

        <!-- 主体：描述、附件 -->
        <view class="card-body">
          <text class="desc" wx:if="{{item.description}}">{{item.description}}</text>
          
          <view class="attachments" wx:if="{{item.attachments && item.attachments.length > 0}}">
            <view class="att-pill" wx:for="{{item.attachments}}" wx:key="name" wx:for-item="att">
              <view class="icon-clip"></view>
              <text>{{att.name}}</text>
            </view>
          </view>
        </view>

        <!-- 底部：执行人、日期 -->
        <view class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f1f5f9; padding-left: 64rpx; overflow: hidden;">
          <!-- 执行人多选展示 -->
            <view class="meta-assignee" style="display: flex; align-items: center; flex: 1; min-width: 0; padding-left: 0; margin-bottom: 0; height: 32rpx;">
              <view style="display: flex; justify-content: center; align-items: center; width: 32rpx; height: 32rpx; margin-right: 4rpx; flex-shrink: 0;">
                <view class="icon-user" style="transform: scale(0.9) translateY(-6rpx); margin: 0;"></view>
              </view>
              <text style="display: flex; align-items: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 26rpx; line-height: 32rpx; height: 32rpx; color: var(--primary-700); min-width: 0; flex: 1;">{{item.assignedNames}}</text>
            </view>

          <!-- 日期展示 (右对齐) -->
          <view class="meta-badge meta-date date-{{item.dueStatus}}" style="margin-bottom: 0; flex-shrink: 0;" wx:if="{{item.dueDate && item.status !== 'completed'}}">
            <view class="icon-calendar"></view>
            <text>{{item.displayDueDate}} 截止</text>
          </view>
          <view class="meta-badge meta-completed-date" style="margin-bottom: 0; flex-shrink: 0;" wx:if="{{item.status === 'completed' && item.completedAt}}">
            <view class="icon-check-circle"></view>
            <text>{{item.completedAt}} 完成</text>
          </view>
        </view>

      </view>
    </block>

    <!-- 分组模式 -->
    <block wx:else>
      <block wx:for="{{groupedTodos}}" wx:key="title" wx:for-item="group">
        <!-- 分组标题 -->
        <view class="group-title">
          <text>{{group.title}}</text>
          <text class="group-count">{{group.items.length}}</text>
        </view>

        <!-- 分组内的卡片 -->
        <view class="todo-card {{item.status === 'completed' ? 'opacity-60' : ''}}" hover-class="card-hover" hover-stay-time="100" wx:for="{{group.items}}" wx:key="_id" bindtap="onTodoTap" data-id="{{item._id}}">
          <!-- 卡片内容同上 -->
          <view class="card-header" style="align-items: flex-start;">
            <view class="checkbox {{item.status === 'completed' ? 'checked' : ''}}" catchtap="toggleTodo" data-id="{{item._id}}" style="margin-top: 6rpx;">
              <view wx:if="{{item.status === 'completed'}}" class="checkmark"></view>
            </view>
            <view class="title-wrap" style="flex: 1; min-width: 0;">
              <view style="display: flex; justify-content: space-between; align-items: flex-start;">
                <text class="title {{item.status === 'completed' ? 'line-through' : ''}}" style="flex: 1; padding-right: 16rpx;">{{item.title}}</text>
                <view class="meta-badge priority-badge-{{item.priority}}" style="margin-bottom: 0; flex-shrink: 0;">
                  <view class="priority-dot priority-bg-{{item.priority}}"></view>  
                  <text>{{item.priorityText}}</text>
                </view>
              </view>
              
              <!-- 标题下方：关联对象自适应宽度展示 -->
              <view class="meta-tags-row mt-1" wx:if="{{item.relatedTo && item.relatedTo.type !== 'none'}}" catchtap="goToRelated" data-type="{{item.relatedTo.type}}" data-id="{{item.relatedTo.id}}" style="margin-top: 12rpx;">
                <view class="meta-badge meta-related" style="margin-bottom: 0; padding: 6rpx 16rpx; background: #f8fafc; border: 1rpx solid #e2e8f0; border-radius: 12rpx; color: var(--primary-700); display: inline-flex; align-items: center; max-width: 100%; width: fit-content; box-sizing: border-box;">
                  <view class="icon-target" style="margin-bottom: 0; width: 18rpx; height: 18rpx; border-width: 2rpx; margin-right: 8rpx; flex-shrink: 0;"></view>
                  <text style="font-size: 24rpx; font-weight: normal; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{item.relatedTo.type === 'project' ? '工地' : '客户'}}: {{item.relatedTo.name}}</text>
                </view>
              </view>
            </view>
          </view>
          <view class="card-body">
            <text class="desc" wx:if="{{item.description}}">{{item.description}}</text>
            <view class="attachments" wx:if="{{item.attachments && item.attachments.length > 0}}">
              <view class="att-pill" wx:for="{{item.attachments}}" wx:key="name" wx:for-item="att">
                <view class="icon-clip"></view>
                <text>{{att.name}}</text>
              </view>
            </view>
          </view>
          <!-- 底部：执行人、日期 -->
          <view class="card-footer" style="display: flex; justify-content: space-between; align-items: center; margin-top: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f1f5f9; padding-left: 64rpx; overflow: hidden;">
            <!-- 执行人多选展示 -->
            <view class="meta-assignee" style="display: flex; align-items: center; flex: 1; min-width: 0; padding-left: 0; margin-bottom: 0; height: 32rpx;">
              <view style="display: flex; justify-content: center; align-items: center; width: 32rpx; height: 32rpx; margin-right: 4rpx; flex-shrink: 0;">
                <view class="icon-user" style="transform: scale(0.9) translateY(-6rpx); margin: 0;"></view>
              </view>
              <text style="display: flex; align-items: center; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 26rpx; line-height: 32rpx; height: 32rpx; color: var(--primary-700); min-width: 0; flex: 1;">{{item.assignedNames}}</text>
            </view>
            <!-- 日期展示 (右对齐) -->
            <view class="meta-badge meta-date date-{{item.dueStatus}}" style="margin-bottom: 0; flex-shrink: 0;" wx:if="{{item.dueDate && item.status !== 'completed'}}">
              <view class="icon-calendar"></view>
              <text>{{item.displayDueDate}} 截止</text>
            </view>
            <view class="meta-badge meta-completed-date" style="margin-bottom: 0; flex-shrink: 0;" wx:if="{{item.status === 'completed' && item.completedAt}}">
              <view class="icon-check-circle"></view>
              <text>{{item.completedAt}} 完成</text>
            </view>
          </view>
        </view>
      </block>
    </block>
    
    <view class="empty-state" wx:if="{{todos.length === 0}}">
      <view class="empty-icon"></view>
      <text>暂无相关待办</text>
    </view>
    
    <view class="pb-tabbar"></view>
  </view>

  <!-- 高级人员筛选弹窗 -->
  <block wx:if="{{showFilterModal}}">
    <view class="modal-mask" bindtap="closeFilterModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text>待办高级筛选</text>
        <view class="btn-close" bindtap="applyFilter">确定</view>
      </view>
      <scroll-view scroll-y class="modal-list" style="height: 60vh;">
      <!-- 与我相关 / 全部 (所有人可见) -->
      <view class="filter-section">
        <view class="filter-title">范围</view>
        <view class="filter-tags">
          <view class="filter-tag {{filterScope === 'related' ? 'active' : ''}}" bindtap="switchFilterScope" data-scope="related">与我相关</view>
          <view class="filter-tag {{filterScope === 'all' ? 'active' : ''}}" bindtap="switchFilterScope" data-scope="all">全部待办</view>
        </view>
      </view>

      <!-- 优先级 (所有人可见) -->
      <view class="filter-section">
        <view class="filter-title">优先级</view>
        <view class="filter-tags">
          <view class="filter-tag {{filterPriority === 'all' ? 'active' : ''}}" bindtap="switchFilterPriority" data-priority="all">全部</view>
          <view class="filter-tag {{filterPriority === 'high' ? 'active' : ''}}" bindtap="switchFilterPriority" data-priority="high">紧急</view>
          <view class="filter-tag {{filterPriority === 'medium' ? 'active' : ''}}" bindtap="switchFilterPriority" data-priority="medium">重要</view>
          <view class="filter-tag {{filterPriority === 'low' ? 'active' : ''}}" bindtap="switchFilterPriority" data-priority="low">普通</view>
        </view>
      </view>

      <!-- 关联客户 (所有人可见) -->
      <view class="filter-section">
        <view class="filter-title">关联客户</view>
        <picker mode="selector" range="{{availableLeadNames}}" bindchange="onFilterLeadChange">
          <view class="filter-tag active" style="width: auto; padding: 10rpx 20rpx; border-radius: 8rpx; background: #faf9f8; color: #5c4f48; border: 1rpx solid #e6dfda;">
            {{filterRelatedLeadName || '全部客户 (点击选择)'}}
          </view>
        </picker>
      </view>

      <!-- 人员选择 (所有人可见) -->
      <view class="filter-section">
        <view class="filter-title">执行人员</view>
        <block wx:for="{{groupedEmployees}}" wx:key="dept">
          <view class="dept-title" bindtap="toggleDept" data-dept="{{item.dept}}">
            <text>{{item.dept}}</text>
            <view class="arrow {{item.expanded ? 'up' : 'down'}}"></view>
          </view>
          <view class="dept-employees" wx:if="{{item.expanded}}">
            <view class="employee-item" wx:for="{{item.employees}}" wx:for-item="emp" wx:key="id" bindtap="toggleFilterEmployee" data-id="{{emp.id}}">
              <view class="checkbox {{emp.selected ? 'checked' : ''}}">
                <view wx:if="{{emp.selected}}" class="checkmark"></view>
              </view>
              <text class="emp-name">{{emp.name}}</text>
            </view>
          </view>
        </block>
      </view>
      </scroll-view>
    </view>
  </block>

  <!-- 新建待办弹窗 -->
  <block wx:if="{{showAddModal}}">
    <view class="modal-mask" bindtap="closeAddModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text>新建待办</text>
        <view class="btn-close" bindtap="closeAddModal">取消</view>
      </view>
      <scroll-view scroll-y class="modal-scroll">
        <view class="modal-body">
          <view class="form-group">
            <text class="label">任务标题 <text style="color:red">*</text></text>
            <input class="input" placeholder="请输入待办标题" value="{{newTodo.title}}" bindinput="onNewTodoInput" data-field="title" />
          </view>
          <view class="form-group">
            <text class="label">详细描述</text>
            <input class="input" placeholder="选填，任务的具体要求" value="{{newTodo.description}}" bindinput="onNewTodoInput" data-field="description" />
          </view>
          <view class="form-group">
            <text class="label">优先级</text>
            <picker bindchange="onNewTodoPickerChange" data-field="priority" range="{{['紧急', '重要', '普通']}}">
              <view class="picker-view">
                <text>{{newTodo.priority === 'high' ? '紧急' : newTodo.priority === 'medium' ? '重要' : '普通'}}</text>
                <view class="arrow-down"></view>
              </view>
            </picker>
          </view>
          
          <view class="form-group">
            <text class="label">关联类型</text>
            <picker bindchange="onNewTodoTypeChange" range="{{['无关联', '关联客户', '关联工地']}}">
              <view class="picker-view">
                <text>{{newTodo.relatedTypeLabel || '无关联'}}</text>
                <view class="arrow-down"></view>
              </view>
            </picker>
          </view>
          <view class="form-group" wx:if="{{newTodo.relatedType && newTodo.relatedType !== 'none'}}">
            <text class="label">关联{{newTodo.relatedType === 'lead' ? '客户' : '工地'}} <text class="required">*</text></text>
            <picker bindchange="onNewTodoTargetChange" range="{{createTargetNames}}">
              <view class="picker-view">
                <text class="{{newTodo.relatedTargetName ? 'text-primary' : 'text-placeholder'}}">{{newTodo.relatedTargetName || '请选择'}}</text>
                <view class="arrow-down"></view>
              </view>
            </picker>
          </view>
          <view class="form-group">
            <text class="label">截止日期</text>
            <picker mode="date" value="{{newTodo.dueDate}}" bindchange="onNewTodoDateChange">
              <view class="picker-view">
                <text>{{newTodo.dueDate || '不填默认今天'}}</text>
                <view class="arrow-down"></view>
              </view>
            </picker>
          </view>
          <view class="form-group" style="margin-bottom: 0;">
            <text class="label">执行人 <text style="color:red">*</text></text>
            <!-- 多选执行人下拉框 -->
            <view class="picker-view" bindtap="toggleAssigneeDropdown">
              <text class="{{newTodo.assigneeNames ? 'text-primary' : 'text-placeholder'}}">{{newTodo.assigneeNames || '请选择执行人 (可多选)'}}</text>
              <view class="arrow-down"></view>
            </view>
            
            <!-- 模拟下拉多选面板 -->
            <view class="dropdown-panel" wx:if="{{showAssigneeDropdown}}">
              <scroll-view scroll-y style="max-height: 400rpx;">
                <block wx:for="{{groupedEmployees}}" wx:key="dept">
                  <view class="dropdown-dept-title" bindtap="toggleDept" data-dept="{{item.dept}}">
                    <text>{{item.dept}}</text>
                    <view class="arrow {{item.expanded ? 'up' : 'down'}}"></view>
                  </view>
                  <view class="dept-employees" wx:if="{{item.expanded}}">
                    <view class="dropdown-item" wx:for="{{item.employees}}" wx:for-item="emp" wx:key="id" bindtap="toggleNewTodoAssignee" data-id="{{emp.id}}">
                      <text>{{emp.name}}</text>
                      <view class="checkbox {{emp._todoSelected ? 'checked' : ''}}">
                        <view wx:if="{{emp._todoSelected}}" class="checkmark"></view>
                      </view>
                    </view>
                  </view>
                </block>
              </scroll-view>
              <view class="dropdown-footer" bindtap="toggleAssigneeDropdown">
                <text>确定</text>
              </view>
            </view>
          </view>
          
          <view class="btn-save hover-scale" bindtap="saveNewTodo">保 存</view>
        </view>
      </scroll-view>
    </view>
  </block>

</view>