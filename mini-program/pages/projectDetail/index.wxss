.badge-dot {
  position: absolute;
  width: 14rpx;
  height: 14rpx;
  background: var(--rose-600);
  border-radius: 50%;
}
.page-container {
  padding: 20rpx;
  background: #f5f4f2;
  min-height: 100vh;
}
.project-header {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.flex {
  display: flex;
}
.justify-between {
  justify-content: space-between;
}
.items-center {
  align-items: center;
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1a1a1a;
}
.badge-green { background: var(--emerald-50); color: var(--emerald-600); }
.badge-yellow { background: #fffbeb; color: var(--amber-600); }
.badge-red { background: var(--rose-50); color: var(--rose-600); }
.status-badge {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}
.address-text {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}
.meta-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 30rpx;
  padding-top: 20rpx;
  border-top: 1rpx dashed #eee;
}
.meta-item {
  display: flex;
  flex-direction: column;
}
.meta-item .label {
  font-size: 22rpx;
  color: #999;
}
.meta-item .value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-top: 6rpx;
}

.progress-section {
  background: #fff;
  padding: 30rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
  padding-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.days-badge {
  font-size: 22rpx;
  color: var(--amber-600);
  background: #fffbeb;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: normal;
}

.nodes-list {
  padding-left: 20rpx;
}
.node-item {
  display: flex;
  align-items: flex-start;
  position: relative;
  margin-bottom: 40rpx;
}
.node-line {
  position: absolute;
  left: 18rpx;
  top: 40rpx;
  bottom: -40rpx;
  width: 4rpx;
  background: #e2e8f0;
  z-index: 1;
}
.node-line.active {
  background: var(--emerald-600);
}
.node-circle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #e2e8f0;
  color: #94a3b8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: bold;
  z-index: 2;
  position: relative;
  margin-right: 20rpx;
}
.node-circle.completed {
  background: var(--emerald-600);
  color: #fff;
}
.node-circle.current {
  background: var(--amber-600);
  color: #fff;
  box-shadow: 0 0 0 6rpx var(--amber-50);
}
.node-info {
  display: flex;
  flex-direction: column;
}
.node-name {
  font-size: 28rpx;
  color: #333;
}
.node-name.current-text {
  font-weight: bold;
  color: var(--amber-600);
}
.node-status {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.action-section {
  padding: 20rpx 0;
}
.btn-quote {
  background: var(--primary-900, #4a403a);
  color: #fff;
  text-align: center;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.health-badge, .share-btn {
  width: 104rpx !important;
  height: 48rpx !important;
  display: flex !important;
  align-items: center !important;
  justify-content: center !important;
  padding: 0 !important;
  box-sizing: border-box !important;
  font-size: 22rpx !important;
  font-weight: bold !important;
  border-radius: 8rpx !important;
  margin-bottom: 0 !important;
  margin-left: 0 !important;
  margin-right: 0 !important;
  line-height: 1 !important;
}

.share-btn {
  background: #f1f5f9 !important;
  color: #475569 !important;
}

.share-btn::after {
  display: none;
}