<wxs src="./format.wxs" module="format" />

<view class="page-container" wx:if="{{!loading && project}}">

  <!-- 顶部项目概览卡片 -->
  <view style="background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); position: relative;">
    <!-- 分享按钮 -->
    <view style="position: absolute; right: 32rpx; top: 32rpx; display: flex; flex-direction: column; align-items: flex-end; gap: 16rpx; z-index: 10;">
      <view style="width: 100%; text-align: center; font-size: 24rpx; font-weight: bold; padding: 4rpx 12rpx; border-radius: 8rpx; color: {{project.health === '严重延期' ? 'var(--rose-600)' : (project.health === '预警' ? 'var(--amber-600)' : 'var(--emerald-600)')}}; background: {{project.health === '严重延期' ? 'var(--rose-50)' : (project.health === '预警' ? 'var(--amber-50)' : 'var(--emerald-50)')}}; margin-bottom: 0;">
        {{project.health || '正常'}}
      </view>
      <button open-type="share" style="width: 100%; margin: 0; padding: 4rpx 12rpx; font-size: 24rpx; font-weight: bold; border-radius: 8rpx; color: #64748b; background: #f1f5f9; line-height: normal; border: none; min-width: auto; min-height: auto;">
        分享
      </button>
    </view>

    <!-- 标题和健康状态 -->
    <view style="display: flex; justify-content: center; align-items: flex-start; margin-bottom: 32rpx; text-align: center;">
      <view style="font-size: 36rpx; font-weight: bold; color: #1e293b; line-height: 1.4;">{{project.address || '未知地址'}}</view>
    </view>

<wxs module="ganttUtil">
  module.exports = {
    getDelayDays: function(actualEndDate, expectedEndDate) {
      if (!actualEndDate || !expectedEndDate) return 0;
      var actual = getDate(actualEndDate.replace(getRegExp('-', 'g'), '/')).getTime();
      var expected = getDate(expectedEndDate.replace(getRegExp('-', 'g'), '/')).getTime();
      if (actual <= expected) return 0;
      return Math.floor((actual - expected) / (1000 * 60 * 60 * 24));
    },
    getOverdueDays: function(expectedEndDate) {
      if (!expectedEndDate) return 0;
      var today = getDate();
      today.setHours(0,0,0,0);
      var expected = getDate(expectedEndDate.replace(getRegExp('-', 'g'), '/'));
      expected.setHours(0,0,0,0);
      var diff = today.getTime() - expected.getTime();
      if (diff <= 0) return 0;
      return Math.floor(diff / (1000 * 60 * 60 * 24));
    },
    getActualDays: function(actualStartDate, actualEndDate) {
      if (!actualStartDate || !actualEndDate) return 0;
      var start = getDate(actualStartDate.replace(getRegExp('-', 'g'), '/')).getTime();
      var end = getDate(actualEndDate.replace(getRegExp('-', 'g'), '/')).getTime();
      return Math.max(1, Math.floor((end - start) / (1000 * 60 * 60 * 24)) + 1);
    },
    formatDateRange: function(start, end) {
      if (!start || !end) return start + ' ~ ' + end;
      var startParts = start.split('-');
      var endParts = end.split('-');
      if (startParts.length !== 3 || endParts.length !== 3) return start + ' ~ ' + end;
      
      if (startParts[0] === endParts[0]) {
        return start + ' ~ ' + endParts[1] + '-' + endParts[2];
      }
      return start + ' ~ ' + end;
    }
  };
</wxs>

    <!-- 客户信息 -->
    <view style="margin-bottom: 20rpx; margin-top: -12rpx;" bindtap="goToLead">
      <customer-info name="{{project.customer}}" phone="{{project.phone}}" customerNo="{{project.customerNo || project.leadId}}" />
    </view>

    <!-- 核心数据网格 -->
    <view style="display: flex; flex-direction: column; gap: 16rpx; background: #f8fafc; padding: 24rpx; border-radius: 12rpx;">
      <!-- 第一行 -->
      <view style="display: flex; justify-content: space-between; align-items: center;">
        <view style="flex: 1; display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">实际开工</text>
          <text style="font-size: 26rpx; font-weight: 500; color: #334155;">{{project.startDate || '未开工'}}</text>
        </view>
        <view style="flex: 1; display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">预计完工</text>
          <text style="font-size: 26rpx; font-weight: 500; color: #334155;">{{project.expectedEndDate || '-'}}</text>
        </view>
        <view style="flex: 1; display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">已耗工期</text>
          <view style="display: flex; align-items: baseline;">
            <text style="font-size: 28rpx; font-weight: bold; color: var(--amber-600);">{{project.daysElapsed || 0}}</text>
            <text style="font-size: 20rpx; color: var(--amber-600); margin-left: 4rpx;">天</text>
          </view>
        </view>
      </view>
      <!-- 分割线 -->
      <view style="height: 1rpx; background: #e2e8f0; width: 100%; margin: 8rpx 0;"></view>
      <!-- 第二行 -->
      <view style="display: flex; justify-content: space-between; align-items: center;">
        <view style="flex: 1; display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">项目经理</text>
          <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.manager || '-'}}</text>
        </view>
        <view style="flex: 1; display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">销售</text>
          <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.sales || '-'}}</text>
        </view>
        <view style="flex: 1; display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">设计师</text>
          <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.designer || '-'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作区：三块入口 -->
  <view style="display: flex; gap: 16rpx; margin-bottom: 24rpx;">
    <!-- 客户信息（所有人可见） -->
    <view bindtap="goToLead" style="flex: 1; background: #fff; padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e8edf2;">
      <text style="font-size: 26rpx; font-weight: 600; color: #334155;">客户信息</text>
    </view>
    
    <!-- 以下入口仅相关人员可见 -->
    <block wx:if="{{isAdmin || isRelated}}">
      <view bindtap="goToFiles" style="flex: 1; background: #fff; padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e8edf2;">
        <text style="font-size: 26rpx; font-weight: 600; color: #334155;">项目资料</text>
      </view>
      <view bindtap="goToFollowUps" style="flex: 1; background: #fff; padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e8edf2;">
        <view style="position: relative; display: inline-block;">
          <text style="font-size: 26rpx; font-weight: 600; color: #334155;">跟进记录</text>
          <view wx:if="{{hasUnreadFollowUp}}" class="badge-dot" style="top: -6rpx; right: -16rpx;"></view>
        </view>
      </view>
      <view bindtap="goToAccessManage" style="flex: 1; background: #fff; padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e8edf2;">
        <text style="font-size: 26rpx; font-weight: 600; color: #334155;">查看申请</text>
      </view>
    </block>
  </view>

  <!-- 施工动态看板 -->
  <!-- 只有管理员或者相关人员才能看到整个施工动态版块 -->
  <view wx:if="{{isAdmin || isRelated}}" style="background: #fff; border-radius: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); overflow: hidden; margin-bottom: 60rpx;">
    <!-- 头部栏 -->
    <view style="padding: 24rpx 32rpx; background: rgba(248,250,252,0.8); border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
      <view style="font-size: 30rpx; font-weight: bold; color: #1e293b; display: flex; align-items: center;">
        <view style="width: 8rpx; height: 28rpx; background: #4a403a; border-radius: 4rpx; margin-right: 16rpx;"></view>
        施工动态
      </view>
      <view style="display: flex; gap: 16rpx; align-items: center;">
        <view wx:if="{{isEditingNodes}}" bindtap="cancelEditNodes" style="font-size: 24rpx; color: #64748b; background: #f8fafc; padding: 10rpx 24rpx; border-radius: 30rpx; border: 1rpx solid #e2e8f0;">
          取消修改
        </view>
        <view bindtap="toggleEditNodes" style="font-size: 24rpx; color: {{isEditingNodes ? '#fff' : 'var(--primary-600)'}}; font-weight: bold; background: {{isEditingNodes ? 'var(--primary-900)' : '#f1f5f9'}}; padding: 10rpx 24rpx; border-radius: 30rpx;">
          {{isEditingNodes ? '保存编辑' : '编辑节点'}}
        </view>
      </view>
    </view>
    
    <!-- 时间轴列表 -->
    <view style="padding: 32rpx; position: relative;">
      <!-- 左侧贯穿连接线 (仅在非编辑模式下显示) -->
      <view wx:if="{{!isEditingNodes}}" style="position: absolute; left: 58rpx; top: 50rpx; bottom: 50rpx; width: 4rpx; background: #f1f5f9; border-radius: 2rpx; z-index: 0;"></view>

      <view wx:for="{{nodesList}}" wx:key="name" wx:for-index="idx" style="position: relative; z-index: {{draggingIdx === idx ? 99 : 1}}; display: flex; margin-bottom: 40rpx; {{draggingIdx === idx ? 'transform: scale(1.02); box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.1);' : ''}} transition: transform 0.2s;">
        
        <!-- 左侧状态图标圈 (仅在非编辑模式下显示) -->
        <view wx:if="{{!isEditingNodes}}" style="width: 56rpx; flex-shrink: 0; display: flex; justify-content: center; margin-right: 24rpx; padding-top: 8rpx;">
          <view wx:if="{{item.status === 'completed'}}" style="width: 48rpx; height: 48rpx; background: var(--emerald-600); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);">
            <text style="color: #fff; font-size: 24rpx; font-weight: bold;">✓</text>
          </view>
          <view wx:elif="{{item.status === 'current'}}" style="width: 48rpx; height: 48rpx; background: var(--amber-600); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid var(--amber-50);">
            <text style="color: #fff; font-size: 24rpx; font-weight: bold;">•</text>
          </view>
          <view wx:else style="width: 48rpx; height: 48rpx; background: #f1f5f9; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff;">
            <text style="color: #94a3b8; font-size: 22rpx; font-weight: bold; font-family: monospace;">{{idx + 1}}</text>
          </view>
        </view>

        <!-- 右侧内容卡片 -->
        <view style="flex: 1; background: {{isEditingNodes ? '#fff' : (item.status === 'current' ? '#fff' : (item.status === 'completed' ? '#fff' : '#f8fafc'))}}; border: 1rpx solid {{isEditingNodes ? '#e2e8f0' : (item.status === 'current' ? 'rgba(245,158,11,0.3)' : '#f1f5f9')}}; border-radius: 16rpx; overflow: hidden; transition: all 0.3s; box-shadow: {{(item.status === 'current' && !isEditingNodes) ? '0 8rpx 24rpx rgba(245,158,11,0.12)' : 'none'}};">
          
          <!-- 删除大节点按钮 (仅编辑模式下显示) -->
          <view wx:if="{{isEditingNodes}}" catchtap="removeMajorNode" data-index="{{idx}}" style="position: absolute; right: 0; top: 0; background: var(--rose-600); color: #fff; width: 44rpx; height: 44rpx; border-radius: 0 16rpx 0 16rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; z-index: 10;">×</view>

          <!-- 卡片头部 (可点击展开) -->
          <view style="display: flex; align-items: {{isEditingNodes ? 'flex-start' : 'stretch'}};">
            <!-- 拖拽把手 (仅编辑模式) -->
            <view wx:if="{{isEditingNodes}}"
                  catchtouchstart="onNodeDragStart"
                  catchtouchmove="onNodeDragMove"
                  catchtouchend="onNodeDragEnd"
                  data-index="{{idx}}"
                  style="padding: 32rpx 16rpx 32rpx 24rpx; display: flex; align-items: center; justify-content: center;">
              <view style="display: flex; flex-direction: column; gap: 8rpx;">
                <view style="width: 32rpx; height: 4rpx; background: #cbd5e1; border-radius: 2rpx;"></view>
                <view style="width: 32rpx; height: 4rpx; background: #cbd5e1; border-radius: 2rpx;"></view>
                <view style="width: 32rpx; height: 4rpx; background: #cbd5e1; border-radius: 2rpx;"></view>
              </view>
            </view>

            <!-- 头部内容区 -->
            <view bindtap="toggleNode" data-index="{{idx}}" style="flex: 1; padding: 24rpx 24rpx 24rpx {{isEditingNodes ? '8rpx' : '24rpx'}}; display: flex; justify-content: space-between; align-items: center;">
              <view style="flex: 1;">
                <!-- 编辑模式下可修改大节点名称 -->
                <view wx:if="{{isEditingNodes}}" style="display: flex; align-items: center; gap: 16rpx; width: 85%;">
                  <input value="{{item.name}}" data-index="{{idx}}" catchtap="preventBubble" bindinput="onEditMajorNodeName" style="font-size: 30rpx; font-weight: bold; color: #1e293b; background: #f8fafc; padding: 8rpx 16rpx; border-radius: 8rpx; flex: 1; border: 1rpx solid #e2e8f0;" placeholder="节点名称" />
                </view>
                <view wx:else style="font-size: 30rpx; font-weight: bold; margin-bottom: 8rpx; color: {{item.status === 'current' ? 'var(--amber-600)' : (item.status === 'completed' ? 'var(--emerald-600)' : '#94a3b8')}};">
                  {{item.name}}
                </view>
                
                <view wx:if="{{!isEditingNodes}}" style="font-size: 22rpx; color: #64748b; display: flex; flex-direction: column; gap: 8rpx;">
                  <view style="display: flex; align-items: center; justify-content: space-between;">
                    <view style="display: flex; align-items: center; color: #94a3b8;">
                      <view style="width: 70rpx;">计划：</view>
                      <view>{{ganttUtil.formatDateRange(item.startDate, item.endDate)}}</view>
                    </view>
                    <view style="padding: 2rpx 12rpx; background: #f1f5f9; border-radius: 8rpx; color: #64748b; font-size: 20rpx;">计划 {{item.duration}} 天</view>
                  </view>
                  <view wx:if="{{item.actualStartDate || item.actualEndDate}}" style="display: flex; align-items: center; justify-content: space-between;">
                    <view style="display: flex; align-items: center;">
                      <view style="width: 70rpx;">实际：</view>
                      <view>{{ganttUtil.formatDateRange(item.actualStartDate || item.startDate, item.actualEndDate || '至今')}}</view>
                    </view>
                    <view wx:if="{{item.status === 'completed'}}" style="padding: 2rpx 12rpx; background: #f1f5f9; border-radius: 8rpx; color: #64748b; font-size: 20rpx;">用时 {{ganttUtil.getActualDays(item.actualStartDate || item.startDate, item.actualEndDate)}} 天</view>
                  </view>
                </view>
              </view>
              <view style="display: flex; align-items: center; gap: 16rpx; margin-right: {{isEditingNodes ? '50rpx' : '0'}};">
                <view style="transform: {{item.expanded ? 'rotate(180deg)' : 'rotate(0)'}}; transition: 0.3s; font-size: 24rpx; color: #cbd5e1;">▼</view>
              </view>
            </view>
          </view>

          <!-- 展开详情 -->
          <view wx:if="{{item.expanded}}" style="padding: 0 24rpx 24rpx; border-top: 1rpx solid #f1f5f9; padding-top: 20rpx;">
            <!-- 小工序列表（无圆点，纯列表） -->
            <view style="display: flex; flex-direction: column; gap: 16rpx;">
              <view wx:for="{{item.subNodes}}" wx:for-item="sub" wx:for-index="subIdx" wx:key="name"
                    bindtap="openSubNodePopup" data-major="{{idx}}" data-sub="{{subIdx}}"
                    style="background: #f8fafc; border-radius: 12rpx; padding: 20rpx 24rpx; position: relative; border: 0.5px solid {{(subIdx === 0 || subIdx === item.subNodes.length - 1) ? (sub.status === 'completed' ? 'var(--emerald-500)' : (sub.status === 'awaiting_signature' ? 'var(--amber-500)' : '#cbd5e1')) : 'transparent'}};">
                <!-- 删除按钮（裁剪模式） -->
                <view wx:if="{{isEditingNodes}}" catchtap="removeSubNode" data-major="{{idx}}" data-sub="{{subIdx}}" style="position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; background: var(--rose-600); color: #fff; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; z-index: 10; opacity: {{(subIdx === 0 || subIdx === item.subNodes.length - 1) ? '0.3' : '1'}};">×</view>
                <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: {{isEditingNodes ? '0' : '16rpx'}};">
                  <!-- 编辑模式下的名字输入框 -->
                  <view wx:if="{{isEditingNodes}}" style="display: flex; align-items: center; gap: 12rpx; width: 100%; padding-right: 20rpx;">
                    <input value="{{sub.name}}" data-major="{{idx}}" data-sub="{{subIdx}}" catchtap="preventBubble" bindinput="onEditSubNodeName" placeholder="工序名称" style="font-size: 28rpx; font-weight: 600; color: #1e293b; background: #fff; border: 1rpx solid #e2e8f0; border-radius: 8rpx; padding: 0 16rpx; flex: 1; height: 56rpx; min-height: 56rpx;" />
                  </view>

                  <!-- 非编辑模式下的正常显示 -->
                  <block wx:else>
                    <view style="display: flex; align-items: center; gap: 12rpx;">
                      <text style="font-size: 28rpx; font-weight: bold; color: {{sub.status==='completed' ? '#334155' : ((sub.status==='current' || sub.status==='awaiting_signature') ? 'var(--amber-600)' : '#475569')}};">{{sub.name}}</text>
                    </view>
                    <view style="display: flex; align-items: center; gap: 8rpx;">
                      <block wx:if="{{sub.status==='completed'}}">
                        <block wx:if="{{subIdx === 0 || subIdx === item.subNodes.length - 1}}">
                          <view style="font-size: 20rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">已确认</view>
                        </block>
                        <block wx:else>
                          <view wx:if="{{sub.actualEndDate <= sub.endDate}}" style="font-size: 20rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">按时完成</view>
                          <view wx:else style="font-size: 20rpx; color: var(--rose-600); background: var(--rose-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">逾期 {{ganttUtil.getDelayDays(sub.actualEndDate, sub.endDate)}} 天</view>
                        </block>
                      </block>
                      <view wx:elif="{{sub.status==='awaiting_signature'}}" style="font-size: 20rpx; color: var(--rose-600); background: var(--rose-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold; border: 1rpx solid var(--rose-200); animation: pulse 2s infinite;">待确认</view>
                      <block wx:elif="{{sub.status==='current'}}">
                        <view wx:if="{{ganttUtil.getOverdueDays(sub.endDate) > 0}}" style="font-size: 20rpx; color: var(--rose-600); background: var(--rose-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold;">逾期 {{ganttUtil.getOverdueDays(sub.endDate)}} 天</view>
                        <view wx:else style="font-size: 20rpx; color: var(--amber-600); background: var(--amber-50); padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: bold; border: 1rpx solid var(--amber-200);">施工中</view>
                      </block>
                    </view>
                  </block>
                </view>
                
                <!-- 非编辑模式下的日期显示 -->
                <view wx:if="{{!isEditingNodes}}" style="display: flex; flex-direction: column; gap: 10rpx;">
                  <view style="display: flex; align-items: center; justify-content: space-between; font-size: 22rpx; color: #94a3b8; line-height: 1;">
                    <view style="display: flex; align-items: center;">
                      <view style="width: 70rpx;">计划：</view>
                      <view>{{ganttUtil.formatDateRange(sub.startDate, sub.endDate)}}</view>
                    </view>
                    <view style="padding: 2rpx 12rpx; background: #f1f5f9; border-radius: 8rpx; color: #64748b; font-size: 20rpx;">计划 {{sub.duration}} 天</view>
                  </view>
                  <view wx:if="{{sub.actualStartDate || sub.actualEndDate}}" style="display: flex; align-items: center; justify-content: space-between; font-size: 22rpx; color: #64748b; line-height: 1;">
                    <view style="display: flex; align-items: center;">
                      <view style="width: 70rpx;">实际：</view>
                      <view>
                        {{ganttUtil.formatDateRange(sub.actualStartDate || sub.startDate, sub.actualEndDate || '至今')}}
                      </view>
                    </view>
                    <view wx:if="{{sub.status === 'completed'}}" style="padding: 2rpx 12rpx; background: #f1f5f9; border-radius: 8rpx; color: #64748b; font-size: 20rpx;">用时 {{ganttUtil.getActualDays(sub.actualStartDate || sub.startDate, sub.actualEndDate)}} 天</view>
                  </view>
                </view>
              </view>
              
              <!-- 添加小工序按钮 -->
              <view wx:if="{{isEditingNodes}}" bindtap="addSubNode" data-index="{{idx}}" style="margin-top: 10rpx; background: #fff; border: 2rpx dashed #cbd5e1; border-radius: 12rpx; padding: 16rpx; display: flex; justify-content: center; align-items: center; color: #64748b; font-size: 26rpx;">
                <text style="font-weight: bold; margin-right: 8rpx; font-size: 32rpx; line-height: 1;">+</text> 添加小工序
              </view>
            </view>
          </view>
          
        </view>
      </view>
      
      <!-- 添加大节点按钮 -->
      <view wx:if="{{isEditingNodes}}" bindtap="addMajorNode" style="margin-top: 40rpx; background: #fff; border: 2rpx dashed var(--primary-400); border-radius: 16rpx; padding: 24rpx; display: flex; justify-content: center; align-items: center; color: var(--primary-600); font-size: 28rpx;">
        <text style="font-weight: bold; margin-right: 12rpx; font-size: 36rpx; line-height: 1;">+</text> 添加大节点
      </view>
    </view>
  </view>
  
  <!-- 添加施工档案弹窗 -->
  <view class="modal-mask" wx:if="{{showUploadModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 16rpx; padding: 30rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx;">添加施工记录</view>
      <textarea placeholder="输入文字说明..." bindinput="onDescInput" value="{{uploadDesc}}" style="width: 100%; height: 160rpx; background: #f8fafc; padding: 20rpx; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; margin-bottom: 20rpx;"></textarea>
      
      <view class="media-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; width: 100%; margin-bottom: 30rpx; box-sizing: border-box;">
        <block wx:for="{{uploadFiles}}" wx:key="url">
          <view style="width: 100%; padding-bottom: 100%; position: relative;">
            <image src="{{format.formatImageUrl(item.url)}}" mode="aspectFill" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 8rpx;" wx:if="{{item.type === 'image'}}" bindtap="previewUploadPhoto" data-index="{{index}}"></image>
            <video src="{{item.url}}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 8rpx;" wx:if="{{item.type === 'video'}}" bindtap="previewUploadPhoto" data-index="{{index}}"></video>
            <view catchtap="removeUploadPhoto" data-index="{{index}}" style="position: absolute; top: -12rpx; right: -12rpx; width: 44rpx; height: 44rpx; background: var(--rose-600); color: #fff; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold; z-index: 10;">×</view>
          </view>
        </block>
        <view class="upload-btn" bindtap="chooseMedia" style="width: 100%; padding-bottom: 100%; position: relative; border-radius: 8rpx; background: #f1f5f9;">
          <view style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #94a3b8;">
            <text style="font-size: 40rpx; line-height: 1;">+</text>
          </view>
        </view>
      </view>
      
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeUpload" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="submitUpload" style="flex: 1; font-size: 28rpx; background: #4a403a; color: #fff;">提交</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeUpload" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 子工序详情浮层 -->
  <view wx:if="{{showSubNodePopup && (isAdmin || isRelated)}}" catchtouchmove="preventTouchMove" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; display: flex; align-items: flex-end; justify-content: center;">
    <view bindtap="closeSubNodePopup" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5);"></view>
    <view style="position: relative; z-index: 1; width: 100%; height: 85vh; background: #fff; border-radius: 32rpx 32rpx 0 0; box-sizing: border-box; display: flex; flex-direction: column;">
      
      <!-- 顶部固定区域：工序名称 + 状态标签 -->
      <view style="display: flex; justify-content: space-between; align-items: center; padding: 48rpx 40rpx 24rpx; flex-shrink: 0;">
        <view style="font-size: 36rpx; font-weight: bold; color: #1e293b;">{{popupSub.name}}</view>
        <view wx:if="{{popupSub.status === 'completed'}}" style="font-size: 22rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 8rpx 24rpx; border-radius: 20rpx; font-weight: 600;">已确认</view>
        <view wx:elif="{{popupSub.status === 'awaiting_signature'}}" style="font-size: 22rpx; color: var(--rose-600); background: var(--rose-50); padding: 8rpx 24rpx; border-radius: 20rpx; font-weight: 600;">待确认</view>
        <view wx:else style="font-size: 22rpx; color: #64748b; background: #f1f5f9; padding: 8rpx 24rpx; border-radius: 20rpx;">待完成</view>
      </view>

      <!-- 中间可滚动区域 -->
      <scroll-view scroll-y="{{true}}" style="flex: 1; width: 100%; height: 0;">
        <view style="padding: 0 40rpx 40rpx; width: 100%; box-sizing: border-box; padding-bottom: 240rpx;">
          <!-- 时间与工期信息卡片 (带浅色背景) -->
          <view style="background: #f8fafc; border-radius: 16rpx; padding: 32rpx; margin-bottom: 48rpx; display: flex; justify-content: space-between; align-items: center;">
            <view style="display: flex; flex-direction: column; align-items: flex-start; gap: 8rpx;">
              <text style="font-size: 22rpx; color: #94a3b8;">预计开工</text>
              <text style="font-size: 26rpx; font-weight: bold; color: #1e293b;">{{popupSub.startDate || '-'}}</text>
              <text style="font-size: 22rpx; color: #94a3b8; margin-top: 12rpx;">实际开工</text>
              <text style="font-size: 26rpx; font-weight: bold; color: #1e293b;">{{popupSub.actualStartDate || '-'}}</text>
            </view>
            
            <view style="display: flex; flex-direction: column; align-items: center;">
              <text style="font-size: 22rpx; color: #94a3b8; margin-bottom: 12rpx;">预计工期</text>
              <view style="display: flex; align-items: baseline;">
                <text style="font-size: 30rpx; font-weight: bold; color: var(--amber-600);">{{popupSub.duration}}</text>
                <text style="font-size: 22rpx; color: var(--amber-600); margin-left: 4rpx;">天</text>
              </view>
              <view wx:if="{{popupSub.status === 'completed'}}" style="display: flex; flex-direction: column; align-items: center; margin-top: 12rpx;">
                <text style="font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx;">实际用时</text>
                <view style="display: flex; align-items: baseline;">
                  <text style="font-size: 30rpx; font-weight: bold; color: #1e293b;">{{ganttUtil.getActualDays(popupSub.actualStartDate, popupSub.actualEndDate)}}</text>
                  <text style="font-size: 22rpx; color: #1e293b; margin-left: 4rpx;">天</text>
                </view>
              </view>
            </view>
            
            <view style="display: flex; flex-direction: column; align-items: flex-end; gap: 8rpx;">
              <text style="font-size: 22rpx; color: #94a3b8;">预计完工</text>
              <text style="font-size: 26rpx; font-weight: bold; color: #1e293b;">{{popupSub.endDate || '-'}}</text>
              <text style="font-size: 22rpx; color: #94a3b8; margin-top: 12rpx;">实际完工</text>
              <text style="font-size: 26rpx; font-weight: bold; color: {{popupSub.status === 'completed' && popupSub.actualEndDate > popupSub.endDate ? 'var(--rose-600)' : '#1e293b'}};">{{popupSub.actualEndDate || '-'}}</text>
            </view>
          </view>

          <!-- 已完成：显示验收人 -->
          <view wx:if="{{popupSub.status === 'completed' && popupSub.acceptanceRecord}}" style="margin-bottom: 32rpx;">
            <view style="font-size: 24rpx; color: #64748b; margin-bottom: 8rpx;">验收人：{{popupSub.acceptanceRecord.inspector || '-'}}</view>
            <view style="font-size: 22rpx; color: #94a3b8; margin-bottom: 12rpx;">验收时间：{{popupSub.acceptanceRecord.createdAt || '-'}}</view>
            <view wx:if="{{popupSub.actualEndDate > popupSub.endDate}}" style="margin-top: 12rpx;">
              <block wx:if="{{popupSub.acceptanceRecord.delayReason}}">
                <view style="font-size: 24rpx; color: var(--rose-600); line-height: 1.5; word-break: break-all; background: var(--rose-50); padding: 12rpx 16rpx; border-radius: 8rpx; border: 1rpx dashed var(--rose-200);">
                  <text style="font-weight: bold;">逾期原因：</text>{{popupSub.acceptanceRecord.delayReason}}
                </view>
              </block>
              <block wx:else>
                    <view style="font-size: 22rpx; color: var(--rose-600);">
                      * 此工序已逾期，请补充填写逾期原因
                      <text catchtap="openAcceptance" data-major-idx="{{idx}}" data-sub-idx="{{subIdx}}" style="color: var(--primary-600); margin-left: 12rpx; text-decoration: underline; font-weight: bold; position: relative; z-index: 10;">去填写</text>
                    </view>
                  </block>
            </view>
          </view>

          <!-- 已完成/待确认：施工影像与现场说明 -->
          <view wx:if="{{(popupSub.status === 'completed' || popupSub.status === 'awaiting_signature') && popupSub.acceptanceRecord && ((popupSub.acceptanceRecord.photos && popupSub.acceptanceRecord.photos.length > 0) || popupSub.acceptanceRecord.remark)}}" style="margin-bottom: 32rpx; width: 100%; box-sizing: border-box;">
            <view style="font-size: 26rpx; color: #334155; margin-bottom: 16rpx; font-weight: 600;">施工现场记录</view>
            
            <view wx:if="{{popupSub.acceptanceRecord.photos && popupSub.acceptanceRecord.photos.length > 0}}" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; width: 100%; box-sizing: border-box;">
              <view wx:for="{{popupSub.acceptanceRecord.photos}}" wx:key="url" style="width: 100%; padding-bottom: 100%; position: relative;">
                <image wx:if="{{!item.type || item.type === 'image'}}" src="{{format.formatImageUrl(item.url || item)}}" mode="aspectFill"
                  style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 12rpx; border: 1rpx solid #e2e8f0; box-sizing: border-box;"
                  bindtap="previewAcceptancePhoto" data-index="{{index}}">
                </image>
                <video wx:if="{{item.type === 'video'}}" src="{{item.url}}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 12rpx; box-sizing: border-box;" bindtap="previewAcceptancePhoto" data-index="{{index}}"></video>
              </view>
            </view>
            <view wx:if="{{popupSub.acceptanceRecord.remark}}" style="margin-top: 16rpx; font-size: 26rpx; color: #475569; line-height: 1.6; word-break: break-all;">{{popupSub.acceptanceRecord.remark}}</view>
          </view>

          <!-- 客户签字确认 -->
          <view wx:if="{{popupSub.signature && popupSub.signature.url}}" style="margin-bottom: 32rpx; padding: 24rpx; background: #f8fafc; border-radius: 16rpx; border-left: 4rpx solid var(--emerald-600);">
            <view style="font-size: 26rpx; color: #334155; margin-bottom: 16rpx; font-weight: 600;">客户签字确认</view>
            <view style="display: flex; align-items: flex-end; justify-content: space-between; margin-bottom: 16rpx;">
              <view style="width: 280rpx; height: 140rpx; background: #fff; border-radius: 12rpx; border: 2rpx solid var(--emerald-200); padding: 12rpx; box-sizing: border-box; display: flex; align-items: center; justify-content: center;">
                <image src="{{format.formatImageUrl(popupSub.signature.url)}}" mode="aspectFit" style="width: 100%; height: 100%;" bindtap="previewSignature" data-url="{{popupSub.signature.url}}" />
              </view>
              <view style="text-align: right;">
                <view style="font-size: 22rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 6rpx 16rpx; border-radius: 12rpx; display: inline-block; margin-bottom: 8rpx;">已签字</view>
                <view style="font-size: 20rpx; color: #94a3b8;">{{popupSub.signature.time}}</view>
              </view>
            </view>
            <!-- 客户反馈 -->
            <view wx:if="{{popupSub.signature.feedback}}" style="background: #fff; padding: 20rpx; border-radius: 12rpx; border: 1rpx solid #e2e8f0;">
              <view style="font-size: 24rpx; color: #64748b; margin-bottom: 8rpx; font-weight: 500;">客户反馈</view>
              <view style="font-size: 26rpx; color: #334155; line-height: 1.6; word-break: break-all;">{{popupSub.signature.feedback}}</view>
            </view>
          </view>
        </view>
      </scroll-view>

      <!-- 底部固定区域：操作按钮组 -->
      <view style="position: absolute; bottom: 0; left: 0; right: 0; display: flex; flex-direction: column; gap: 16rpx; padding: 24rpx 40rpx calc(24rpx + env(safe-area-inset-bottom)); background: #fff; border-top: 1rpx solid #f1f5f9; z-index: 10;">
        <view wx:if="{{popupSub.status === 'awaiting_signature'}}" style="text-align: center; font-size: 24rpx; color: var(--rose-600); margin-bottom: 8rpx;">
          * 请点击下方按钮分享到群内，提醒客户签字确认
        </view>
        <view style="display: flex; gap: 24rpx;">
          <view wx:if="{{popupSub.status !== 'completed' && popupSub.status !== 'awaiting_signature' && project.status !== '未开工'}}" bindtap="openSubNodeEdit" style="flex: 1; background: #f1f5f9; border-radius: 16rpx; padding: 26rpx 0; text-align: center; font-size: 28rpx; font-weight: bold; color: #475569;">编辑排期</view>

          <view wx:if="{{popupSub.status === 'completed' || popupSub.status === 'awaiting_signature'}}" bindtap="openAcceptance" style="flex: 1; background: #f1f5f9; border-radius: 16rpx; padding: 26rpx 0; text-align: center; font-size: 28rpx; font-weight: bold; color: #475569;">修改记录</view>

          <view wx:if="{{popupSub.status !== 'completed' && popupSub.status !== 'awaiting_signature' && popupMajorNode.status !== 'pending'}}" bindtap="openAcceptance" style="flex: 1; background: #1e293b; border-radius: 16rpx; padding: 26rpx 0; text-align: center; font-size: 28rpx; font-weight: bold; color: #fff;">添加记录</view>

          <button wx:if="{{popupSub.status === 'completed' || popupSub.status === 'awaiting_signature'}}" open-type="share" data-share-type="node" data-major-idx="{{popupMajorIdx}}" data-sub-idx="{{popupSubIdx}}" style="flex: 1; margin: 0; background: var(--emerald-600); border-radius: 16rpx; padding: 26rpx 0; text-align: center; font-size: 28rpx; font-weight: bold; color: #fff; line-height: normal; border: none;">分享{{popupSubIdx === 0 || popupSubIdx === popupMajorNode.subNodes.length - 1 ? '确认单' : '验收单'}}</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 编辑排期弹窗 -->
  <view wx:if="{{showSubNodeEdit}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300; display: flex; align-items: flex-end; justify-content: center;">
    <view bindtap="closeSubNodeEdit" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6);"></view>
    <view style="position: relative; z-index: 1; width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 48rpx 40rpx 64rpx; box-sizing: border-box;">
      <view style="font-size: 36rpx; font-weight: bold; color: #1e293b; margin-bottom: 8rpx; text-align: left;">编辑排期</view>
      <view style="font-size: 26rpx; color: #94a3b8; text-align: left; margin-bottom: 40rpx;">当前工序：{{popupSub.name}}</view>

      <!-- 开工日期 -->
      <view style="margin-bottom: 32rpx;">
        <view style="font-size: 26rpx; color: #334155; font-weight: 600; margin-bottom: 16rpx;">预计开工日期</view>
        <picker mode="date" value="{{editSubStartDate}}" bindchange="onEditSubStartDateChange">
          <view style="padding: 28rpx 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 30rpx; color: #1e293b; font-weight: 500; border: 1rpx solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
            <text>{{editSubStartDate || '请选择日期'}}</text>
            <text style="color: #94a3b8; font-size: 24rpx;">▼</text>
          </view>
        </picker>
      </view>

      <!-- 工期天数 -->
      <view style="margin-bottom: 32rpx;">
        <view style="font-size: 26rpx; color: #334155; font-weight: 600; margin-bottom: 16rpx;">工期 (天)</view>
        <view style="padding: 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 30rpx; color: #1e293b; font-weight: 500; border: 1rpx solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
          <input type="number" value="{{editSubDuration}}" bindinput="onEditSubDurationInput" placeholder="输入天数" style="width: 100%; height: 100%;" />
        </view>
      </view>

      <!-- 完工日期 -->
      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 26rpx; color: #334155; font-weight: 600; margin-bottom: 16rpx;">预计完工日期</view>
        <picker mode="date" value="{{editSubEndDate}}" bindchange="onEditSubEndDateChange">
          <view style="padding: 28rpx 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 30rpx; color: #1e293b; font-weight: 500; border: 1rpx solid #e2e8f0; display: flex; justify-content: space-between; align-items: center;">
            <text>{{editSubEndDate || '请选择日期'}}</text>
            <text style="color: #94a3b8; font-size: 24rpx;">▼</text>
          </view>
        </picker>
      </view>

      <view style="font-size: 24rpx; color: var(--amber-600); background: var(--amber-50); padding: 20rpx 24rpx; border-radius: 12rpx; margin-bottom: 48rpx; line-height: 1.6; border: 1rpx solid rgba(245, 158, 11, 0.2);">
        确认后，此工序之后的所有工序将自动顺延（跳过周末及法定节假日）
      </view>

      <view style="display: flex; gap: 24rpx;">
        <view bindtap="closeSubNodeEdit" style="flex: 1; font-size: 30rpx; background: #f1f5f9; color: #475569; border-radius: 16rpx; text-align: center; padding: 28rpx 0; font-weight: bold;">取消</view>
        <view bindtap="confirmSubNodeEdit" style="flex: 1; font-size: 30rpx; background: #1e293b; color: #fff; border-radius: 16rpx; text-align: center; padding: 28rpx 0; font-weight: bold;">确认保存</view>
      </view>
    </view>
  </view>

  <!-- 施工影像档案弹窗 -->
  <view wx:if="{{showAcceptanceModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300; display: flex; flex-direction: column;">
    <view style="background: #fff; flex: 1; overflow-y: auto; padding: 0 0 calc(140rpx + env(safe-area-inset-bottom));">
      <!-- 顶部导航栏 -->
      <view style="display: flex; align-items: center; padding: 60rpx 32rpx 24rpx; border-bottom: 1rpx solid #f1f5f9; position: sticky; top: 0; background: #fff; z-index: 10;">
        <view bindtap="closeAcceptance" style="font-size: 28rpx; color: #64748b; padding: 8rpx 20rpx 8rpx 0; margin-right: 16rpx;">返回</view>
        <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; flex: 1;">{{popupSub.name}} · 施工影像</view>
        <view wx:if="{{acceptanceMode === 'edit'}}" style="font-size: 24rpx; color: var(--rose-600); background: var(--rose-50); padding: 8rpx 20rpx; border-radius: 20rpx;">编辑中</view>
        <view wx:if="{{acceptanceMode === 'draft'}}" style="font-size: 24rpx; color: var(--amber-600); background: var(--amber-50); padding: 8rpx 20rpx; border-radius: 20rpx;">草稿</view>
      </view>

      <view style="padding: 40rpx;">
        <!-- 记录人 -->
        <view style="margin-bottom: 32rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">记录人</view>
          <view style="padding: 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; color: #1e293b; font-weight: 500;">{{userName}}</view>
        </view>

        <!-- 现场说明 -->
        <view style="margin-bottom: 32rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">现场说明</view>
          <textarea placeholder="填写施工情况说明..." bindinput="onAcceptanceRemarkInput" value="{{acceptanceRemark}}" style="width: 100%; height: 200rpx; background: #f8fafc; padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #1e293b;"></textarea>
        </view>

        <!-- 延期原因（若逾期则必填） -->
        <view wx:if="{{ganttUtil.getDelayDays(todayDate, popupSub.endDate) > 0 || (popupSub.actualEndDate && popupSub.actualEndDate > popupSub.endDate)}}" style="margin-bottom: 32rpx;">
          <view style="font-size: 26rpx; color: var(--rose-600); margin-bottom: 12rpx; font-weight: bold;">逾期原因</view>
          <textarea placeholder="请详细说明导致此工序逾期的原因..." bindinput="onDelayReasonInput" value="{{delayReason}}" style="width: 100%; height: 160rpx; background: var(--rose-50); padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid var(--rose-200); color: var(--rose-900);"></textarea>
        </view>

        <!-- 现场影像 -->
        <view style="margin-bottom: 40rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 16rpx;">现场影像 <text style="color: #cbd5e1; font-size: 22rpx; font-weight: normal; margin-left: 8rpx;">(选填)</text></view>
          <view class="media-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20rpx; width: 100%; box-sizing: border-box;">
            <view wx:for="{{acceptancePhotos}}" wx:key="url" style="width: 100%; padding-bottom: 100%; position: relative;">
              <image wx:if="{{item.type === 'image' || !item.type}}" src="{{format.formatImageUrl(item.url || item)}}" mode="aspectFill" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 12rpx; border: 1rpx solid #e2e8f0; box-sizing: border-box;" bindtap="previewAcceptancePhoto" data-index="{{index}}"></image>
              <video wx:else src="{{item.url}}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; border-radius: 12rpx; box-sizing: border-box;" bindtap="previewAcceptancePhoto" data-index="{{index}}"></video>
              <view catchtap="removeAcceptancePhoto" data-index="{{index}}" style="position: absolute; top: -12rpx; right: -12rpx; width: 44rpx; height: 44rpx; background: var(--rose-600); color: #fff; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold; z-index: 10;">×</view>
            </view>
            <view bindtap="chooseAcceptanceMedia" style="width: 100%; padding-bottom: 100%; position: relative; border-radius: 12rpx; background: #f8fafc; border: 2rpx dashed #cbd5e1; box-sizing: border-box;">
              <view style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; display: flex; flex-direction: column; align-items: center; justify-content: center;">
                <text style="font-size: 56rpx; color: #94a3b8; font-weight: 300; line-height: 1;">+</text>
                <text style="font-size: 22rpx; color: #94a3b8; margin-top: 8rpx;">上传影像</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 底部固定按钮 -->
    <view style="position: fixed; bottom: 0; left: 0; right: 0; background: #fff; padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom)); border-top: 1rpx solid #f1f5f9; z-index: 20; display: flex; gap: 20rpx;">
      <button bindtap="closeAcceptance" style="flex: 1; background: #f1f5f9; color: #475569; font-size: 28rpx; font-weight: bold; border-radius: 16rpx; padding: 26rpx 0; border: none; margin: 0;">稍后填写</button>
      <button bindtap="submitAcceptance" style="flex: 1; background: #1e293b; color: #fff; font-size: 28rpx; font-weight: bold; border-radius: 16rpx; padding: 26rpx 0; border: none; margin: 0;">
        {{acceptanceMode === 'edit' ? '保存修改' : '提交记录'}}
      </button>
    </view>
  </view>

  <!-- 修改工期弹窗 -->
  <view class="modal-mask" wx:if="{{showEditDurationModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 12rpx; color: #1e293b;">修改工期天数</view>
      <view style="font-size: 24rpx; color: #64748b; text-align: center; margin-bottom: 40rpx;">{{nodesList[editDurationMajorIdx].subNodes[editDurationSubIdx].name}}</view>

      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">工序天数（0 表示跳过此工序）</view>
        <input type="number" placeholder="输入天数" value="{{editDurationValue}}" bindinput="onEditDurationInput" style="width: 100%; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0;" />
      </view>

      <view style="font-size: 22rpx; color: var(--amber-600); background: var(--amber-50); padding: 16rpx; border-radius: 8rpx; margin-bottom: 40rpx;">
        修改后系统将自动重新推算后续所有工序的预计开/完工日期（自动跳过周末及法定节假日）。
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeEditDurationModal" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="confirmEditDuration" style="flex: 1; font-size: 28rpx; background: #1e293b; color: #fff; font-weight: bold;">保存并重算</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeEditDurationModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>


  <!-- 资料弹窗已被移除，使用独立页面替代 -->

  <!-- 分享图绘制 Canvas (隐藏) -->
  <canvas type="2d" id="shareCanvas" style="width: 500px; height: 400px; position: fixed; left: -9999px; top: -9999px;"></canvas>
  <canvas type="2d" id="projectShareCanvas" style="width: 500px; height: 400px; position: fixed; left: -9999px; top: -9999px;"></canvas>

  <!-- 延误停工弹窗 -->
  <view class="modal-mask" wx:if="{{showDelayModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; color: #be123c;">记录停工 / 延误</view>
      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">延误天数</view>
        <input type="number" placeholder="输入延误天数" value="{{delayDays}}" bindinput="onDelayDaysInput" style="width: 100%; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;" />
      </view>
      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">延误原因</view>
        <textarea placeholder="说明延误或停工的具体原因..." value="{{delayReason}}" bindinput="onDelayReasonInput" style="width: 100%; height: 140rpx; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;"></textarea>
      </view>
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeDelayModal" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="confirmDelay" style="flex: 1; font-size: 28rpx; background: var(--rose-600); color: #fff; font-weight: bold;">确认记录并重算</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeDelayModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 开工弹窗 -->
  <view class="modal-mask" wx:if="{{isStartingProject}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx;">准备开工</view>
      <view style="margin-bottom: 30rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">项目总开工日期</view>
        <picker mode="date" value="{{baseStartDate}}" bindchange="onStartDateChange">
          <view style="width: 100%; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155; font-weight: 500; text-align: center;">{{baseStartDate || '请选择日期'}}</view>
        </picker>
        <view style="font-size: 22rpx; color: #94a3b8; margin-top: 10rpx;">系统将自动按 T+N 算法推算所有工序的预计开/完工日期，自动跳过周末及法定节假日。</view>
      </view>
      <view style="margin-bottom: 40rpx; display: flex; align-items: center; justify-content: space-between; background: #f1f5f9; padding: 20rpx; border-radius: 8rpx;">
        <view style="font-size: 26rpx; color: #334155;">裁剪不需要的工序</view>
        <switch checked="{{isEditingNodes}}" bindchange="toggleEditNodes" color="var(--amber-600)" style="transform: scale(0.8);" />
      </view>
      <view wx:if="{{isEditingNodes}}" style="font-size: 22rpx; color: var(--amber-600); margin-bottom: 30rpx; background: var(--amber-50); padding: 16rpx; border-radius: 8rpx;">
        裁剪模式已开启，在背景列表中点击红色 × 删除不需要的工序，完成后点击确认开工。
      </view>
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeStartModal" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="confirmStartProject" style="flex: 1; font-size: 28rpx; background: var(--amber-600); color: #fff; font-weight: bold;">确认开工</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeStartModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 编辑项目概况弹窗 -->
  <view class="modal-mask" wx:if="{{showEditProjectModal}}" style="z-index: 9998;">
    <view class="modal-content" style="background: #fff; width: 90%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; bottom: auto; transform: translate(-50%, -50%); z-index: 9998; box-sizing: border-box;">
      <view style="font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 40rpx; color: #1e293b;">编辑工地信息</view>
      
      <view style="margin-bottom: 30rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">实际开工日期</view>
        <picker mode="date" value="{{editProjectStartDate}}" bindchange="onEditProjectStartDateChange">
          <view style="width: 100%; height: 88rpx; line-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155; font-weight: 500;">
            {{editProjectStartDate || '请选择日期'}}
          </view>
        </picker>
      </view>

      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">项目经理</view>
        <picker bindchange="onEditProjectManagerChange" value="{{managerIndex}}" range="{{managerList}}" range-key="name">
          <view style="width: 100%; height: 88rpx; min-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155; display: flex; align-items: center; justify-content: space-between;">
            <text>{{managerIndex !== -1 ? managerList[managerIndex].name : '请选择项目经理'}}</text>
            <text style="font-size: 20rpx; color: #94a3b8;">▼</text>
          </view>
        </picker>
      </view>

      <view style="font-size: 22rpx; color: var(--amber-600); background: var(--amber-50); padding: 16rpx 20rpx; border-radius: 8rpx; margin-bottom: 40rpx; line-height: 1.5;">
        提示：修改开工日期后，系统将自动重新推算所有相关工序的开始和结束日期（跳过周末及节假日）。
      </view>
      
      <view style="display: flex; gap: 20rpx; margin-bottom: 24rpx;">
        <button bindtap="closeEditProjectModal" style="flex: 1; font-size: 30rpx; background: #f1f5f9; color: #475569; border-radius: 12rpx; border: none; padding: 16rpx 0; margin: 0;">取消</button>
        <button bindtap="confirmEditProject" style="flex: 1; font-size: 30rpx; background: #4a403a; color: #fff; border-radius: 12rpx; border: none; padding: 16rpx 0; margin: 0; font-weight: bold;">保存修改</button>
      </view>

      <view style="margin-top: 16rpx;">
        <view bindtap="deleteProject" style="width: 100%; font-size: 28rpx; font-weight: bold; background: #f8fafc; color: var(--rose-600); border-radius: 12rpx; text-align: center; padding: 24rpx 0; box-sizing: border-box;">删除此工地记录</view>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeEditProjectModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9998;"></view>
  </view>

  <view style="height: calc(240rpx + env(safe-area-inset-bottom));"></view>
</view>


