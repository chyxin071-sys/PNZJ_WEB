<view class="page-container" wx:if="{{!loading && project}}">

  <!-- 顶部项目概览卡片 -->
  <view style="background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04); position: relative;">
    <!-- 标题和健康状态 -->
    <view style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx;">
      <view style="font-size: 36rpx; font-weight: bold; color: #1e293b; flex: 1; padding-right: 20rpx; line-height: 1.4;">{{project.address || '未知地址'}}</view>
      <view style="display: flex; align-items: center; gap: 12rpx; flex-shrink: 0;">
        <view style="font-size: 22rpx; font-weight: bold; padding: 6rpx 16rpx; border-radius: 30rpx; color: {{project.health === '严重延期' ? 'var(--rose-600)' : (project.health === '预警' ? 'var(--amber-600)' : 'var(--emerald-600)')}}; background: {{project.health === '严重延期' ? 'var(--rose-50)' : (project.health === '预警' ? 'var(--amber-50)' : 'var(--emerald-50)')}};">
          {{project.health || '正常'}}
        </view>
        <view wx:if="{{userRole === 'admin' || userRole === 'manager'}}" bindtap="openEditProjectModal" style="width: 48rpx; height: 48rpx; background: #f8fafc; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e2e8f0;">
          <text style="font-size: 24rpx; color: #64748b;">编辑</text>
        </view>
      </view>
    </view>

    <!-- 客户信息 -->
    <view style="margin-bottom: 28rpx;">
      <customer-info name="{{project.customer}}" phone="{{project.phone}}" customerNo="{{project.customerNo || project.leadId}}" />
    </view>

    <!-- 核心数据网格 -->
    <view style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16rpx; background: #f8fafc; padding: 20rpx; border-radius: 12rpx;">
      <view style="display: flex; flex-direction: column;">
        <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">实际开工日期</text>
        <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.startDate || '未开工'}}</text>
      </view>
      <view style="display: flex; flex-direction: column;">
        <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">预计完工日期</text>
        <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.expectedEndDate || '-'}}</text>
      </view>
      <view style="display: flex; flex-direction: column;">
        <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">项目经理</text>
        <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.manager || '-'}}</text>
      </view>
      <view style="display: flex; flex-direction: column;">
        <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">已耗工期</text>
        <view style="display: flex; align-items: baseline;">
          <text style="font-size: 28rpx; font-weight: bold; color: var(--amber-600);">{{project.daysElapsed || 0}}</text>
          <text style="font-size: 20rpx; color: var(--amber-600); margin-left: 4rpx;">天</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作区：三块入口 -->
  <view style="display: flex; gap: 16rpx; margin-bottom: 24rpx;">
    <view bindtap="viewFiles" style="flex: 1; background: #fff; padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e8edf2;">
      <text style="font-size: 26rpx; font-weight: 600; color: #334155;">项目资料</text>
    </view>
    <view bindtap="goToQuote" style="flex: 1; background: #fff; padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; border: 1rpx solid #e8edf2;">
      <text style="font-size: 26rpx; font-weight: 600; color: #334155;">报价单</text>
    </view>
    <view wx:if="{{project.status === '未开工'}}" bindtap="startProjectModal" style="flex: 1; background: var(--amber-600); padding: 28rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center;">
      <text style="font-size: 26rpx; font-weight: 600; color: #fff;">准备开工</text>
    </view>
  </view>

  <!-- 8大施工节点管控看板 -->
  <!-- 只有管理员或者相关人员才能看到编辑操作 -->
  <view wx:if="{{isAdmin || isRelated}}" style="background: #fff; border-radius: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); overflow: hidden; margin-bottom: 60rpx;">
    <!-- 头部栏 -->
    <view style="padding: 24rpx 32rpx; background: rgba(248,250,252,0.8); border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
      <view style="font-size: 30rpx; font-weight: bold; color: #1e293b; display: flex; align-items: center;">
        <view style="width: 8rpx; height: 28rpx; background: #4a403a; border-radius: 4rpx; margin-right: 16rpx;"></view>
        8大施工节点管控
      </view>
      <view style="font-size: 24rpx; color: #64748b; font-family: monospace;">
        当前: <text style="font-weight: bold; color: #1e293b;">{{nodesList[currentNodeIndex] ? nodesList[currentNodeIndex].name : '已竣工'}}</text>
      </view>
    </view>
    
    <!-- 时间轴列表 -->
    <view style="padding: 32rpx; position: relative;">
      <!-- 左侧贯穿连接线 -->
      <view style="position: absolute; left: 58rpx; top: 50rpx; bottom: 50rpx; width: 4rpx; background: #f1f5f9; border-radius: 2rpx; z-index: 0;"></view>

      <view wx:for="{{nodesList}}" wx:key="name" wx:for-index="idx" style="position: relative; z-index: 1; display: flex; margin-bottom: 40rpx;">
        
        <!-- 左侧状态图标圈 -->
        <view style="width: 56rpx; flex-shrink: 0; display: flex; justify-content: center; margin-right: 24rpx; padding-top: 8rpx;">
          <view wx:if="{{item.status === 'completed'}}" style="width: 48rpx; height: 48rpx; background: #1e293b; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);">
            <text style="color: #fff; font-size: 24rpx; font-weight: bold;">✓</text>
          </view>
          <view wx:elif="{{item.status === 'current'}}" style="width: 48rpx; height: 48rpx; background: var(--amber-600); border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid var(--amber-50);">
            <text style="color: #fff; font-size: 24rpx; font-weight: bold;">•</text>
          </view>
          <view wx:else style="width: 48rpx; height: 48rpx; background: #f1f5f9; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff;">
            <text style="color: #94a3b8; font-size: 22rpx; font-weight: bold; font-family: monospace;">{{idx + 1}}</text>
          </view>
        </view>

        <!-- 右侧内容卡片 -->
        <view style="flex: 1; background: {{item.status === 'current' ? '#fff' : (item.status === 'completed' ? '#fff' : '#f8fafc')}}; border: 1rpx solid {{item.status === 'current' ? '#fcd34d' : '#f1f5f9'}}; border-radius: 16rpx; overflow: hidden; transition: all 0.3s; box-shadow: {{item.status === 'current' ? '0 4rpx 12rpx rgba(245,158,11,0.05)' : 'none'}};">
          
          <!-- 卡片头部 (可点击展开) -->
          <view bindtap="toggleNode" data-index="{{idx}}" style="padding: 24rpx; display: flex; justify-content: space-between; align-items: center;">
            <view>
              <view style="font-size: 30rpx; font-weight: bold; margin-bottom: 8rpx; color: {{item.status === 'current' ? 'var(--amber-600)' : (item.status === 'completed' ? '#1e293b' : '#94a3b8')}};">
                {{item.name}}
              </view>
              <view style="font-size: 22rpx; color: #64748b;">
                <text wx:if="{{item.status === 'completed'}}">实际开工 {{item.startDate}} · 实际完工 {{item.endDate}}</text>
                <text wx:elif="{{item.status === 'current'}}">进行中 · 预计完工 {{item.endDate}}</text>
                <text wx:else>未开始 · 预计开工 {{item.startDate || '-'}}</text>
              </view>
            </view>
            <view style="display: flex; align-items: center; gap: 16rpx;">
              <view style="transform: {{item.expanded ? 'rotate(180deg)' : 'rotate(0)'}}; transition: 0.3s; font-size: 24rpx; color: #cbd5e1;">▼</view>
            </view>
          </view>

          <!-- 展开详情 -->
          <view wx:if="{{item.expanded}}" style="padding: 0 24rpx 24rpx; border-top: 1rpx solid #f1f5f9; padding-top: 20rpx;">
            <!-- 小工序列表（无圆点，纯列表） -->
            <view style="display: flex; flex-direction: column; gap: 16rpx;">
              <view wx:for="{{item.subNodes}}" wx:for-item="sub" wx:for-index="subIdx" wx:key="name"
                    bindtap="openSubNodePopup" data-major="{{idx}}" data-sub="{{subIdx}}"
                    style="background: #f8fafc; border-radius: 12rpx; padding: 20rpx 24rpx; position: relative;">
                <!-- 删除按钮（裁剪模式） -->
                <view wx:if="{{isEditingNodes && project.status === '未开工'}}" catchtap="removeSubNode" data-major="{{idx}}" data-sub="{{subIdx}}" style="position: absolute; top: -10rpx; right: -10rpx; width: 36rpx; height: 36rpx; background: var(--rose-600); color: #fff; border-radius: 18rpx; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: bold; z-index: 10;">×</view>
                <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8rpx;">
                  <text style="font-size: 28rpx; font-weight: 600; color: {{sub.status==='completed' ? '#1e293b' : '#475569'}};">{{sub.name}}</text>
                  <view wx:if="{{sub.status==='completed'}}" style="font-size: 20rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 4rpx 14rpx; border-radius: 20rpx; font-weight: 600;">已完成</view>
                  <view wx:else style="font-size: 20rpx; color: #94a3b8; background: #fff; padding: 4rpx 14rpx; border-radius: 20rpx; border: 1rpx solid #e2e8f0;">{{sub.duration}}天</view>
                </view>
                <text style="font-size: 22rpx; color: #94a3b8;">
                  <text wx:if="{{sub.status==='completed'}}">实际：{{sub.actualStartDate || '-'}} ~ {{sub.actualEndDate || '-'}}</text>
                  <text wx:else>预计：{{sub.startDate || '-'}} ~ {{sub.endDate || '-'}}</text>
                </text>
              </view>
            </view>
          </view>
          
        </view>
      </view>
    </view>
  </view>
  
  <!-- 添加施工档案弹窗 -->
  <view class="modal-mask" wx:if="{{showUploadModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 16rpx; padding: 30rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx;">添加施工记录</view>
      <textarea placeholder="输入文字说明..." bindinput="onDescInput" value="{{uploadDesc}}" style="width: 100%; height: 160rpx; background: #f8fafc; padding: 20rpx; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; margin-bottom: 20rpx;"></textarea>
      
      <view class="media-grid" style="display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 30rpx;">
        <block wx:for="{{uploadFiles}}" wx:key="url">
          <image src="{{item.url}}" mode="aspectFill" style="width: 120rpx; height: 120rpx; border-radius: 8rpx;" wx:if="{{item.type === 'image'}}"></image>
          <video src="{{item.url}}" style="width: 120rpx; height: 120rpx; border-radius: 8rpx;" wx:if="{{item.type === 'video'}}"></video>
        </block>
        <view class="upload-btn" bindtap="chooseMedia" style="width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #94a3b8;">+</view>
      </view>
      
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeUpload" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="submitUpload" style="flex: 1; font-size: 28rpx; background: #4a403a; color: #fff;">提交</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeUpload" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 子工序详情浮层 -->
  <view wx:if="{{showSubNodePopup}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 200; display: flex; align-items: flex-end;">
    <view bindtap="closeSubNodePopup" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5);"></view>
    <view style="position: relative; z-index: 1; width: 100%; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 40rpx 48rpx 72rpx; box-sizing: border-box;">
      <view style="width: 72rpx; height: 8rpx; background: #e2e8f0; border-radius: 4rpx; margin: 0 auto 36rpx;"></view>

      <!-- 工序名称 + 状态 -->
      <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 32rpx;">
        <view style="font-size: 34rpx; font-weight: bold; color: #1e293b;">{{popupSub.name}}</view>
        <view wx:if="{{popupSub.status === 'completed'}}" style="font-size: 22rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 8rpx 20rpx; border-radius: 20rpx; font-weight: 600;">已完成</view>
        <view wx:else style="font-size: 22rpx; color: #94a3b8; background: #f1f5f9; padding: 8rpx 20rpx; border-radius: 20rpx;">待完成</view>
      </view>

      <!-- 时间 + 工期信息 -->
      <view style="background: #f8fafc; border-radius: 16rpx; padding: 28rpx; margin-bottom: 32rpx;">
        <view style="display: flex; justify-content: space-between; margin-bottom: 20rpx;">
          <view>
            <view style="font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx;">{{popupSub.status === 'completed' ? '实际开工' : '预计开工'}}</view>
            <view style="font-size: 28rpx; font-weight: 600; color: #1e293b;">{{popupSub.status === 'completed' ? (popupSub.actualStartDate || '-') : (popupSub.startDate || '-')}}</view>
          </view>
          <view style="text-align: center;">
            <view style="font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx;">工期</view>
            <view style="font-size: 28rpx; font-weight: 600; color: var(--amber-600);">{{popupSub.duration}} 天</view>
          </view>
          <view style="text-align: right;">
            <view style="font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx;">{{popupSub.status === 'completed' ? '实际完工' : '预计完工'}}</view>
            <view style="font-size: 28rpx; font-weight: 600; color: #1e293b;">{{popupSub.status === 'completed' ? (popupSub.actualEndDate || '-') : (popupSub.endDate || '-')}}</view>
          </view>
        </view>
        <!-- 已完成：显示验收人 -->
        <view wx:if="{{popupSub.status === 'completed' && popupSub.acceptanceRecord}}" style="border-top: 1rpx solid #e8edf2; padding-top: 16rpx;">
          <view style="font-size: 22rpx; color: #94a3b8;">验收人：{{popupSub.acceptanceRecord.inspector || '-'}} · {{popupSub.acceptanceRecord.createdAt || '-'}}</view>
        </view>
      </view>

      <!-- 已完成：验收记录图片 -->
      <view wx:if="{{popupSub.status === 'completed' && popupSub.acceptanceRecord && popupSub.acceptanceRecord.photos && popupSub.acceptanceRecord.photos.length > 0}}" style="margin-bottom: 32rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 16rpx; font-weight: 600;">施工影像</view>
        <view style="display: flex; flex-wrap: wrap; gap: 12rpx;">
          <image wx:for="{{popupSub.acceptanceRecord.photos}}" wx:key="url"
            src="{{item.url || item}}" mode="aspectFill"
            style="width: 180rpx; height: 180rpx; border-radius: 12rpx; border: 1rpx solid #e2e8f0;"
            bindtap="previewAcceptancePhoto" data-index="{{index}}">
          </image>
        </view>
        <view wx:if="{{popupSub.acceptanceRecord.remark}}" style="margin-top: 16rpx; font-size: 26rpx; color: #475569; line-height: 1.6;">{{popupSub.acceptanceRecord.remark}}</view>
      </view>

      <!-- 操作按钮：未完成才显示 -->
      <view wx:if="{{popupSub.status !== 'completed'}}" style="display: flex; gap: 20rpx;">
        <view wx:if="{{project.status !== '未开工'}}" bindtap="openSubNodeEdit" style="flex: 1; background: #f1f5f9; border-radius: 16rpx; padding: 28rpx 0; text-align: center; font-size: 28rpx; font-weight: 600; color: #475569;">编辑排期</view>
        <view wx:if="{{popupMajorNode.status !== 'pending'}}" bindtap="openAcceptance" style="flex: 1; background: #1e293b; border-radius: 16rpx; padding: 28rpx 0; text-align: center; font-size: 28rpx; font-weight: 600; color: #fff;">上传影像</view>
      </view>
    </view>
  </view>

  <!-- 编辑排期弹窗 -->
  <view wx:if="{{showSubNodeEdit}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300; display: flex; align-items: center; justify-content: center;">
    <view bindtap="closeSubNodeEdit" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6);"></view>
    <view style="position: relative; z-index: 1; width: 84%; background: #fff; border-radius: 24rpx; padding: 48rpx 40rpx;">
      <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; margin-bottom: 8rpx; text-align: center;">编辑排期</view>
      <view style="font-size: 24rpx; color: #94a3b8; text-align: center; margin-bottom: 40rpx;">{{popupSub.name}}</view>

      <!-- 开工日期 -->
      <view style="margin-bottom: 32rpx;">
        <view style="font-size: 26rpx; color: #334155; font-weight: 600; margin-bottom: 16rpx;">预计开工日期</view>
        <picker mode="date" value="{{editSubStartDate}}" bindchange="onEditSubStartDateChange">
          <view style="padding: 28rpx 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 30rpx; color: #1e293b; font-weight: 500; border: 1rpx solid #e2e8f0;">{{editSubStartDate || '请选择日期'}}</view>
        </picker>
      </view>

      <!-- 完工日期 -->
      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 26rpx; color: #334155; font-weight: 600; margin-bottom: 16rpx;">预计完工日期</view>
        <picker mode="date" value="{{editSubEndDate}}" bindchange="onEditSubEndDateChange">
          <view style="padding: 28rpx 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 30rpx; color: #1e293b; font-weight: 500; border: 1rpx solid #e2e8f0;">{{editSubEndDate || '请选择日期'}}</view>
        </picker>
      </view>

      <view style="font-size: 22rpx; color: var(--amber-600); background: var(--amber-50); padding: 16rpx 20rpx; border-radius: 8rpx; margin-bottom: 36rpx; line-height: 1.6;">
        确认后，此工序之后的所有工序将自动顺延（跳过周末及法定节假日）
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeSubNodeEdit" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #475569; border-radius: 12rpx; border: none; padding: 24rpx 0; margin: 0;">取消</button>
        <button bindtap="confirmSubNodeEdit" style="flex: 1; font-size: 28rpx; background: #1e293b; color: #fff; border-radius: 12rpx; border: none; padding: 24rpx 0; margin: 0; font-weight: bold;">确认保存</button>
      </view>
    </view>
  </view>

  <!-- 施工影像档案弹窗 -->
  <view wx:if="{{showAcceptanceModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 300; display: flex; flex-direction: column;">
    <view style="background: #fff; flex: 1; overflow-y: auto; padding: 0 0 40rpx;">
      <!-- 顶部导航栏 -->
      <view style="display: flex; align-items: center; padding: 60rpx 32rpx 24rpx; border-bottom: 1rpx solid #f1f5f9; position: sticky; top: 0; background: #fff; z-index: 10;">
        <view bindtap="closeAcceptance" style="font-size: 28rpx; color: #64748b; padding: 8rpx 20rpx 8rpx 0; margin-right: 16rpx;">返回</view>
        <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; flex: 1;">{{popupSub.name}} · 施工影像</view>
        <view wx:if="{{acceptanceMode === 'edit'}}" style="font-size: 24rpx; color: var(--rose-600); background: var(--rose-50); padding: 8rpx 20rpx; border-radius: 20rpx;">编辑中</view>
      </view>

      <view style="padding: 32rpx;">
        <!-- 记录人 -->
        <view style="margin-bottom: 32rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">记录人</view>
          <view style="padding: 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; color: #1e293b; font-weight: 500;">{{userName}}</view>
        </view>

        <!-- 现场说明 -->
        <view style="margin-bottom: 32rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">现场说明</view>
          <textarea placeholder="填写施工情况说明（选填）..." bindinput="onAcceptanceRemarkInput" value="{{acceptanceRemark}}" style="width: 100%; height: 200rpx; background: #f8fafc; padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #1e293b;"></textarea>
        </view>

        <!-- 现场影像 -->
        <view style="margin-bottom: 40rpx;">
          <view style="font-size: 26rpx; color: #64748b; margin-bottom: 16rpx;">现场影像 <text style="color: var(--rose-600);">*</text></view>
          <view style="display: flex; flex-wrap: wrap; gap: 16rpx;">
            <view wx:for="{{acceptancePhotos}}" wx:key="url" style="position: relative; width: 200rpx; height: 200rpx;">
              <image wx:if="{{item.type === 'image' || !item.type}}" src="{{item.url || item}}" mode="aspectFill" style="width: 100%; height: 100%; border-radius: 12rpx; border: 1rpx solid #e2e8f0;" bindtap="previewAcceptancePhoto" data-index="{{index}}"></image>
              <video wx:else src="{{item.url}}" style="width: 100%; height: 100%; border-radius: 12rpx;"></video>
              <view catchtap="removeAcceptancePhoto" data-index="{{index}}" style="position: absolute; top: -12rpx; right: -12rpx; width: 44rpx; height: 44rpx; background: var(--rose-600); color: #fff; border-radius: 22rpx; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: bold; z-index: 10;">×</view>
            </view>
            <view wx:if="{{acceptancePhotos.length < 9}}" bindtap="chooseAcceptanceMedia" style="width: 200rpx; height: 200rpx; border-radius: 12rpx; background: #f8fafc; border: 2rpx dashed #cbd5e1; display: flex; flex-direction: column; align-items: center; justify-content: center;">
              <text style="font-size: 56rpx; color: #94a3b8; font-weight: 300; line-height: 1;">+</text>
              <text style="font-size: 22rpx; color: #94a3b8; margin-top: 8rpx;">上传影像</text>
            </view>
          </view>
        </view>

        <!-- 提交按钮 -->
        <button bindtap="submitAcceptance" style="width: 100%; background: #1e293b; color: #fff; font-size: 32rpx; font-weight: bold; border-radius: 16rpx; padding: 32rpx 0; border: none; margin: 0;">
          {{acceptanceMode === 'edit' ? '保存修改' : '提交现场记录'}}
        </button>
      </view>
    </view>
  </view>

  <!-- 修改工期弹窗 -->
  <view class="modal-mask" wx:if="{{showEditDurationModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 12rpx; color: #1e293b;">修改工期天数</view>
      <view style="font-size: 24rpx; color: #64748b; text-align: center; margin-bottom: 40rpx;">{{nodesList[editDurationMajorIdx].subNodes[editDurationSubIdx].name}}</view>

      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">工序天数（0 表示跳过此工序）</view>
        <input type="number" placeholder="输入天数" value="{{editDurationValue}}" bindinput="onEditDurationInput" style="width: 100%; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0;" />
      </view>

      <view style="font-size: 22rpx; color: var(--amber-600); background: var(--amber-50); padding: 16rpx; border-radius: 8rpx; margin-bottom: 40rpx;">
        修改后系统将自动重新推算后续所有工序的预计开/完工日期（自动跳过周末及法定节假日）。
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeEditDurationModal" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="confirmEditDuration" style="flex: 1; font-size: 28rpx; background: #1e293b; color: #fff; font-weight: bold;">保存并重算</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeEditDurationModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>


  <!-- 资料弹窗 -->
  <view class="modal-mask" wx:if="{{showFilesModal}}">
    <view class="modal-content" style="background: #fff; width: 90%; max-height: 80vh; border-radius: 20rpx; padding: 30rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100; overflow-y: auto;">
      <view style="font-size: 32rpx; font-weight: bold; margin-bottom: 30rpx; display: flex; justify-content: space-between; align-items: center;">
        <text>项目资料/图纸</text>
        <view bindtap="uploadProjectFile" style="font-size: 24rpx; color: var(--emerald-600); background: var(--emerald-50); padding: 8rpx 20rpx; border-radius: 30rpx;">+ 上传资料</view>
      </view>
      <view wx:if="{{project.files && project.files.length > 0}}">
        <view wx:for="{{project.files}}" wx:key="url" style="display: flex; justify-content: space-between; align-items: center; padding: 20rpx; background: #f8fafc; border-radius: 12rpx; margin-bottom: 16rpx;" bindtap="previewFile" data-url="{{item.url}}" data-type="{{item.type}}">
          <view style="display: flex; flex-direction: column;">
            <text style="font-size: 26rpx; color: #334155; font-weight: 500;">{{item.name || '附件文件'}}</text>
            <text style="font-size: 22rpx; color: #94a3b8; margin-top: 8rpx;">{{item.time}} | {{item.uploader}}</text>
          </view>
          <text style="font-size: 24rpx; color: #4a403a; background: #fff; padding: 6rpx 16rpx; border-radius: 8rpx; border: 1rpx solid #e2e8f0;">查看</text>
        </view>
      </view>
      <view wx:else style="padding: 60rpx 0; text-align: center; color: #94a3b8; font-size: 26rpx;">暂无项目资料</view>
      <button bindtap="closeFiles" style="margin-top: 30rpx; background: #f1f5f9; color: #475569; font-size: 28rpx;">关闭</button>
    </view>
    <view class="modal-bg" bindtap="closeFiles" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 延误停工弹窗 -->
  <view class="modal-mask" wx:if="{{showDelayModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx; color: #be123c;">记录停工 / 延误</view>
      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">延误天数</view>
        <input type="number" placeholder="输入延误天数" value="{{delayDays}}" bindinput="onDelayDaysInput" style="width: 100%; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;" />
      </view>
      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">延误原因</view>
        <textarea placeholder="说明延误或停工的具体原因..." value="{{delayReason}}" bindinput="onDelayReasonInput" style="width: 100%; height: 140rpx; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box;"></textarea>
      </view>
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeDelayModal" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="confirmDelay" style="flex: 1; font-size: 28rpx; background: var(--rose-600); color: #fff; font-weight: bold;">确认记录并重算</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeDelayModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 开工弹窗 -->
  <view class="modal-mask" wx:if="{{isStartingProject}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx;">准备开工</view>
      <view style="margin-bottom: 30rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">项目总开工日期</view>
        <picker mode="date" value="{{baseStartDate}}" bindchange="onStartDateChange">
          <view style="width: 100%; padding: 20rpx; background: #f8fafc; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155; font-weight: 500; text-align: center;">{{baseStartDate || '请选择日期'}}</view>
        </picker>
        <view style="font-size: 22rpx; color: #94a3b8; margin-top: 10rpx;">系统将自动按 T+N 算法推算所有工序的预计开/完工日期，自动跳过周末及法定节假日。</view>
      </view>
      <view style="margin-bottom: 40rpx; display: flex; align-items: center; justify-content: space-between; background: #f1f5f9; padding: 20rpx; border-radius: 8rpx;">
        <view style="font-size: 26rpx; color: #334155;">裁剪不需要的工序</view>
        <switch checked="{{isEditingNodes}}" bindchange="toggleEditNodes" color="var(--amber-600)" style="transform: scale(0.8);" />
      </view>
      <view wx:if="{{isEditingNodes}}" style="font-size: 22rpx; color: var(--amber-600); margin-bottom: 30rpx; background: var(--amber-50); padding: 16rpx; border-radius: 8rpx;">
        裁剪模式已开启，在背景列表中点击红色 × 删除不需要的工序，完成后点击确认开工。
      </view>
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeStartModal" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="confirmStartProject" style="flex: 1; font-size: 28rpx; background: var(--amber-600); color: #fff; font-weight: bold;">确认开工</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeStartModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>

  <!-- 编辑项目概况弹窗 -->
  <view class="modal-mask" wx:if="{{showEditProjectModal}}" style="z-index: 9999;">
    <view class="modal-content" style="background: #fff; width: 90%; border-radius: 20rpx; padding: 40rpx; position: fixed; top: 50%; left: 50%; bottom: auto; transform: translate(-50%, -50%); z-index: 10000; box-sizing: border-box;">
      <view style="font-size: 34rpx; font-weight: bold; text-align: center; margin-bottom: 40rpx; color: #1e293b;">编辑工地信息</view>
      
      <view style="margin-bottom: 30rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">实际开工日期</view>
        <picker mode="date" value="{{editProjectStartDate}}" bindchange="onEditProjectStartDateChange">
          <view style="width: 100%; height: 88rpx; line-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155; font-weight: 500;">
            {{editProjectStartDate || '请选择日期'}}
          </view>
        </picker>
      </view>

      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 24rpx; color: #64748b; margin-bottom: 12rpx;">项目经理</view>
        <input type="text" placeholder="输入项目经理姓名" value="{{editProjectManager}}" bindinput="onEditProjectManagerInput" style="width: 100%; height: 88rpx; min-height: 88rpx; padding: 0 24rpx; background: #f8fafc; border-radius: 12rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0; color: #334155;" />
      </view>

      <view style="font-size: 22rpx; color: var(--amber-600); background: var(--amber-50); padding: 16rpx 20rpx; border-radius: 8rpx; margin-bottom: 40rpx; line-height: 1.5;">
        提示：修改开工日期后，系统将自动重新推算所有相关工序的开始和结束日期（跳过周末及节假日）。
      </view>
      
      <view style="display: flex; gap: 20rpx; margin-bottom: 24rpx;">
        <button bindtap="closeEditProjectModal" style="flex: 1; font-size: 30rpx; background: #f1f5f9; color: #475569; border-radius: 12rpx; border: none; padding: 16rpx 0; margin: 0;">取消</button>
        <button bindtap="confirmEditProject" style="flex: 1; font-size: 30rpx; background: #4a403a; color: #fff; border-radius: 12rpx; border: none; padding: 16rpx 0; margin: 0; font-weight: bold;">保存修改</button>
      </view>

      <view style="margin-top: 16rpx;">
        <view bindtap="deleteProject" style="width: 100%; font-size: 28rpx; font-weight: bold; background: #f8fafc; color: var(--rose-600); border-radius: 12rpx; text-align: center; padding: 24rpx 0; box-sizing: border-box;">删除此工地记录</view>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeEditProjectModal" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999;"></view>
  </view>

  <view style="height: calc(240rpx + env(safe-area-inset-bottom));"></view>
</view>


