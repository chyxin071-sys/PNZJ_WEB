<view class="page-container" wx:if="{{!loading && project}}">
  
  <!-- 顶部项目概览卡片 -->
  <view class="top-overview-card" style="background: #fff; border-radius: 20rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); position: relative; overflow: hidden;">
    <!-- 装饰背景 -->
    <view style="position: absolute; top: 0; right: 0; width: 160rpx; height: 160rpx; background: linear-gradient(135deg, rgba(74,64,58,0.05) 0%, transparent 100%); border-bottom-left-radius: 160rpx; z-index: 0;">  <!-- 弹窗部分 -->
  
  <!-- 1. 开工与裁剪节点弹窗 -->
  <view class="modal-mask" wx:if="{{isStartingProject}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 40rpx;">
    <view class="modal-content" style="background: #fff; width: 100%; border-radius: 24rpx; padding: 40rpx; position: relative;">
      <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; text-align: center; margin-bottom: 40rpx;">准备开工与工序裁剪</view>
      
      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">选择总开工日期 <text style="color: #ef4444;">*</text></view>
        <picker mode="date" bindchange="onStartDateChange" value="{{baseStartDate}}">
          <view style="width: 100%; height: 80rpx; background: #f8fafc; border-radius: 12rpx; padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box; display: flex; align-items: center;">{{baseStartDate}}</view>
        </picker>
        <view style="font-size: 20rpx; color: #94a3b8; margin-top: 8rpx;">系统将自动使用(T+N)算法排期。</view>
      </view>

      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">裁剪不需要的小节点</view>
        <view bindtap="toggleEditNodes" style="width: 100%; text-align: center; height: 80rpx; line-height: 80rpx; background: {{isEditingNodes ? '#f1f5f9' : '#fff'}}; border: 1rpx solid #e2e8f0; border-radius: 12rpx; font-size: 28rpx; color: #475569;">
          {{isEditingNodes ? '结束裁剪，点击下方确认' : '开启裁剪模式 (点击背景中的X删除)'}}
        </view>
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeStartModal" style="flex: 1; font-size: 30rpx; background: #f1f5f9; color: #475569; padding: 20rpx 0; border-radius: 12rpx;">取消</button>
        <button bindtap="confirmStartProject" style="flex: 1; font-size: 30rpx; background: #4a403a; color: #fff; padding: 20rpx 0; border-radius: 12rpx;">确认开工</button>
      </view>
    </view>
  </view>

  <!-- 2. 添加延误记录弹窗 -->
  <view class="modal-mask" wx:if="{{showDelayModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 40rpx;">
    <view class="modal-content" style="background: #fff; width: 100%; border-radius: 24rpx; padding: 40rpx; position: relative;">
      <view style="font-size: 32rpx; font-weight: bold; color: #e11d48; text-align: center; margin-bottom: 40rpx;">记录停工 / 延误</view>
      
      <view style="margin-bottom: 24rpx;">
        <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">延误天数 <text style="color: #ef4444;">*</text></view>
        <input type="number" value="{{delayDays}}" bindinput="onDelayDaysInput" style="width: 100%; height: 80rpx; background: #f8fafc; border-radius: 12rpx; padding: 0 24rpx; font-size: 28rpx; box-sizing: border-box;" />
      </view>

      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">延误原因 <text style="color: #ef4444;">*</text></view>
        <textarea value="{{delayReason}}" bindinput="onDelayReasonInput" placeholder="例如：等主材进场" style="width: 100%; height: 120rpx; background: #f8fafc; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; box-sizing: border-box;"></textarea>
      </view>

      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeDelayModal" style="flex: 1; font-size: 30rpx; background: #f1f5f9; color: #475569; padding: 20rpx 0; border-radius: 12rpx;">取消</button>
        <button bindtap="confirmDelay" style="flex: 1; font-size: 30rpx; background: #e11d48; color: #fff; padding: 20rpx 0; border-radius: 12rpx;">确认并重算</button>
      </view>
    </view>
  </view>

  <!-- 3. 子节点验收弹窗 -->
  <view class="modal-mask" wx:if="{{showSubNodeModal}}" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 1000; display: flex; align-items: flex-end;">
    <view class="modal-content" style="background: #fff; width: 100%; border-radius: 32rpx 32rpx 0 0; padding: 40rpx; position: relative;">
      <view style="font-size: 32rpx; font-weight: bold; color: #1e293b; margin-bottom: 40rpx; display: flex; justify-content: space-between;">
        <text>工序验收: {{nodesList[subNodeMajorIdx].subNodes[subNodeIdx].name}}</text>
        <text bindtap="closeSubNodeModal" style="color: #94a3b8;">×</text>
      </view>
      
      <view style="margin-bottom: 30rpx;">
        <view style="font-size: 26rpx; color: #64748b; margin-bottom: 16rpx;">现场照片 (最多9张) <text style="color: #ef4444;">*</text></view>
        <view style="display: flex; flex-wrap: wrap; gap: 16rpx;">
          <image wx:for="{{subNodePhotos}}" wx:key="*this" src="{{item}}" mode="aspectFill" style="width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f1f5f9;"></image>
          <view wx:if="{{subNodePhotos.length < 9}}" bindtap="chooseSubPhotos" style="width: 140rpx; height: 140rpx; border-radius: 12rpx; border: 2rpx dashed #cbd5e1; display: flex; align-items: center; justify-content: center; background: #f8fafc;">
            <text style="font-size: 40rpx; color: #94a3b8;">+</text>
          </view>
        </view>
      </view>

      <view style="margin-bottom: 40rpx;">
        <view style="font-size: 26rpx; color: #64748b; margin-bottom: 12rpx;">验收说明 / 备注</view>
        <textarea value="{{subNodeRemark}}" bindinput="onSubRemarkInput" placeholder="填写相关施工情况说明..." style="width: 100%; height: 160rpx; background: #f8fafc; border-radius: 12rpx; padding: 20rpx 24rpx; font-size: 28rpx; box-sizing: border-box; border: 1rpx solid #e2e8f0;"></textarea>
      </view>

      <view style="display: flex; gap: 20rpx; padding-bottom: env(safe-area-inset-bottom);">
        <button bindtap="submitSubNode" data-result="rejected" style="flex: 1; font-size: 30rpx; background: #fff1f2; color: #e11d48; border: 1rpx solid #fecdd3; padding: 20rpx 0; border-radius: 12rpx; font-weight: bold;">驳回整改</button>
        <button bindtap="submitSubNode" data-result="approved" style="flex: 1; font-size: 30rpx; background: #10b981; color: #fff; padding: 20rpx 0; border-radius: 12rpx; font-weight: bold;">通过验收</button>
      </view>
    </view>
  </view>

</view>
    
    <view style="position: relative; z-index: 1;">
      <!-- 标题和健康状态 -->
      <view style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx;">
        <view style="font-size: 36rpx; font-weight: bold; color: #1e293b; flex: 1; padding-right: 20rpx; line-height: 1.4;">{{project.address || '未知小区'}}</view>
        <view class="health-badge {{project.health === '严重延期' ? 'bg-rose-50 text-rose-600' : (project.health === '预警' ? 'bg-amber-50 text-amber-600' : 'bg-emerald-50 text-emerald-600')}}" style="font-size: 22rpx; font-weight: bold; padding: 6rpx 16rpx; border-radius: 30rpx; flex-shrink: 0; border: 1rpx solid {{project.health === '严重延期' ? '#ffe4e6' : (project.health === '预警' ? '#fef3c7' : '#d1fae5')}};">
          {{project.health || '正常'}}
        </view>
      </view>

      <!-- 客户信息 -->
      <view style="display: flex; align-items: center; margin-bottom: 30rpx; flex-wrap: wrap;">
        <text style="font-size: 28rpx; font-weight: 500; color: #334155; margin-right: 12rpx;">{{project.customer}}</text>
        <text style="font-size: 22rpx; color: #94a3b8; font-family: monospace; margin-right: 16rpx;">{{project.customerNo || project.leadId}}</text>
        <text style="font-size: 24rpx; color: #cbd5e1; margin-right: 16rpx;">|</text>
        <text style="font-size: 26rpx; color: #64748b;">{{project.phone || '暂无电话'}}</text>
      </view>

      <!-- 核心数据网格 -->
      <view style="display: grid; grid-template-columns: 1fr 1fr 1fr 1fr; gap: 16rpx; background: #f8fafc; padding: 20rpx; border-radius: 12rpx;">
        <view style="display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">开工日期</text>
          <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.startDate || '未定'}}</text>
        </view>
        <view style="display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">预计完工</text>
          <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.endDate || project.expectedEndDate || '-'}}</text>
        </view>
        <view style="display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">项目经理</text>
          <text style="font-size: 24rpx; font-weight: 500; color: #334155;">{{project.manager || '-'}}</text>
        </view>
        <view style="display: flex; flex-direction: column;">
          <text style="font-size: 20rpx; color: #94a3b8; margin-bottom: 6rpx;">已耗时</text>
          <view style="display: flex; align-items: baseline;">
            <text style="font-size: 28rpx; font-weight: bold; color: #f59e0b;">{{project.daysElapsed || 0}}</text>
            <text style="font-size: 20rpx; color: #f59e0b; margin-left: 4rpx; opacity: 0.8;">天</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作区 -->
  <view style="display: flex; justify-content: space-between; gap: 20rpx; margin-bottom: 24rpx;">
    <view wx:if="{{project.status === '未开工'}}" bindtap="startProjectModal" style="flex: 1; background: #f59e0b; padding: 24rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 4rpx 12rpx rgba(245,158,11,0.2);">
      <text style="font-size: 26rpx; font-weight: bold; color: #fff;">▶ 准备开工(裁剪节点)</text>
    </view>
    <view wx:else bindtap="viewFiles" style="flex: 1; background: #fff; padding: 24rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02); border: 1rpx solid #f1f5f9;">
      <text style="font-size: 26rpx; font-weight: bold; color: #4a403a;">📁 项目资料/图纸</text>
    </view>
    <view bindtap="goToQuote" style="flex: 1; background: #fff; padding: 24rpx 0; border-radius: 16rpx; display: flex; align-items: center; justify-content: center; box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02); border: 1rpx solid #f1f5f9;">
      <text style="font-size: 26rpx; font-weight: bold; color: #4a403a;">📄 关联报价单</text>
    </view>
  </view>

  <!-- 8大施工节点管控看板 -->
  <view style="background: #fff; border-radius: 20rpx; box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03); overflow: hidden; margin-bottom: 60rpx;">
    <!-- 头部栏 -->
    <view style="padding: 24rpx 32rpx; background: rgba(248,250,252,0.8); border-bottom: 1rpx solid #f1f5f9; display: flex; justify-content: space-between; align-items: center;">
      <view style="font-size: 30rpx; font-weight: bold; color: #1e293b; display: flex; align-items: center;">
        <view style="width: 8rpx; height: 28rpx; background: #4a403a; border-radius: 4rpx; margin-right: 16rpx;"></view>
        8大施工节点管控
      </view>
      <view style="font-size: 24rpx; color: #64748b; font-family: monospace;">
        当前: <text style="font-weight: bold; color: #1e293b;">{{nodesList[currentNodeIndex].name || '-'}}</text>
      </view>
    </view>
    
    <!-- 时间轴列表 -->
    <view style="padding: 32rpx; position: relative;">
      <!-- 左侧贯穿连接线 -->
      <view style="position: absolute; left: 58rpx; top: 50rpx; bottom: 50rpx; width: 4rpx; background: #f1f5f9; border-radius: 2rpx; z-index: 0;"></view>

      <view wx:for="{{nodesList}}" wx:key="name" wx:for-index="idx" style="position: relative; z-index: 1; display: flex; margin-bottom: 40rpx;">
        
        <!-- 左侧状态图标圈 -->
        <view style="width: 56rpx; flex-shrink: 0; display: flex; justify-content: center; margin-right: 24rpx; padding-top: 8rpx;">
          <view wx:if="{{item.status === 'completed'}}" style="width: 48rpx; height: 48rpx; background: #1e293b; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);">
            <text style="color: #fff; font-size: 24rpx; font-weight: bold;">✓</text>
          </view>
          <view wx:elif="{{item.status === 'current'}}" style="width: 48rpx; height: 48rpx; background: #f59e0b; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fef3c7;">
            <text style="color: #fff; font-size: 24rpx; font-weight: bold;">▶</text>
          </view>
          <view wx:else style="width: 48rpx; height: 48rpx; background: #f1f5f9; border-radius: 24rpx; display: flex; align-items: center; justify-content: center; border: 4rpx solid #fff;">
            <text style="color: #94a3b8; font-size: 22rpx; font-weight: bold; font-family: monospace;">{{idx + 1}}</text>
          </view>
        </view>

        <!-- 右侧内容卡片 -->
        <view style="flex: 1; background: {{item.status === 'current' ? '#fff' : (item.status === 'completed' ? '#fff' : '#f8fafc')}}; border: 1rpx solid {{item.status === 'current' ? '#fcd34d' : '#f1f5f9'}}; border-radius: 16rpx; overflow: hidden; transition: all 0.3s; box-shadow: {{item.status === 'current' ? '0 4rpx 12rpx rgba(245,158,11,0.05)' : 'none'}};">
          
          <!-- 卡片头部 (可点击展开) -->
          <view bindtap="toggleNode" data-index="{{idx}}" style="padding: 24rpx; display: flex; justify-content: space-between; align-items: center;">
            <view>
              <view style="font-size: 30rpx; font-weight: bold; margin-bottom: 8rpx; color: {{item.status === 'current' ? '#d97706' : (item.status === 'completed' ? '#1e293b' : '#94a3b8')}};">
                {{item.name}}
              </view>
              <view style="font-size: 22rpx; color: #64748b;">
                <text wx:if="{{item.status === 'completed'}}">已完成: {{item.startDate}} ~ {{item.endDate}}</text>
                <text wx:elif="{{item.status === 'current'}}">进行中 | 预计: {{item.endDate}}</text>
                <text wx:else>未开始 | 预计: {{item.startDate}} ~ {{item.endDate}}</text>
              </view>
            </view>
            <view style="display: flex; align-items: center; gap: 16rpx;">
              <view wx:if="{{item.status === 'current'}}" catchtap="completeNode" data-index="{{idx}}" style="background: #f59e0b; color: #fff; font-size: 22rpx; font-weight: bold; padding: 10rpx 24rpx; border-radius: 30rpx; box-shadow: 0 2rpx 8rpx rgba(245,158,11,0.2);">
                验收完成
              </view>
              <view style="transform: {{item.expanded ? 'rotate(180deg)' : 'rotate(0)'}}; transition: 0.3s; font-size: 24rpx; color: #cbd5e1;">▼</view>
            </view>
          </view>

          <!-- 展开详情 (施工工序与留痕) -->
          <view wx:if="{{item.expanded}}" style="padding: 0 24rpx 24rpx; background: rgba(248,250,252,0.5); border-top: 1rpx solid #f1f5f9; padding-top: 20rpx;">
            <!-- 小工序标签 -->
            <view style="margin-bottom: 24rpx;">
              <view style="font-size: 22rpx; color: #94a3b8; margin-bottom: 16rpx;">包含施工工序</view>
              <view style="display: flex; flex-wrap: wrap; gap: 12rpx;">
                <view wx:for="{{item.subNodes}}" wx:for-item="sub" wx:for-index="subIdx" wx:key="name" 
                      bindtap="openSubNodeModal" data-major="{{idx}}" data-sub="{{subIdx}}"
                      style="position: relative; font-size: 22rpx; padding: 6rpx 16rpx; border-radius: 30rpx; border: 1rpx solid {{sub.status==='approved' ? '#a7f3d0' : (sub.status==='rejected' ? '#fecdd3' : '#e2e8f0')}}; background: {{sub.status==='approved' ? '#ecfdf5' : (sub.status==='rejected' ? '#fff1f2' : '#fff')}}; color: {{sub.status==='approved' ? '#047857' : (sub.status==='rejected' ? '#be123c' : '#475569')}};">
                  {{sub.status==='approved' ? '✓ ' : (sub.status==='rejected' ? '⚠ ' : '')}}{{sub.name}}
                  
                  <!-- 删除按钮 -->
                  <view wx:if="{{isEditingNodes && project.status === '未开工'}}" catchtap="removeSubNode" data-major="{{idx}}" data-sub="{{subIdx}}" style="position: absolute; top: -10rpx; right: -10rpx; width: 28rpx; height: 28rpx; background: #ef4444; color: #fff; border-radius: 14rpx; display: flex; align-items: center; justify-content: center; font-size: 18rpx; font-weight: bold; z-index: 10;">×</view>
                </view>
              </view>
            </view>

            <!-- 延误记录 -->
            <view style="margin-bottom: 24rpx;">
              <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;">
                <text style="font-size: 22rpx; color: #94a3b8;">项目延误/停工记录</text>
                <text wx:if="{{(item.status === 'current' || item.status === 'pending') && project.status !== '未开工'}}" bindtap="openDelayModal" data-index="{{idx}}" style="font-size: 22rpx; color: #ef4444; font-weight: bold; background: #fef2f2; padding: 4rpx 12rpx; border-radius: 8rpx;">+ 记录延误</text>
              </view>
              <view wx:if="{{item.delayRecords && item.delayRecords.length > 0}}">
                <view wx:for="{{item.delayRecords}}" wx:for-item="delay" wx:key="createdAt" style="background: #fff1f2; padding: 16rpx; border-radius: 8rpx; margin-bottom: 12rpx; border: 1rpx solid #fecdd3; display: flex; justify-content: space-between; align-items: center;">
                  <text style="font-size: 24rpx; color: #be123c; font-weight: bold;">停工延误: {{delay.days}} 天</text>
                  <text style="font-size: 20rpx; color: #f43f5e;">{{delay.reason}}</text>
                </view>
              </view>
            </view>

            <!-- 验收记录 -->
            <view>
              <view style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx;">
                <text style="font-size: 22rpx; color: #94a3b8;">验收留痕记录</text>
                <text wx:if="{{item.status === 'current' || item.status === 'completed'}}" bindtap="openUpload" data-index="{{idx}}" style="font-size: 22rpx; color: #10b981; font-weight: bold;">+ 添加记录</text>
              </view>
              
              <block wx:if="{{item.records && item.records.length > 0}}">
                <view wx:for="{{item.records}}" wx:for-item="record" wx:key="time" style="background: #fff; padding: 20rpx; border-radius: 12rpx; border: 1rpx solid #e2e8f0; margin-bottom: 16rpx;">
                  <view style="display: flex; justify-content: space-between; margin-bottom: 12rpx;">
                    <text style="font-size: 24rpx; font-weight: bold; color: #334155;">{{record.uploader}}</text>
                    <text style="font-size: 22rpx; color: #94a3b8;">{{record.time}}</text>
                  </view>
                  <view wx:if="{{record.desc}}" style="font-size: 26rpx; color: #475569; margin-bottom: 16rpx; line-height: 1.4;">{{record.desc}}</view>
                  <view wx:if="{{record.files && record.files.length > 0}}" style="display: flex; flex-wrap: wrap; gap: 12rpx;">
                    <image wx:for="{{record.files}}" wx:for-item="file" wx:key="url" src="{{file.url}}" mode="aspectFill" style="width: 110rpx; height: 110rpx; border-radius: 8rpx; background: #f1f5f9; border: 1rpx solid #e2e8f0;" wx:if="{{file.type === 'image'}}"></image>
                  </view>
                </view>
              </block>
              <view wx:else style="padding: 30rpx 0; text-align: center; background: #fff; border-radius: 12rpx; border: 1rpx dashed #cbd5e1;">
                <text style="font-size: 24rpx; color: #94a3b8;">暂无验收记录</text>
              </view>
            </view>
          </view>
          
        </view>
      </view>
    </view>
  </view>
  
  <!-- 上传弹窗 -->
  <view class="modal-mask" wx:if="{{showUploadModal}}">
    <view class="modal-content" style="background: #fff; width: 85%; border-radius: 16rpx; padding: 30rpx; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 100;">
      <view style="font-size: 32rpx; font-weight: bold; text-align: center; margin-bottom: 30rpx;">添加验收记录</view>
      <textarea placeholder="输入文字说明..." bindinput="onDescInput" value="{{uploadDesc}}" style="width: 100%; height: 160rpx; background: #f8fafc; padding: 20rpx; border-radius: 8rpx; font-size: 28rpx; box-sizing: border-box; margin-bottom: 20rpx;"></textarea>
      
      <view class="media-grid" style="display: flex; flex-wrap: wrap; gap: 10rpx; margin-bottom: 30rpx;">
        <block wx:for="{{uploadFiles}}" wx:key="url">
          <image src="{{item.url}}" mode="aspectFill" style="width: 120rpx; height: 120rpx; border-radius: 8rpx;" wx:if="{{item.type === 'image'}}"></image>
          <video src="{{item.url}}" style="width: 120rpx; height: 120rpx; border-radius: 8rpx;" wx:if="{{item.type === 'video'}}"></video>
        </block>
        <view class="upload-btn" bindtap="chooseMedia" style="width: 120rpx; height: 120rpx; border-radius: 8rpx; background: #f1f5f9; display: flex; align-items: center; justify-content: center; font-size: 40rpx; color: #94a3b8;">+</view>
      </view>
      
      <view style="display: flex; gap: 20rpx;">
        <button bindtap="closeUpload" style="flex: 1; font-size: 28rpx; background: #f1f5f9; color: #333;">取消</button>
        <button bindtap="submitUpload" style="flex: 1; font-size: 28rpx; background: #4a403a; color: #fff;">提交</button>
      </view>
    </view>
    <view class="modal-bg" bindtap="closeUpload" style="position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 99;"></view>
  </view>
</view>