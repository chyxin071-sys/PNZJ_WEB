.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 100rpx; background: white; display: flex; padding-bottom: env(safe-area-inset-bottom); border-top: 1rpx solid #f1f5f9; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.02); z-index: 9999; }
.tab-bar-item { flex: 1; display: flex; justify-content: center; align-items: center; }
.icon-wrap { width: 80rpx; height: 80rpx; display: flex; align-items: center; justify-content: center; color: #cbd5e1; transition: all 0.2s; border-radius: 20rpx; }
.icon-wrap.active { color: #4a403a; }
.icon { box-sizing: border-box; flex-shrink: 0; }

/* CSS Icons - All exactly 44x44 perfectly balanced */

/* 1. Todo: Check square */
.icon-todo { width: 44rpx; height: 44rpx; border: 4rpx solid currentColor; border-radius: 12rpx; position: relative; }
.icon-todo::after { content: ''; position: absolute; top: 4rpx; left: 12rpx; width: 10rpx; height: 18rpx; border: 4rpx solid currentColor; border-top: none; border-left: none; transform: rotate(45deg); box-sizing: border-box; }

/* 2. Leads: Person Outline */
.icon-leads { width: 44rpx; height: 44rpx; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.icon-leads::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 22rpx; height: 22rpx; border: 4rpx solid currentColor; border-radius: 50%; box-sizing: border-box; }
.icon-leads::after { content: ''; width: 44rpx; height: 18rpx; border: 4rpx solid currentColor; border-bottom: none; border-radius: 22rpx 22rpx 0 0; box-sizing: border-box; }

/* 3. Projects: Hammer */
.icon-projects { width: 44rpx; height: 44rpx; position: relative; transform: rotate(45deg); box-sizing: border-box; }
.icon-projects::before { content: ''; position: absolute; top: 0; left: 4rpx; width: 36rpx; height: 16rpx; border: 4rpx solid currentColor; border-radius: 8rpx; box-sizing: border-box; }
.icon-projects::after { content: ''; position: absolute; top: 12rpx; left: 16rpx; width: 12rpx; height: 28rpx; background: currentColor; border-radius: 4rpx; box-sizing: border-box; }

/* 4. Profile: Layout Grid (old Projects) */
.icon-profile { width: 44rpx; height: 44rpx; border: 4rpx solid currentColor; border-radius: 12rpx; position: relative; box-sizing: border-box; }
.icon-profile::before { content: ''; position: absolute; top: 16rpx; left: 0; right: 0; height: 4rpx; background: currentColor; }
.icon-profile::after { content: ''; position: absolute; top: 20rpx; bottom: 0; left: 16rpx; width: 4rpx; background: currentColor; }