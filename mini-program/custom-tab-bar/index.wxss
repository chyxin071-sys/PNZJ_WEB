.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; height: 130rpx; background: white; display: flex; padding-bottom: env(safe-area-inset-bottom); border-top: 1rpx solid #f1f5f9; box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.02); z-index: 9999; }
.tab-bar-item { flex: 1; display: flex; justify-content: center; align-items: center; }
.icon-wrap { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #cbd5e1; transition: all 0.2s; gap: 8rpx; }
.icon-wrap.active { color: #4a403a; }
.icon { box-sizing: border-box; flex-shrink: 0; }
.tab-text { font-size: 22rpx; font-weight: bold; color: inherit; line-height: 1; margin-top: 4rpx; }

/* CSS Icons - All scaled slightly down to fit text */

/* 1. Todo: Check square */
.icon-todo { width: 36rpx; height: 36rpx; border: 4rpx solid currentColor; border-radius: 10rpx; position: relative; }
.icon-todo::after { content: ''; position: absolute; top: 2rpx; left: 10rpx; width: 8rpx; height: 16rpx; border: 4rpx solid currentColor; border-top: none; border-left: none; transform: rotate(45deg); box-sizing: border-box; }

/* 2. Leads: Person Outline */
.icon-leads { width: 36rpx; height: 36rpx; position: relative; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; }
.icon-leads::before { content: ''; position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 18rpx; height: 18rpx; border: 4rpx solid currentColor; border-radius: 50%; box-sizing: border-box; }
.icon-leads::after { content: ''; width: 36rpx; height: 14rpx; border: 4rpx solid currentColor; border-bottom: none; border-radius: 18rpx 18rpx 0 0; box-sizing: border-box; }

/* 3. Projects: Hammer */
.icon-projects { width: 36rpx; height: 36rpx; position: relative; transform: rotate(45deg); box-sizing: border-box; }
.icon-projects::before { content: ''; position: absolute; top: 2rpx; left: 4rpx; width: 28rpx; height: 14rpx; border: 4rpx solid currentColor; border-radius: 6rpx; box-sizing: border-box; }
.icon-projects::after { content: ''; position: absolute; top: 12rpx; left: 14rpx; width: 8rpx; height: 22rpx; background: currentColor; border-radius: 4rpx; box-sizing: border-box; }

/* 4. Message: Bubble */
.icon-message { width: 36rpx; height: 36rpx; border: 4rpx solid currentColor; border-radius: 12rpx; position: relative; box-sizing: border-box; }
.icon-message::before { content: ''; position: absolute; bottom: -8rpx; left: 4rpx; border-width: 6rpx 6rpx 0 0; border-style: solid; border-color: currentColor transparent transparent transparent; transform: skewX(-20deg); }

.badge { position: absolute; top: -10rpx; right: -16rpx; background: #ef4444; color: white; font-size: 20rpx; padding: 2rpx 8rpx; border-radius: 20rpx; font-weight: bold; border: 2rpx solid #fff; line-height: 1; }