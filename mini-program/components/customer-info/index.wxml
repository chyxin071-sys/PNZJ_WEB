<view class="customer-info" style="{{customStyle}}">
  <view class="top-row">
    <text class="name">{{name}}</text>
    <view class="tag" wx:if="{{displayNo}}">
      <text class="tag-prefix">NO.</text>{{displayNo}}
    </view>
  </view>
  <view class="bottom-row">
    <text class="phone">{{formattedPhone}}</text>
  </view>
</view>